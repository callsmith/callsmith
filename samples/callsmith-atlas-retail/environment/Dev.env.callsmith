{
  "environmentId": "cc85431f-6715-4d2e-89f8-070e9f4ab101",
  "name": "Dev",
  "color": "#22c55e",
  "variables": [
    {
      "name": "protocol",
      "value": "https"
    },
    {
      "name": "domain-root",
      "value": "north-api.dev.atlasretail.example"
    },
    {
      "name": "tenant-subdomain",
      "value": "tenant-spruce"
    },
    {
      "name": "base-url",
      "value": "{{protocol}}://{{tenant-subdomain}}.{{domain-root}}/{{api-version}}"
    },
    {
      "name": "tenant-id",
      "value": "tenant-spruce"
    },
    {
      "name": "region",
      "value": "us-east-1"
    },
    {
      "name": "featured-product-id",
      "value": "SKU-100045"
    },
    {
      "name": "page-number",
      "value": "1"
    },
    {
      "name": "search-term",
      "value": "wireless headset"
    },
    {
      "name": "idempotency-key",
      "value": "{{request-id}}"
    },
    {
      "name": "order-note-template",
      "value": "Demo order for {{tenant-id}} in {{region}}"
    },
    {
      "name": "auth-email",
      "value": "dev.engineer@atlasretail.example"
    },
    {
      "name": "auth-password",
      "value": "",
      "isSecret": true
    }
  ]
}

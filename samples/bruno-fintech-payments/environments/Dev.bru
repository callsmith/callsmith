  primary-account-id: ACC-001948
  latest-payment-id: PAY-0003772
  session-access-token: paste-access-token-here
  session-refresh-token: paste-refresh-token-here
  auth-email: dev.analyst@northbank.example
}

vars:secret [
  auth-password
]

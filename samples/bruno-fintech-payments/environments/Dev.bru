  institution-id: northbank-dev
  customer-id: CUST-000812
  counterparty-iban: DE89370400440532013000
  region: us-east-1
  currency: USD
  transfer-amount: 250.00
  request-id: 9e981e84-3254-4911-bf69-c3953fec84bb

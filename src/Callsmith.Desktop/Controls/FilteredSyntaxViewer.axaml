<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="400"
             x:Class="Callsmith.Desktop.Controls.FilteredSyntaxViewer">

  <Grid RowDefinitions="Auto,*"
        Background="#1e1e1e">
    <Border x:Name="FilterBar"
            Grid.Row="0"
            Background="#1e1e1e"
            BorderBrush="#343434"
            BorderThickness="0,0,0,1"
            Padding="8,6,8,6"
            IsVisible="False">
      <StackPanel Spacing="4">
        <StackPanel Orientation="Horizontal"
              Spacing="4"
              MinHeight="16">
          <TextBlock x:Name="FilterLabelTextBlock"
                     Foreground="#888"
                     FontWeight="Bold"
                     FontSize="10"
                     LetterSpacing="1"
                     VerticalAlignment="Center"
                     Text="FILTER"/>
          <Border x:Name="JsonPathHelpButton"
                  Width="14"
                  Height="14"
                  CornerRadius="7"
                  Background="#3a3a3a"
                  BorderBrush="#555"
                  BorderThickness="1"
                  VerticalAlignment="Center"
                  Cursor="Help"
                  IsVisible="False">
            <ToolTip.Tip>
              <ToolTip MaxWidth="380">
                <StackPanel Spacing="6">
                  <TextBlock Text="JSONPath Filter"
                             FontWeight="SemiBold"
                             FontSize="12"
                             Foreground="#d4d4d4"/>
                  <TextBlock TextWrapping="Wrap"
                             FontSize="11"
                             Foreground="#aaa"
                             Text="Fully compliant with RFC 9535. Supports all standard selectors: property access, array indexes, slices, wildcards, recursive descent, and filter expressions with comparison and logical operators."/>
                  <TextBlock Text="Sort extensions (arrays only)"
                             FontWeight="SemiBold"
                             FontSize="11"
                             Foreground="#d4d4d4"
                             Margin="0,2,0,0"/>
                  <Grid ColumnDefinitions="Auto,*"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                        Margin="4,0,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               FontFamily="Consolas,Menlo,monospace"
                               FontSize="11"
                               Foreground="#9cdcfe"
                               Text="sort(field)"
                               Margin="0,0,10,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               FontSize="11"
                               Foreground="#aaa"
                               TextWrapping="Wrap"
                               Text="Sort ascending (alias for sort_asc)"/>
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               FontFamily="Consolas,Menlo,monospace"
                               FontSize="11"
                               Foreground="#9cdcfe"
                               Text="sort_asc(field)"
                               Margin="0,0,10,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               FontSize="11"
                               Foreground="#aaa"
                               TextWrapping="Wrap"
                               Text="Sort ascending by field"/>
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               FontFamily="Consolas,Menlo,monospace"
                               FontSize="11"
                               Foreground="#9cdcfe"
                               Text="sort_desc(field)"
                               Margin="0,0,10,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               FontSize="11"
                               Foreground="#aaa"
                               TextWrapping="Wrap"
                               Text="Sort descending by field"/>
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontSize="11"
                               Foreground="#666"
                               Text="──────────────────────────────"
                               Margin="0,2,0,2"/>
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontSize="11"
                               Foreground="#aaa"
                               Text="Object arrays — field required:"/>
                    <TextBlock Grid.Row="5" Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontFamily="Consolas,Menlo,monospace"
                               FontSize="11"
                               Foreground="#ce9178"
                               Text="  $.items.sort_asc(price)"
                               Margin="0,1,0,4"/>
                    <TextBlock Grid.Row="6" Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontSize="11"
                               Foreground="#aaa"
                               Text="Primitive arrays — no field:"/>
                    <TextBlock Grid.Row="7" Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontFamily="Consolas,Menlo,monospace"
                               FontSize="11"
                               Foreground="#ce9178"
                               Text="  $.scores.sort_desc()"/>
                  </Grid>
                </StackPanel>
              </ToolTip>
            </ToolTip.Tip>
            <TextBlock Text="?"
                       FontSize="9"
                       FontWeight="SemiBold"
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock x:Name="FilterStatusTextBlock"
                     FontSize="11"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="1"/>
        </StackPanel>
        <Border BorderBrush="#343434"
                BorderThickness="1"
                CornerRadius="4">
          <Grid MinHeight="32">
            <TextBox x:Name="FilterTextBox"
                     Background="Transparent"
                     Foreground="#d4d4d4"
                     BorderThickness="0"
                     FontFamily="Consolas,Menlo,monospace"
                     FontSize="12"
                     MinHeight="32"
                     Padding="10,4,28,4"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Watermark="Path"/>
            <Button x:Name="ClearButton"
                    Content="×"
                    Width="18"
                    Height="18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="0,0,6,0"
                    Background="Transparent"
                    Foreground="#8e8e8e"
                    BorderThickness="0"
                    Padding="0"
                    FontSize="12"
                    Focusable="False"
                    IsVisible="False"
                    ToolTip.Tip="Clear path filter"/>
          </Grid>
        </Border>
      </StackPanel>
    </Border>

    <controls:SyntaxEditor x:Name="Editor"
                           Grid.Row="1"
                           IsReadOnly="True"/>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="400"
             x:Class="Callsmith.Desktop.Controls.FilteredSyntaxViewer">

  <Grid RowDefinitions="Auto,*"
        Background="#1e1e1e">
    <Border x:Name="FilterBar"
            Grid.Row="0"
            Background="#1e1e1e"
            BorderBrush="#343434"
            BorderThickness="0,0,0,1"
            Padding="8,6,8,6"
            IsVisible="False">
      <StackPanel Spacing="4">
        <StackPanel Orientation="Horizontal"
              Spacing="4"
              MinHeight="16">
          <TextBlock x:Name="FilterLabelTextBlock"
                     Foreground="#888"
                     FontWeight="Bold"
                     FontSize="10"
                     LetterSpacing="1"
                     VerticalAlignment="Center"
                     Text="FILTER"/>
          <TextBlock x:Name="FilterStatusTextBlock"
                     FontSize="11"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="1"/>
        </StackPanel>
        <Border BorderBrush="#343434"
                BorderThickness="1"
                CornerRadius="4">
          <Grid MinHeight="32">
            <TextBox x:Name="FilterTextBox"
                     Background="Transparent"
                     Foreground="#d4d4d4"
                     BorderThickness="0"
                     FontFamily="Consolas,Menlo,monospace"
                     FontSize="12"
                     MinHeight="32"
                     Padding="10,4,28,4"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Watermark="Path"/>
            <Button x:Name="ClearButton"
                    Content="×"
                    Width="18"
                    Height="18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="0,0,6,0"
                    Background="Transparent"
                    Foreground="#8e8e8e"
                    BorderThickness="0"
                    Padding="0"
                    FontSize="12"
                    Focusable="False"
                    IsVisible="False"
                    ToolTip.Tip="Clear path filter"/>
          </Grid>
        </Border>
      </StackPanel>
    </Border>

    <controls:SyntaxEditor x:Name="Editor"
                           Grid.Row="1"
                           IsReadOnly="True"/>
  </Grid>
</UserControl>

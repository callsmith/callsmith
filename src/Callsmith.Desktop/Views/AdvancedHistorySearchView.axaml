<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="480"
             x:Class="Callsmith.Desktop.Views.AdvancedHistorySearchView"
             x:DataType="vm:AdvancedHistorySearchViewModel">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Enter" Command="{Binding ApplyCommand}"/>
  </UserControl.KeyBindings>

  <Border Background="#2d2d30"
          BorderBrush="#555"
          BorderThickness="1"
          CornerRadius="6"
          Padding="18,14"
          BoxShadow="0 4 24 0 #CC000000"
          Width="480">
    <StackPanel Spacing="14">

      <!-- Title -->
      <TextBlock Text="Advanced Search"
                 Foreground="#d4d4d4"
                 FontSize="14"
                 FontWeight="SemiBold"/>

      <!-- Row helper style injected inline via panel.  Each row is a 2-col Grid:
           col 0 = 130px label, col 1 = * content. -->

      <!-- Request contains -->
      <Grid ColumnDefinitions="130,*">
        <TextBlock Grid.Column="0"
                   Text="Request contains"
                   Foreground="#999"
                   FontSize="12"
                   VerticalAlignment="Center"/>
        <Grid Grid.Column="1">
          <TextBox Text="{Binding RequestContains}"
                   Watermark="body, headers, params…"
                   FontSize="12"
                   Background="#1e1e1e"
                   Foreground="#d4d4d4"
                   BorderBrush="#555"
                   VerticalContentAlignment="Center"
                   Padding="6,0,24,0"/>
          <Button Content="×"
                  Command="{Binding ClearRequestContainsCommand}"
                  IsVisible="{Binding RequestContains, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Focusable="False"
                  Width="18" Height="18" Margin="0,0,5,0"
                  Background="Transparent" Foreground="#888"
                  BorderThickness="0" Padding="0" FontSize="12"/>
        </Grid>
      </Grid>

      <!-- Response contains -->
      <Grid ColumnDefinitions="130,*">
        <TextBlock Grid.Column="0"
                   Text="Response contains"
                   Foreground="#999"
                   FontSize="12"
                   VerticalAlignment="Center"/>
        <Grid Grid.Column="1">
          <TextBox Text="{Binding ResponseContains}"
                   Watermark="body, headers…"
                   FontSize="12"
                   Background="#1e1e1e"
                   Foreground="#d4d4d4"
                   BorderBrush="#555"
                   VerticalContentAlignment="Center"
                   Padding="6,0,24,0"/>
          <Button Content="×"
                  Command="{Binding ClearResponseContainsCommand}"
                  IsVisible="{Binding ResponseContains, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Focusable="False"
                  Width="18" Height="18" Margin="0,0,5,0"
                  Background="Transparent" Foreground="#888"
                  BorderThickness="0" Padding="0" FontSize="12"/>
        </Grid>
      </Grid>

      <!-- Method -->
      <Grid ColumnDefinitions="130,*">
        <TextBlock Grid.Column="0"
                   Text="Method"
                   Foreground="#999"
                   FontSize="12"
                   VerticalAlignment="Center"/>
        <Grid Grid.Column="1">
          <TextBox Text="{Binding MethodSearch}"
                   Watermark="GET, POST, ws:connect…"
                   FontSize="12"
                   Background="#1e1e1e"
                   Foreground="#d4d4d4"
                   BorderBrush="#555"
                   VerticalContentAlignment="Center"
                   Padding="6,0,24,0"/>
          <Button Content="×"
                  Command="{Binding ClearMethodSearchCommand}"
                  IsVisible="{Binding MethodSearch, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Focusable="False"
                  Width="18" Height="18" Margin="0,0,5,0"
                  Background="Transparent" Foreground="#888"
                  BorderThickness="0" Padding="0" FontSize="12"/>
        </Grid>
      </Grid>

      <!-- Status code range -->
      <Grid ColumnDefinitions="130,*">
        <TextBlock Grid.Column="0"
                   Text="Status code"
                   Foreground="#999"
                   FontSize="12"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <NumericUpDown Value="{Binding MinStatusCode}"
                         Minimum="100" Maximum="999"
                         Width="90"
                         FontSize="12"
                         Watermark="Min"
                         Background="#1e1e1e"
                         Foreground="#d4d4d4"
                         BorderBrush="#555"
                         ShowButtonSpinner="False"
                         AllowSpin="False"/>
          <TextBlock Text="to" Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
          <NumericUpDown Value="{Binding MaxStatusCode}"
                         Minimum="100" Maximum="999"
                         Width="90"
                         FontSize="12"
                         Watermark="Max"
                         Background="#1e1e1e"
                         Foreground="#d4d4d4"
                         BorderBrush="#555"
                         ShowButtonSpinner="False"
                         AllowSpin="False"/>
        </StackPanel>
      </Grid>

      <!-- Date / time range — From -->
      <Grid ColumnDefinitions="130,*">
        <TextBlock Grid.Column="0"
                   Text="Date from"
                   Foreground="#999"
                   FontSize="12"
                   VerticalAlignment="Top"
                   Margin="0,6,0,0"/>
        <!-- 2-row grid: col 0 = fixed buttons (Auto), col 1 = pickers (same * width) -->
        <Grid Grid.Column="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="4">
            <Button Grid.Row="0" Grid.Column="0"
                    Content="Today"
                    Command="{Binding SetDateFromToTodayCommand}"
                    FontSize="11"
                    Width="52"
                    Background="Transparent"
                    Foreground="#9cdcfe"
                    BorderBrush="#555"
                    BorderThickness="1"
                    Padding="0,2"
                    HorizontalContentAlignment="Center"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"/>
            <DatePicker Grid.Row="0" Grid.Column="1"
                        SelectedDate="{Binding DateFromDate}"
                        HorizontalAlignment="Stretch"
                        MinWidth="0"
                        FontSize="12"
                        Background="#1e1e1e"
                        Foreground="#d4d4d4"
                        BorderBrush="#555"/>
            <Button Grid.Row="1" Grid.Column="0"
                    Content="Now"
                    Command="{Binding SetDateFromTimeToNowCommand}"
                    FontSize="11"
                    Width="52"
                    Background="Transparent"
                    Foreground="#9cdcfe"
                    BorderBrush="#555"
                    BorderThickness="1"
                    Padding="0,2"
                    HorizontalContentAlignment="Center"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"/>
            <TimePicker Grid.Row="1" Grid.Column="1"
                        SelectedTime="{Binding DateFromTime}"
                        ClockIdentifier="24HourClock"
                        HorizontalAlignment="Stretch"
                        MinWidth="0"
                        FontSize="12"
                        Background="#1e1e1e"
                        Foreground="#d4d4d4"
                        BorderBrush="#555"/>
        </Grid>
      </Grid>

      <!-- Date / time range — To -->
      <Grid ColumnDefinitions="130,*">
        <TextBlock Grid.Column="0"
                   Text="Date to"
                   Foreground="#999"
                   FontSize="12"
                   VerticalAlignment="Top"
                   Margin="0,6,0,0"/>
        <!-- 2-row grid: col 0 = fixed buttons (Auto), col 1 = pickers (same * width) -->
        <Grid Grid.Column="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="4">
            <Button Grid.Row="0" Grid.Column="0"
                    Content="Today"
                    Command="{Binding SetDateToToTodayCommand}"
                    FontSize="11"
                    Width="52"
                    Background="Transparent"
                    Foreground="#9cdcfe"
                    BorderBrush="#555"
                    BorderThickness="1"
                    Padding="0,2"
                    HorizontalContentAlignment="Center"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"/>
            <DatePicker Grid.Row="0" Grid.Column="1"
                        SelectedDate="{Binding DateToDate}"
                        HorizontalAlignment="Stretch"
                        MinWidth="0"
                        FontSize="12"
                        Background="#1e1e1e"
                        Foreground="#d4d4d4"
                        BorderBrush="#555"/>
            <Button Grid.Row="1" Grid.Column="0"
                    Content="Now"
                    Command="{Binding SetDateToTimeToNowCommand}"
                    FontSize="11"
                    Width="52"
                    Background="Transparent"
                    Foreground="#9cdcfe"
                    BorderBrush="#555"
                    BorderThickness="1"
                    Padding="0,2"
                    HorizontalContentAlignment="Center"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"/>
            <TimePicker Grid.Row="1" Grid.Column="1"
                        SelectedTime="{Binding DateToTime}"
                        ClockIdentifier="24HourClock"
                        HorizontalAlignment="Stretch"
                        MinWidth="0"
                        FontSize="12"
                        Background="#1e1e1e"
                        Foreground="#d4d4d4"
                        BorderBrush="#555"/>
        </Grid>
      </Grid>

      <!-- Elapsed time range (ms) -->
      <Grid ColumnDefinitions="130,*">
        <TextBlock Grid.Column="0"
                   Text="Elapsed (ms)"
                   Foreground="#999"
                   FontSize="12"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <NumericUpDown Value="{Binding MinElapsedMs}"
                         Minimum="0"
                         Width="100"
                         FontSize="12"
                         Watermark="Min"
                         Background="#1e1e1e"
                         Foreground="#d4d4d4"
                         BorderBrush="#555"
                         ShowButtonSpinner="False"
                         AllowSpin="False"/>
          <TextBlock Text="to" Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
          <NumericUpDown Value="{Binding MaxElapsedMs}"
                         Minimum="0"
                         Width="100"
                         FontSize="12"
                         Watermark="Max"
                         Background="#1e1e1e"
                         Foreground="#d4d4d4"
                         BorderBrush="#555"
                         ShowButtonSpinner="False"
                         AllowSpin="False"/>
        </StackPanel>
      </Grid>

      <!-- Footer buttons -->
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8"
                  Margin="0,6,0,0">
        <Button Content="Clear All"
                Command="{Binding ClearAllCommand}"
                FontSize="12"
                Background="Transparent"
                Foreground="#f48771"
                BorderBrush="#555"
                BorderThickness="1"
                Padding="12,4"
                CornerRadius="3"/>
        <Button Content="Cancel"
                Command="{Binding CancelCommand}"
                FontSize="12"
                Background="#3a3a3a"
                Foreground="#ccc"
                BorderThickness="0"
                Padding="12,4"
                CornerRadius="3"/>
        <Button Content="Apply"
                Command="{Binding ApplyCommand}"
                FontSize="12"
                Background="#0d7377"
                Foreground="#fff"
                BorderThickness="0"
                Padding="12,4"
                CornerRadius="3"/>
      </StackPanel>

    </StackPanel>
  </Border>

</UserControl>


<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Callsmith.Desktop.Views.EnvironmentEditorView"
             x:DataType="vm:EnvironmentEditorViewModel"
             Background="#1e1e1e">

  <Grid RowDefinitions="Auto,*">

    <!-- ======================================================================
         Header bar
         ====================================================================== -->
    <Border Grid.Row="0"
            Background="#252526"
            BorderBrush="#444"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <TextBlock Text="Environments"
                     Foreground="#d4d4d4"
                     FontSize="14"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <!-- Error banner (transient) -->
          <Border Background="#5a1a1a"
                  CornerRadius="4"
                  Padding="8,3"
                  IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#f48771"
                       FontSize="12"
                       VerticalAlignment="Center"/>
          </Border>
        </StackPanel>

        <Button Grid.Column="1"
                Content="← Back to Editor"
                Command="{Binding CloseEditorCommand}"
                FontSize="11"
                Background="Transparent"
                Foreground="#4ec9b0"
                BorderThickness="0"
                Padding="8,2"
                VerticalAlignment="Center"
                ToolTip.Tip="Return to the request editor"/>

      </Grid>
    </Border>

    <!-- ======================================================================
         Main body: environment list (left) + variable editor (right)
         ====================================================================== -->
    <Grid Grid.Row="1"
          ColumnDefinitions="220,1,*">

      <!-- ────────────────────────────────────────────────────────────────────
           Left panel — environment list
           ──────────────────────────────────────────────────────────────────── -->
      <ScrollViewer Grid.Column="0"
                    VerticalScrollBarVisibility="Auto"
                    Background="#252526">
        <StackPanel>

        <!-- Environment list -->
          <ListBox ItemsSource="{Binding Environments}"
                   SelectedItem="{Binding SelectedEnvironment, Mode=TwoWay}"
                   x:Name="EnvironmentList"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="0"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ContextMenu>
              <ContextMenu x:Name="EnvListContextMenu"/>
            </ListBox.ContextMenu>
            <ListBox.Styles>
              <!-- Strip default ListBoxItem chrome so our Border controls all visuals -->
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
              </Style>
              <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
              </Style>
              <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
              </Style>
              <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:EnvironmentListItemViewModel">

                <!-- Each item is a selection-aware row -->
                <Border x:Name="ItemRow"
                        Padding="0"
                        Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">
                  <Border.Styles>
                    <Style Selector="Border.selected">
                      <Setter Property="Background" Value="#37373d"/>
                    </Style>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="#2d2d30"/>
                    </Style>
                  </Border.Styles>

                  <Grid ColumnDefinitions="*,Auto"
                        Margin="0">

                    <!-- Display mode: name label + hover actions -->
                    <Grid Grid.Column="0"
                          ColumnDefinitions="Auto,*,Auto,Auto"
                          IsVisible="{Binding !IsRenaming}">

                      <!-- Drag handle — hidden for global env (always pinned) -->
                      <TextBlock Grid.Column="0"
                                 Text="⠿"
                                 Foreground="#555"
                                 FontSize="14"
                                 Padding="8,8,4,8"
                                 VerticalAlignment="Center"
                                 ToolTip.Tip="Drag to reorder"
                                 Cursor="Hand"
                                 IsVisible="{Binding !IsGlobal}"/>

                      <!-- Pin badge for the global env -->
                      <TextBlock Grid.Column="0"
                                 Text="📌"
                                 FontSize="11"
                                 Padding="8,8,4,8"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsGlobal}"
                                 ToolTip.Tip="Global — always active for all environments"/>

                      <!-- Clicking label selects the environment -->
                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="6"
                                  VerticalAlignment="Center"
                                  Margin="4,8">
                        <Border Width="10" Height="10"
                                CornerRadius="2"
                                Background="{Binding Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                                IsVisible="{Binding Color, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}"
                                   Foreground="#cccccc"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                      </StackPanel>

                      <!-- GLOBAL badge -->
                      <Border Grid.Column="2"
                              Background="#1a3a2a"
                              BorderBrush="#2a6a4a"
                              BorderThickness="1"
                              CornerRadius="3"
                              Padding="5,1"
                              Margin="0,0,4,0"
                              IsVisible="{Binding IsGlobal}"
                              VerticalAlignment="Center">
                        <TextBlock Text="GLOBAL"
                                   Foreground="#4ec9b0"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1"/>
                      </Border>

                      <!-- Row action buttons — rename only (hidden for global) -->
                      <Button Grid.Column="3"
                              Content="✎"
                              Command="{Binding BeginRenameCommand}"
                              Background="Transparent"
                              Foreground="#888"
                              BorderThickness="0"
                              Padding="4,2"
                              Margin="0,0,4,0"
                              FontSize="12"
                              VerticalAlignment="Center"
                              IsVisible="{Binding !IsGlobal}"
                              ToolTip.Tip="Rename"/>
                    </Grid>

                    <!-- Rename mode: text box + confirm / cancel -->
                    <Grid Grid.Column="0"
                          ColumnDefinitions="*,Auto,Auto"
                          IsVisible="{Binding IsRenaming}"
                          Margin="4,4">

                      <StackPanel Grid.Column="0">
                        <TextBox Text="{Binding PendingName}"
                                 FontSize="12"
                                 Padding="6,3"
                                 Background="#3c3c3c"
                                 Foreground="#d4d4d4"
                                 BorderBrush="#555"
                                 x:Name="RenameBox"/>
                        <TextBlock Text="{Binding RenameError}"
                                   Foreground="#f48771"
                                   FontSize="10"
                                   IsVisible="{Binding RenameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Margin="2,2,0,0"/>
                      </StackPanel>

                      <Button Grid.Column="1"
                              Content="✓"
                              Command="{Binding CommitRenameCommand}"
                              Background="Transparent"
                              Foreground="#4ec9b0"
                              BorderThickness="0"
                              Padding="6,3"
                              FontSize="13"
                              ToolTip.Tip="Confirm rename"
                              Margin="4,0,0,0"/>

                      <Button Grid.Column="2"
                              Content="✕"
                              Command="{Binding CancelRenameCommand}"
                              Background="Transparent"
                              Foreground="#888"
                              BorderThickness="0"
                              Padding="4,3"
                              FontSize="11"
                              ToolTip.Tip="Cancel rename"/>
                    </Grid>

                  </Grid>
                </Border>

              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        <!-- Add environment area (directly below the list) -->
        <Border BorderBrush="#444"
                BorderThickness="0,1,0,0"
                Padding="8,8">
          <StackPanel>

            <!-- "Add" button — normal state -->
            <Button Content="+ Add Environment"
                    Command="{Binding BeginAddEnvironmentCommand}"
                    IsVisible="{Binding !IsAddingEnvironment}"
                    Background="Transparent"
                    Foreground="#4ec9b0"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    FontSize="12"/>

            <!-- Inline new-name entry — shown when IsAddingEnvironment -->
            <StackPanel IsVisible="{Binding IsAddingEnvironment}"
                        Spacing="4">
              <TextBox Text="{Binding NewEnvironmentName}"
                       Watermark="Environment name…"
                       FontSize="12"
                       Padding="6,4"
                       Background="#3c3c3c"
                       Foreground="#d4d4d4"
                       BorderBrush="#555"/>
              <TextBlock Text="{Binding NewEnvironmentError}"
                         Foreground="#f48771"
                         FontSize="10"
                         IsVisible="{Binding NewEnvironmentError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="Create"
                        Command="{Binding CommitAddEnvironmentCommand}"
                        Background="#0d7a5f"
                        Foreground="#ffffff"
                        BorderThickness="0"
                        Padding="10,4"
                        FontSize="12"
                        CornerRadius="3"/>
                <Button Content="Cancel"
                        Command="{Binding CancelAddEnvironmentCommand}"
                        Background="Transparent"
                        Foreground="#888"
                        BorderThickness="0"
                        Padding="6,4"
                        FontSize="12"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Divider -->
      <Border Grid.Column="1"
              Background="#444"/>

      <!-- ────────────────────────────────────────────────────────────────────
           Right panel — variable editor for the selected environment
           ──────────────────────────────────────────────────────────────────── -->
      <Grid Grid.Column="2"
            RowDefinitions="Auto,*"
            Background="#1e1e1e">

        <!-- Variable editor header -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#444"
                BorderThickness="0,0,0,1"
                Padding="12,8">
          <StackPanel Spacing="6">

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedEnvironment.Name, FallbackValue='No environment selected'}"
                           Foreground="#d4d4d4"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <!-- Dirty indicator -->
                <Border Background="#6a4f00"
                        CornerRadius="3"
                        Padding="6,2"
                        IsVisible="{Binding SelectedEnvironment.IsDirty, FallbackValue=False}">
                  <TextBlock Text="UNSAVED"
                             Foreground="#ffc107"
                             FontSize="10"
                             FontWeight="SemiBold"
                             LetterSpacing="1"/>
                </Border>
              </StackPanel>

              <!-- Save / Revert buttons -->
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="6"
                          IsVisible="{Binding SelectedEnvironment, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Button Content="Revert"
                        Command="{Binding RevertSelectedCommand}"
                        IsVisible="{Binding SelectedEnvironment.IsDirty, FallbackValue=False}"
                        Background="#3c3c3c"
                        Foreground="#cccccc"
                        BorderThickness="0"
                        Padding="14,5"
                        CornerRadius="3"
                        FontSize="12"/>
                <Button Content="Save"
                        Command="{Binding SaveSelectedCommand}"
                        IsEnabled="{Binding SelectedEnvironment.IsDirty, FallbackValue=False}"
                        Background="#0d7a5f"
                        Foreground="#ffffff"
                        BorderThickness="0"
                        Padding="14,5"
                        CornerRadius="3"
                        FontSize="12"/>
              </StackPanel>
            </Grid>

            <!-- Color row — only shown for regular (non-global) environments -->
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        IsVisible="{Binding SelectedEnvironment.IsGlobal, Converter={x:Static BoolConverters.Not}, FallbackValue=False}">
              <TextBlock Text="Color:"
                         Foreground="#888888"
                         FontSize="11"
                         VerticalAlignment="Center"/>
              <!-- Live color preview swatch -->
              <Border Width="22" Height="22"
                      CornerRadius="3"
                      BorderBrush="#555"
                      BorderThickness="1"
                      VerticalAlignment="Center"
                      Background="{Binding SelectedEnvironment.Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"/>
              <!-- Hex input -->
              <TextBox Text="{Binding SelectedEnvironment.Color, Mode=TwoWay}"
                       Watermark="#rrggbb"
                       Width="88"
                       FontSize="12"
                       FontFamily="Consolas,Menlo,monospace"
                       Padding="6,0"
                       Background="#3c3c3c"
                       Foreground="#d4d4d4"
                       BorderBrush="#555"
                       VerticalAlignment="Center"
                       VerticalContentAlignment="Center"
                       ToolTip.Tip="Enter a hex color code, e.g. #4ec9b0"/>
              <!-- Clear button -->
              <Button Content="× Clear"
                      Command="{Binding SelectedEnvironment.ClearColorCommand}"
                      IsVisible="{Binding SelectedEnvironment.Color, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
                      Background="Transparent"
                      Foreground="#888"
                      BorderThickness="0"
                      Padding="4,2"
                      FontSize="11"
                      VerticalAlignment="Center"
                      ToolTip.Tip="Remove environment color"/>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- Variable rows -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding SelectedEnvironment, Converter={x:Static ObjectConverters.IsNotNull}}">
          <StackPanel Margin="12,8">

            <!-- Global environment explanation banner -->
            <Border IsVisible="{Binding SelectedEnvironment.IsGlobal, FallbackValue=False}"
                    Background="#1a2a1a"
                    Padding="10,8"
                    Margin="0,0,0,8">
              <StackPanel Spacing="8">
                <!-- Preview env selector — makes all global dynamic var previews use one consistent context -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                  <TextBlock Text="Preview against:"
                             Foreground="#7db87d"
                             FontSize="11"
                             VerticalAlignment="Center"/>
                  <ComboBox ItemsSource="{Binding GlobalPreviewEnvironments}"
                            SelectedItem="{Binding SelectedGlobalPreviewEnvironment, Mode=TwoWay}"
                            PlaceholderText="(no environment)"
                            MinWidth="160"
                            FontSize="11"
                            Background="#1e2e1e"
                            Foreground="#cccccc"
                            BorderBrush="#2a5a3a"
                            IsEnabled="{Binding HasGlobalPreviewEnvironments}"
                            ToolTip.Tip="The environment to be used as the context for previewing global variables">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:EnvironmentListItemViewModel">
                        <TextBlock Text="{Binding Name}" FontSize="11"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Column headers: Drag(24) | Name(320) | Value(*) | Secret(58) | Override(Auto=72/0) | Type(170) | Delete(28) -->
            <Grid ColumnDefinitions="24,320,*,58,Auto,170,28"
                  Margin="0,0,0,4">
              <TextBlock Grid.Column="1"
                         Text="NAME"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"/>
              <TextBlock Grid.Column="2"
                         Text="VALUE"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         Margin="6,0"/>
              <TextBlock Grid.Column="3"
                         Text="SECRET"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         HorizontalAlignment="Center"/>
              <TextBlock Grid.Column="4"
                         Text="OVERRIDE"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         Width="72"
                         HorizontalAlignment="Center"
                         IsVisible="{Binding SelectedEnvironment.IsGlobal, FallbackValue=False}"
                         ToolTip.Tip="Force this global variable to take priority over a same-named concrete environment variable"/>
              <TextBlock Grid.Column="5"
                         Text="TYPE"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         Margin="4,0"/>
            </Grid>

            <ItemsControl x:Name="VariableRows"
                          ItemsSource="{Binding SelectedEnvironment.Variables}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:EnvironmentVariableItemViewModel">
                  <!-- Columns: Drag(24) | Name(320) | Value(*) | Secret(58) | Override(Auto=72/0) | Type(170) | Delete(28) -->
                  <Grid ColumnDefinitions="24,320,*,58,Auto,170,28"
                        RowDefinitions="Auto,Auto,Auto"
                        Margin="0,2">

                    <!-- Drag handle -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="⠿"
                               Foreground="#555"
                               FontSize="14"
                               Padding="2,4,4,4"
                               VerticalAlignment="Center"
                               ToolTip.Tip="Drag to reorder"
                               Cursor="Hand"/>

                    <!-- Name -->
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding Name}"
                             Watermark="name"
                             FontSize="12"
                             Foreground="#d4d4d4"
                             Background="#2d2d30"
                             BorderBrush="#444"
                             Padding="6,4"
                             Margin="0,0,6,0"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas,Menlo,monospace"/>

                    <!-- Value: static plain — text input (lock is in the SECRET column) -->
                      <Grid Grid.Row="0" Grid.Column="2"
                          IsVisible="{Binding IsStaticNotSecret}"
                          Margin="0,0,6,0">
                      <TextBox Grid.Column="0"
                               Text="{Binding Value}"
                               Watermark="value"
                               FontSize="12"
                               Foreground="#d4d4d4"
                               Background="#2d2d30"
                               BorderBrush="#444"
                               Padding="6,4"
                               VerticalContentAlignment="Center"
                               FontFamily="Consolas,Menlo,monospace"
                               controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}"/>
                    </Grid>

                    <!-- Value: static secret — masked input with eye reveal toggle (lock is in the SECRET column) -->
                      <Grid Grid.Row="0" Grid.Column="2"
                          ColumnDefinitions="*,Auto"
                          IsVisible="{Binding IsStaticAndSecret}"
                          Margin="0,0,6,0">
                      <TextBox Grid.Column="0"
                               Text="{Binding Value}"
                               Watermark="value"
                               FontSize="12"
                               Foreground="#d4d4d4"
                               Background="#2d2d30"
                               BorderBrush="#444"
                               Padding="6,4"
                               VerticalContentAlignment="Center"
                               FontFamily="Consolas,Menlo,monospace"
                               PasswordChar="•"
                               RevealPassword="{Binding IsValueRevealed}"
                               controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}"/>
                      <!-- Eye toggle — reveals the secret value without marking the env dirty -->
                      <ToggleButton Grid.Column="1"
                                    IsChecked="{Binding IsValueRevealed}"
                                    Width="28" Height="26"
                                    Background="Transparent"
                                    BorderBrush="#444"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="4,0,0,0"
                                    ToolTip.Tip="Reveal or hide the secret value">
                        <Grid>
                          <!-- Eye icon shown when value is hidden -->
                          <PathIcon Width="14" Height="14" Foreground="#888"
                                    IsVisible="{Binding IsValueRevealed, Converter={x:Static BoolConverters.Not}}"
                                    Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                          <!-- Eye-slash icon shown when value is revealed -->
                          <PathIcon Width="14" Height="14" Foreground="#888"
                                    IsVisible="{Binding IsValueRevealed}"
                                    Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                        </Grid>
                      </ToggleButton>
                    </Grid>

                    <!-- Value: mock-data type — configure button + summary -->
                    <StackPanel Grid.Row="0" Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                IsVisible="{Binding IsMockData}"
                                VerticalAlignment="Center"
                                Margin="6,0,6,0">
                      <Button Content="Configure…"
                              Command="{Binding OpenMockDataConfigCommand}"
                              Background="#3a3a3a"
                              Foreground="#c586c0"
                              BorderBrush="#555"
                              BorderThickness="1"
                              CornerRadius="3"
                              Padding="8,3"
                              FontSize="11"
                              VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding MockDataSummary}"
                                 Foreground="#c586c0"
                                 FontSize="12"
                                 FontFamily="Consolas,Menlo,monospace"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Value: response-body type — configure button + "name → path" summary (lock is in the SECRET column) -->
                    <Grid Grid.Row="0" Grid.Column="2"
                          IsVisible="{Binding IsResponseBody}"
                          Margin="6,0,6,0">
                      <StackPanel Grid.Column="0"
                                  Orientation="Horizontal"
                                  Spacing="8"
                                  VerticalAlignment="Center">
                        <Button Content="Configure…"
                                Command="{Binding OpenResponseBodyConfigCommand}"
                                Background="#3a3a3a"
                                Foreground="#4ec9b0"
                                BorderBrush="#555"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="8,3"
                                FontSize="11"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ResponseBodySummary}"
                                  Foreground="#4ec9b0"
                                  FontSize="12"
                                  FontFamily="Consolas,Menlo,monospace"
                                  VerticalAlignment="Center"
                                  TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>

                    <!-- SECRET column — lock toggle for all variable types (disabled for mock data).
                         When CanBeSecret=false (mock data) we hide the ToggleButton entirely and
                         show a custom visual instead.  Avalonia's Fluent theme applies a background
                         tint to any disabled ToggleButton that, in a dark theme, is indistinguishable
                         from the checked/on state — hiding the button and replacing it with an
                         explicitly styled placeholder is cleaner than fighting the theme. -->
                    <Panel Grid.Row="0" Grid.Column="3"
                           Width="28"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                      <!-- Enabled state: the real interactive ToggleButton -->
                      <ToggleButton IsChecked="{Binding IsSecret}"
                                    IsVisible="{Binding CanBeSecret}"
                                    Width="28" Height="26"
                                    Background="Transparent"
                                    BorderBrush="#444"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="{Binding SecretLockTooltip}">
                        <TextBlock Text="🔒" FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </ToggleButton>
                      <!-- Disabled state: custom placeholder that clearly reads as "off and not
                           changeable".  Transparent background (no checked-style shading), dim
                           border and a low-opacity lock icon convey "off/unavailable".
                           Also captures pointer events so the tooltip and help cursor work. -->
                      <Border Width="28" Height="26"
                              Background="Transparent"
                              BorderBrush="#2e2e2e"
                              BorderThickness="1"
                              CornerRadius="3"
                              IsVisible="{Binding !CanBeSecret}"
                              Cursor="Help"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              ToolTip.Tip="{Binding SecretLockTooltip}">
                        <TextBlock Text="🔒" FontSize="11"
                                   Foreground="#555"
                                   Opacity="0.4"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                    </Panel>

                    <!-- Override checkbox — visible only for global environment variables -->
                    <!-- Keep a fixed-width host so the checkbox can be visually centered,
                      while the Auto column still collapses to width 0 on concrete rows. -->
                    <Grid Grid.Row="0" Grid.Column="4"
                       Width="72"
                       IsVisible="{Binding IsGlobal}">
                      <CheckBox IsChecked="{Binding IsForceGlobalOverride}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          ToolTip.Tip="Force this global variable to take priority over a same-named concrete environment variable"/>
                    </Grid>

                    <!-- Type dropdown -->
                    <ComboBox Grid.Row="0" Grid.Column="5"
                              ItemsSource="{Binding AvailableVariableTypeOptions}"
                              SelectedItem="{Binding VariableTypeDisplay}"
                              IsEnabled="{Binding !IsTypeDropdownDisabled}"
                              HorizontalAlignment="Stretch"
                              FontSize="11"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"
                              ToolTip.Tip="Variable type"/>

                    <!-- Delete -->
                        <Button Grid.Row="0" Grid.Column="6"
                            Content="×"
                            Command="{Binding DeleteCommand}"
                            Background="Transparent"
                            Foreground="#aaa"
                            BorderThickness="0"
                            Padding="4,0"
                            FontSize="14"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            ToolTip.Tip="Remove variable"/>

                    <!-- Preview row — shown when a static value contains {{VAR}} references -->
                        <Border Grid.Row="1" Grid.Column="2"
                            IsVisible="{Binding HasPreview}"
                            Background="#1e1e1e"
                            BorderBrush="#3a3a3a"
                            BorderThickness="0,1,0,0"
                            Padding="0,3"
                            Margin="0,0,0,4">
                      <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0"
                                   Text="PREVIEW"
                                   Foreground="#5a5a5a"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="8,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PreviewValue}"
                                   Foreground="#888"
                                   FontSize="12"
                                   FontFamily="Consolas,Menlo,monospace"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                      </Grid>
                    </Border>

                    <!-- Conflict row — OVERRIDES or OVERRIDDEN BY -->
                        <Border Grid.Row="2" Grid.Column="2"
                            IsVisible="{Binding HasConflict}"
                            ToolTip.Tip="{Binding ConflictToolTip}"
                            Cursor="Help"
                            Background="#1e1e1e"
                            BorderBrush="#3a3a3a"
                            BorderThickness="0,1,0,0"
                            Padding="0,3"
                            Margin="0,0,0,4">
                      <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ConflictLabel}"
                                   Foreground="#5a5a5a"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="8,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ConflictValue}"
                                   Foreground="#888"
                                   FontSize="12"
                                   FontFamily="Consolas,Menlo,monospace"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                      </Grid>
                    </Border>

                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add variable button -->
            <Button Content="+ Add Variable"
                    Command="{Binding SelectedEnvironment.AddVariableCommand}"
                    Background="Transparent"
                    Foreground="#4ec9b0"
                    BorderThickness="0"
                    Padding="0,6,0,0"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    Margin="0,4,0,0"/>
          </StackPanel>
        </ScrollViewer>

        <!-- Empty-state placeholder when nothing is selected -->
        <TextBlock Grid.Row="1"
                   Text="Select an environment from the list to edit its variables."
                   Foreground="#555"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding SelectedEnvironment, Converter={x:Static ObjectConverters.IsNull}}"/>

      </Grid>

    </Grid>

    <!-- ======================================================================
         Delete confirmation overlay
         ====================================================================== -->
    <Grid Grid.Row="0" Grid.RowSpan="2"
          IsVisible="{Binding IsConfirmingDelete}"
          Background="#99000000"
          ZIndex="100">
      <Border Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="24,20"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="340">
        <StackPanel Spacing="16">
          <TextBlock Text="Delete environment?"
                     Foreground="#d4d4d4"
                     FontSize="14"
                     FontWeight="SemiBold"/>
          <TextBlock TextWrapping="Wrap"
                     Foreground="#aaa"
                     FontSize="12">
            <Run Text="&quot;"/><Run Text="{Binding DeleteConfirmationName}"/><Run Text="&quot; and all its variables will be permanently deleted."/>
          </TextBlock>
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Command="{Binding CancelDeleteCommand}"
                    Background="#3a3a3a"
                    Foreground="#ccc"
                    BorderThickness="0"
                    CornerRadius="3"
                    Padding="14,7"
                    FontSize="12"/>
            <Button Content="Delete"
                    Command="{Binding ConfirmDeleteCommand}"
                    Background="#a82020"
                    Foreground="#ffffff"
                    BorderThickness="0"
                    CornerRadius="3"
                    Padding="14,7"
                    FontSize="12"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

  </Grid>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Callsmith.Desktop.Views.EnvironmentEditorView"
             x:DataType="vm:EnvironmentEditorViewModel"
             Background="#1e1e1e">

  <Grid RowDefinitions="Auto,*">

    <!-- ======================================================================
         Header bar
         ====================================================================== -->
    <Border Grid.Row="0"
            Background="#252526"
            BorderBrush="#444"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <TextBlock Text="Environments"
                     Foreground="#d4d4d4"
                     FontSize="14"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <!-- Error banner (transient) -->
          <Border Background="#5a1a1a"
                  CornerRadius="4"
                  Padding="8,3"
                  IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#f48771"
                       FontSize="12"
                       VerticalAlignment="Center"/>
          </Border>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ======================================================================
         Main body: environment list (left) + variable editor (right)
         ====================================================================== -->
    <Grid Grid.Row="1"
          ColumnDefinitions="220,1,*">

      <!-- ────────────────────────────────────────────────────────────────────
           Left panel — environment list
           ──────────────────────────────────────────────────────────────────── -->
      <ScrollViewer Grid.Column="0"
                    VerticalScrollBarVisibility="Auto"
                    Background="#252526">
        <StackPanel>

        <!-- Environment list -->
          <ListBox ItemsSource="{Binding Environments}"
                   SelectedItem="{Binding SelectedEnvironment, Mode=TwoWay}"
                   x:Name="EnvironmentList"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="0"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.Styles>
              <!-- Strip default ListBoxItem chrome so our Border controls all visuals -->
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
              </Style>
              <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
              </Style>
              <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
              </Style>
              <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:EnvironmentListItemViewModel">

                <!-- Each item is a selection-aware row -->
                <Border x:Name="ItemRow"
                        Padding="0"
                        Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Rename" Command="{Binding BeginRenameCommand}" IsVisible="{Binding !IsGlobal}"/>
                      <MenuItem Header="Clone" Command="{Binding CloneCommand}" IsVisible="{Binding !IsGlobal}"/>
                      <Separator IsVisible="{Binding !IsGlobal}"/>
                      <MenuItem Header="Delete" Command="{Binding DeleteCommand}" IsVisible="{Binding !IsGlobal}"/>
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Border.Styles>
                    <Style Selector="Border.selected">
                      <Setter Property="Background" Value="#37373d"/>
                    </Style>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="#2d2d30"/>
                    </Style>
                  </Border.Styles>

                  <Grid ColumnDefinitions="*,Auto"
                        Margin="0">

                    <!-- Display mode: name label + hover actions -->
                    <Grid Grid.Column="0"
                          ColumnDefinitions="Auto,*,Auto,Auto"
                          IsVisible="{Binding !IsRenaming}">

                      <!-- Drag handle — hidden for global env (always pinned) -->
                      <TextBlock Grid.Column="0"
                                 Text="⠿"
                                 Foreground="#555"
                                 FontSize="14"
                                 Padding="8,8,4,8"
                                 VerticalAlignment="Center"
                                 ToolTip.Tip="Drag to reorder"
                                 Cursor="SizeNorthSouth"
                                 IsVisible="{Binding !IsGlobal}"/>

                      <!-- Pin badge for the global env -->
                      <TextBlock Grid.Column="0"
                                 Text="📌"
                                 FontSize="11"
                                 Padding="8,8,4,8"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsGlobal}"
                                 ToolTip.Tip="Global — always active for all environments"/>

                      <!-- Clicking label selects the environment -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Name}"
                                 Foreground="#cccccc"
                                 FontSize="13"
                                 Padding="4,8"
                                 VerticalAlignment="Center"/>

                      <!-- GLOBAL badge -->
                      <Border Grid.Column="2"
                              Background="#1a3a2a"
                              BorderBrush="#2a6a4a"
                              BorderThickness="1"
                              CornerRadius="3"
                              Padding="5,1"
                              Margin="0,0,4,0"
                              IsVisible="{Binding IsGlobal}"
                              VerticalAlignment="Center">
                        <TextBlock Text="GLOBAL"
                                   Foreground="#4ec9b0"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1"/>
                      </Border>

                      <!-- Row action buttons — rename only (hidden for global) -->
                      <Button Grid.Column="3"
                              Content="✎"
                              Command="{Binding BeginRenameCommand}"
                              Background="Transparent"
                              Foreground="#888"
                              BorderThickness="0"
                              Padding="4,2"
                              Margin="0,0,4,0"
                              FontSize="12"
                              VerticalAlignment="Center"
                              IsVisible="{Binding !IsGlobal}"
                              ToolTip.Tip="Rename"/>
                    </Grid>

                    <!-- Rename mode: text box + confirm / cancel -->
                    <Grid Grid.Column="0"
                          ColumnDefinitions="*,Auto,Auto"
                          IsVisible="{Binding IsRenaming}"
                          Margin="4,4">

                      <StackPanel Grid.Column="0">
                        <TextBox Text="{Binding PendingName}"
                                 FontSize="12"
                                 Padding="6,3"
                                 Background="#3c3c3c"
                                 Foreground="#d4d4d4"
                                 BorderBrush="#555"
                                 x:Name="RenameBox"/>
                        <TextBlock Text="{Binding RenameError}"
                                   Foreground="#f48771"
                                   FontSize="10"
                                   IsVisible="{Binding RenameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Margin="2,2,0,0"/>
                      </StackPanel>

                      <Button Grid.Column="1"
                              Content="✓"
                              Command="{Binding CommitRenameCommand}"
                              Background="Transparent"
                              Foreground="#4ec9b0"
                              BorderThickness="0"
                              Padding="6,3"
                              FontSize="13"
                              ToolTip.Tip="Confirm rename"
                              Margin="4,0,0,0"/>

                      <Button Grid.Column="2"
                              Content="✕"
                              Command="{Binding CancelRenameCommand}"
                              Background="Transparent"
                              Foreground="#888"
                              BorderThickness="0"
                              Padding="4,3"
                              FontSize="11"
                              ToolTip.Tip="Cancel rename"/>
                    </Grid>

                  </Grid>
                </Border>

              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        <!-- Add environment area (directly below the list) -->
        <Border BorderBrush="#444"
                BorderThickness="0,1,0,0"
                Padding="8,8">
          <StackPanel>

            <!-- "Add" button — normal state -->
            <Button Content="+ Add Environment"
                    Command="{Binding BeginAddEnvironmentCommand}"
                    IsVisible="{Binding !IsAddingEnvironment}"
                    Background="Transparent"
                    Foreground="#4ec9b0"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    FontSize="12"/>

            <!-- Inline new-name entry — shown when IsAddingEnvironment -->
            <StackPanel IsVisible="{Binding IsAddingEnvironment}"
                        Spacing="4">
              <TextBox Text="{Binding NewEnvironmentName}"
                       Watermark="Environment name…"
                       FontSize="12"
                       Padding="6,4"
                       Background="#3c3c3c"
                       Foreground="#d4d4d4"
                       BorderBrush="#555"/>
              <TextBlock Text="{Binding NewEnvironmentError}"
                         Foreground="#f48771"
                         FontSize="10"
                         IsVisible="{Binding NewEnvironmentError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="Create"
                        Command="{Binding CommitAddEnvironmentCommand}"
                        Background="#0d7a5f"
                        Foreground="#ffffff"
                        BorderThickness="0"
                        Padding="10,4"
                        FontSize="12"
                        CornerRadius="3"/>
                <Button Content="Cancel"
                        Command="{Binding CancelAddEnvironmentCommand}"
                        Background="Transparent"
                        Foreground="#888"
                        BorderThickness="0"
                        Padding="6,4"
                        FontSize="12"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Divider -->
      <Border Grid.Column="1"
              Background="#444"/>

      <!-- ────────────────────────────────────────────────────────────────────
           Right panel — variable editor for the selected environment
           ──────────────────────────────────────────────────────────────────── -->
      <Grid Grid.Column="2"
            RowDefinitions="Auto,*"
            Background="#1e1e1e">

        <!-- Variable editor header -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#444"
                BorderThickness="0,0,0,1"
                Padding="12,8">
          <StackPanel Spacing="6">

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedEnvironment.Name, FallbackValue='No environment selected'}"
                           Foreground="#d4d4d4"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <!-- Dirty indicator -->
                <Border Background="#6a4f00"
                        CornerRadius="3"
                        Padding="6,2"
                        IsVisible="{Binding SelectedEnvironment.IsDirty, FallbackValue=False}">
                  <TextBlock Text="UNSAVED"
                             Foreground="#ffc107"
                             FontSize="10"
                             FontWeight="SemiBold"
                             LetterSpacing="1"/>
                </Border>
              </StackPanel>

              <!-- Save button -->
              <Button Grid.Column="1"
                      Content="Save"
                      Command="{Binding SaveSelectedCommand}"
                      IsEnabled="{Binding SelectedEnvironment.IsDirty, FallbackValue=False}"
                      Background="#0d7a5f"
                      Foreground="#ffffff"
                      BorderThickness="0"
                      Padding="14,5"
                      CornerRadius="3"
                      FontSize="12"
                      IsVisible="{Binding SelectedEnvironment, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </Grid>

            <!-- Color row — only shown for regular (non-global) environments -->
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        IsVisible="{Binding SelectedEnvironment.IsGlobal, Converter={x:Static BoolConverters.Not}, FallbackValue=False}">
              <TextBlock Text="Color:"
                         Foreground="#888888"
                         FontSize="11"
                         VerticalAlignment="Center"/>
              <!-- Live color preview swatch -->
              <Border Width="22" Height="22"
                      CornerRadius="3"
                      BorderBrush="#555"
                      BorderThickness="1"
                      VerticalAlignment="Center"
                      Background="{Binding SelectedEnvironment.Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"/>
              <!-- Hex input -->
              <TextBox Text="{Binding SelectedEnvironment.Color, Mode=TwoWay}"
                       Watermark="#rrggbb"
                       Width="88"
                       FontSize="12"
                       FontFamily="Consolas,Menlo,monospace"
                       Padding="6,4"
                       Background="#3c3c3c"
                       Foreground="#d4d4d4"
                       BorderBrush="#555"
                       VerticalAlignment="Center"
                       ToolTip.Tip="Enter a hex color code, e.g. #4ec9b0"/>
              <!-- Clear button -->
              <Button Content="× Clear"
                      Command="{Binding SelectedEnvironment.ClearColorCommand}"
                      IsVisible="{Binding SelectedEnvironment.Color, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
                      Background="Transparent"
                      Foreground="#888"
                      BorderThickness="0"
                      Padding="4,2"
                      FontSize="11"
                      VerticalAlignment="Center"
                      ToolTip.Tip="Remove environment color"/>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- Variable rows -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding SelectedEnvironment, Converter={x:Static ObjectConverters.IsNotNull}}">
          <StackPanel Margin="12,8">

            <!-- Global environment explanation banner -->
            <Border IsVisible="{Binding SelectedEnvironment.IsGlobal, FallbackValue=False}"
                    Background="#1a2a1a"
                    BorderBrush="#2a5a3a"
                    BorderThickness="0,0,0,1"
                    Padding="10,8"
                    Margin="0,0,0,8">
              <TextBlock TextWrapping="Wrap"
                         Foreground="#7db87d"
                         FontSize="12">
                Global variables are always active for this collection, regardless of which
                environment is selected. They are scoped to this collection folder and can be
                checked in to source control. A collection environment variable with the same
                name takes priority.
              </TextBlock>
            </Border>

            <!-- Column headers -->
            <Grid ColumnDefinitions="*,*,Auto,Auto,28"
                  Margin="0,0,0,4">
              <TextBlock Grid.Column="0"
                         Text="NAME"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"/>
              <TextBlock Grid.Column="1"
                         Text="VALUE"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         Margin="6,0"/>
              <TextBlock Grid.Column="2"
                         Text="SECRET"
                         Foreground="#666"
                         FontSize="10"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         HorizontalAlignment="Center"
                         ToolTip.Tip="Secret variables are masked in the UI and excluded from history"
                         Margin="4,0"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding SelectedEnvironment.Variables}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:EnvironmentVariableItemViewModel">
                  <Grid ColumnDefinitions="*,*,Auto,Auto,28"
                        RowDefinitions="Auto,Auto"
                        Margin="0,2">

                    <!-- Name -->
                    <TextBox Grid.Row="0" Grid.Column="0"
                             Text="{Binding Name}"
                             Watermark="name"
                             FontSize="12"
                             Foreground="#d4d4d4"
                             Background="#2d2d30"
                             BorderBrush="#444"
                             Padding="6,4"
                             Margin="0,0,6,0"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas,Menlo,monospace"/>

                    <!-- Value (plain text when not secret or when revealed) -->
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding Value}"
                             Watermark="value"
                             FontSize="12"
                             Foreground="#d4d4d4"
                             Background="#2d2d30"
                             BorderBrush="#444"
                             Padding="6,4"
                             Margin="0,0,6,0"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas,Menlo,monospace"
                             PasswordChar="•"
                             RevealPassword="{Binding IsValueRevealed}"
                             IsVisible="{Binding IsSecret}"/>

                    <!-- Value (always-visible when not secret) -->
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding Value}"
                             Watermark="value"
                             FontSize="12"
                             Foreground="#d4d4d4"
                             Background="#2d2d30"
                             BorderBrush="#444"
                             Padding="6,4"
                             Margin="0,0,6,0"
                             VerticalContentAlignment="Center"
                             FontFamily="Consolas,Menlo,monospace"
                             IsVisible="{Binding !IsSecret}"/>

                    <!-- Secret toggle -->
                    <ToggleButton Grid.Row="0" Grid.Column="2"
                                  IsChecked="{Binding IsSecret}"
                                  Width="32" Height="26"
                                  Background="Transparent"
                                  BorderBrush="#444"
                                  BorderThickness="1"
                                  CornerRadius="3"
                                  Margin="0,0,4,0"
                                  ToolTip.Tip="Mark as secret — masks the value in the UI">
                      <TextBlock Text="🔒"
                                 FontSize="11"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </ToggleButton>

                    <!-- Reveal toggle (only meaningful when IsSecret) -->
                    <ToggleButton Grid.Row="0" Grid.Column="3"
                                  IsChecked="{Binding IsValueRevealed}"
                                  Width="32" Height="26"
                                  Background="Transparent"
                                  BorderBrush="#444"
                                  BorderThickness="1"
                                  CornerRadius="3"
                                  Margin="0,0,4,0"
                                  IsVisible="{Binding IsSecret}"
                                  ToolTip.Tip="Reveal / hide value">
                      <TextBlock Text="👁"
                                 FontSize="11"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </ToggleButton>

                    <!-- Placeholder for reveal column when not secret -->
                    <Border Grid.Row="0" Grid.Column="3"
                            Width="36"
                            IsVisible="{Binding !IsSecret}"/>

                    <!-- Delete -->
                    <Button Grid.Row="0" Grid.Column="4"
                            Content="×"
                            Command="{Binding DeleteCommand}"
                            Background="Transparent"
                            Foreground="#aaa"
                            BorderThickness="0"
                            Padding="4,0"
                            FontSize="14"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            ToolTip.Tip="Remove variable"/>

                    <!-- Preview row — shown when the value contains {{VAR}} references -->
                    <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                            IsVisible="{Binding HasPreview}"
                            Background="#1a1a1a"
                            BorderBrush="#3a3a3a"
                            BorderThickness="0,1,0,0"
                            Padding="4,3"
                            Margin="0,0,0,4">
                      <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0"
                                   Text="PREVIEW"
                                   Foreground="#5a5a5a"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PreviewValue}"
                                   Foreground="#888888"
                                   FontFamily="Consolas,Menlo,monospace"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                      </Grid>
                    </Border>

                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add variable button -->
            <Button Content="+ Add Variable"
                    Command="{Binding SelectedEnvironment.AddVariableCommand}"
                    Background="Transparent"
                    Foreground="#4ec9b0"
                    BorderThickness="0"
                    Padding="0,6,0,0"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    Margin="0,4,0,0"/>
          </StackPanel>
        </ScrollViewer>

        <!-- Empty-state placeholder when nothing is selected -->
        <TextBlock Grid.Row="1"
                   Text="Select an environment from the list to edit its variables."
                   Foreground="#555"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding SelectedEnvironment, Converter={x:Static ObjectConverters.IsNull}}"/>

      </Grid>

    </Grid>

    <!-- ======================================================================
         Delete confirmation overlay
         ====================================================================== -->
    <Grid Grid.Row="0" Grid.RowSpan="2"
          IsVisible="{Binding IsConfirmingDelete}"
          Background="#99000000"
          ZIndex="100">
      <Border Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="24,20"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="340">
        <StackPanel Spacing="16">
          <TextBlock Text="Delete environment?"
                     Foreground="#d4d4d4"
                     FontSize="14"
                     FontWeight="SemiBold"/>
          <TextBlock TextWrapping="Wrap"
                     Foreground="#aaa"
                     FontSize="12">
            <Run Text="&quot;"/><Run Text="{Binding DeleteConfirmationName}"/><Run Text="&quot; and all its variables will be permanently deleted."/>
          </TextBlock>
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Command="{Binding CancelDeleteCommand}"
                    Background="#3a3a3a"
                    Foreground="#ccc"
                    BorderThickness="0"
                    CornerRadius="3"
                    Padding="14,7"
                    FontSize="12"/>
            <Button Content="Delete"
                    Command="{Binding ConfirmDeleteCommand}"
                    Background="#a82020"
                    Foreground="#ffffff"
                    BorderThickness="0"
                    CornerRadius="3"
                    Padding="14,7"
                    FontSize="12"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

  </Grid>

</UserControl>

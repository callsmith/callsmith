<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="280"
             x:Class="Callsmith.Desktop.Views.KeyValueEditorView"
             x:DataType="vm:KeyValueEditorViewModel"
             Background="Transparent">

  <StackPanel Margin="0,0,0,0">

    <!-- Column headers -->
    <Grid IsVisible="{Binding Items.Count}"
          ColumnDefinitions="24,28,1*,2*,28"
          Margin="0,4,0,4">
      <TextBlock Grid.Column="2"
                 Text="Key"
                 Foreground="#888"
                 FontSize="10"
                 FontWeight="SemiBold"
                 LetterSpacing="1"
                 Margin="6,0"/>
      <TextBlock Grid.Column="3"
                 Text="Value"
                 Foreground="#888"
                 FontSize="10"
                 FontWeight="SemiBold"
                 LetterSpacing="1"
                 Margin="6,0"/>
    </Grid>

    <!-- Rows + add button (add appears where the new row will be inserted) -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  AllowAutoHide="False">
      <StackPanel>
        <ItemsControl x:Name="ItemRows" ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:KeyValueItemViewModel">
              <Grid ColumnDefinitions="24,28,1*,2*,28" Margin="0,2">

                <!-- Drag handle -->
                <TextBlock Grid.Column="0"
                           Text="⠿"
                           Foreground="#555"
                           FontSize="14"
                           Padding="2,4,4,4"
                           VerticalAlignment="Center"
                           ToolTip.Tip="Drag to reorder"
                           Cursor="Hand"/>

                <CheckBox Grid.Column="1"
                          IsChecked="{Binding IsEnabled}"
                          IsVisible="{Binding ShowEnabledToggle}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"/>

                <TextBox Grid.Column="2"
                         Text="{Binding Key}"
                         Watermark="key"
                         FontSize="12"
                         Foreground="#d4d4d4"
                         Background="#2d2d30"
                         BorderBrush="#444"
                         Padding="6,4"
                         Margin="2,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas,Menlo,monospace"
                         controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}"/>

                <!-- ── Value column: type selector + text/file content on one line ── -->
                <Grid Grid.Column="3" ColumnDefinitions="Auto,*" Margin="2,0">

                  <!-- Text/File type selector (only present in multipart mode; collapses otherwise) -->
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding AvailableValueTypes}"
                            SelectedItem="{Binding ValueType}"
                            IsVisible="{Binding ShowValueTypeSelector}"
                            MinWidth="72"
                            MaxWidth="90"
                            FontSize="11"
                            Margin="0,0,4,0"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            Foreground="#d4d4d4"
                            Background="#3c3c3c"
                            BorderBrush="#555"/>

                  <TextBox Grid.Column="1"
                           Text="{Binding Value}"
                           Watermark="value"
                           FontSize="12"
                           Foreground="#d4d4d4"
                           Background="#2d2d30"
                           BorderBrush="#444"
                           Padding="6,4"
                           VerticalContentAlignment="Center"
                           FontFamily="Consolas,Menlo,monospace"
                           IsVisible="{Binding IsTextValue}"
                           controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}"/>

                  <!-- File picker (shown when row is in File mode) -->
                  <Grid Grid.Column="1"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="8"
                        VerticalAlignment="Center"
                        ClipToBounds="True"
                        IsVisible="{Binding IsFileValue}">
                    <Button Grid.Column="0"
                            Content="Choose File…"
                            Command="{Binding SelectFileCommand}"
                            Background="#3c3c3c" Foreground="#d4d4d4"
                            BorderBrush="#555" BorderThickness="1"
                            Padding="10,5" CornerRadius="4"/>

                    <Grid Grid.Column="1"
                          VerticalAlignment="Center"
                          ClipToBounds="True">
                      <TextBlock Text="{Binding SelectedFilePath}"
                                 Foreground="#888"
                                 FontFamily="Consolas,Menlo,monospace"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 ClipToBounds="True"
                                 IsVisible="{Binding HasSelectedFile}"/>
                      <TextBlock Text="No file selected"
                                 Foreground="#666"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 ClipToBounds="True"
                                 IsVisible="{Binding !HasSelectedFile}"/>
                    </Grid>
                  </Grid>
                </Grid>

                <Button Grid.Column="4"
                        Content="×"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding ShowDeleteButton}"
                        Background="Transparent"
                        Foreground="#aaa"
                        BorderThickness="0"
                        Padding="4,0"
                        FontSize="14"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>

              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="+ Add"
                Command="{Binding AddItemCommand}"
                IsVisible="{Binding ShowAddButton}"
                Background="Transparent"
                Foreground="#4ec9b0"
                BorderThickness="0"
                Padding="0,6,0,0"
                HorizontalAlignment="Left"
                FontSize="12"
                Margin="30,2,0,0"/>
      </StackPanel>
    </ScrollViewer>

  </StackPanel>

</UserControl>

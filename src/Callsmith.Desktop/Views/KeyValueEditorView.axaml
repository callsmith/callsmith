<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="280"
             x:Class="Callsmith.Desktop.Views.KeyValueEditorView"
             x:DataType="vm:KeyValueEditorViewModel"
             Background="Transparent">

  <StackPanel>

    <!-- Column headers -->
    <Grid ColumnDefinitions="28,*,*,28"
          Margin="0,4,0,4">
      <TextBlock Grid.Column="1"
                 Text="Key"
                 Foreground="#888"
                 FontSize="10"
                 FontWeight="SemiBold"
                 LetterSpacing="1"
                 Margin="6,0"/>
      <TextBlock Grid.Column="2"
                 Text="Value"
                 Foreground="#888"
                 FontSize="10"
                 FontWeight="SemiBold"
                 LetterSpacing="1"
                 Margin="6,0"/>
    </Grid>

    <!-- Rows + add button (add appears where the new row will be inserted) -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:KeyValueItemViewModel">
              <Grid ColumnDefinitions="28,*,*,28" Margin="0,2">

                <CheckBox Grid.Column="0"
                          IsChecked="{Binding IsEnabled}"
                          IsVisible="{Binding ShowEnabledToggle}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"/>

                <!-- ── Key column: plain OR pill-aware ───────────────────── -->

                <!-- Plain text key (path params, form body — no pill support) -->
                <TextBox Grid.Column="1"
                         Text="{Binding Key}"
                         Watermark="key"
                         FontSize="12"
                         Foreground="#d4d4d4"
                         Background="#2d2d30"
                         BorderBrush="#444"
                         Padding="6,4"
                         Margin="2,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas,Menlo,monospace"
                         IsVisible="{Binding !ShowKeyPills}"
                         controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}"/>

                <!-- Pill-capable plain key (headers, query params — pills enabled, no segments yet) -->
                <TextBox Grid.Column="1"
                         Text="{Binding KeyField.Text}"
                         Watermark="key"
                         FontSize="12"
                         Foreground="#d4d4d4"
                         Background="#2d2d30"
                         BorderBrush="#444"
                         Padding="6,4"
                         Margin="2,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas,Menlo,monospace"
                         IsVisible="{Binding ShowKeyPlainInput}"
                         controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}">
                  <TextBox.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Dynamic Value…" Command="{Binding KeyField.AddDynamicValueCommand}"/>
                      <MenuItem Header="Mock Data…"     Command="{Binding KeyField.AddMockDataCommand}"/>
                    </ContextMenu>
                  </TextBox.ContextMenu>
                </TextBox>

                <!-- Pill view for key (headers, query params — when segments are present) -->
                <Border Grid.Column="1"
                        Background="#2d2d30"
                        BorderBrush="#4ec9b0"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="4,2"
                        Margin="2,0"
                        MinHeight="28"
                        IsVisible="{Binding ShowKeyPillView}">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Dynamic Value…" Command="{Binding KeyField.AddDynamicValueCommand}"/>
                      <MenuItem Header="Mock Data…"     Command="{Binding KeyField.AddMockDataCommand}"/>
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Grid ColumnDefinitions="Auto,*">
                    <ItemsControl Grid.Column="0" ItemsSource="{Binding KeyField.DisplaySegments}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SegmentedValueFieldViewModel+SegmentDisplayItem">
                          <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding StaticText, Mode=TwoWay}"
                                     IsVisible="{Binding IsStatic}"
                                     Foreground="#cccccc"
                                     FontFamily="Consolas,Menlo,monospace"
                                     FontSize="11"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Margin="2,1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="2,1"
                                     MinWidth="20"
                                     Watermark="…">
                              <TextBox.ContextMenu>
                                <ContextMenu>
                                  <MenuItem Header="Dynamic Value…" Command="{Binding AddDynamicValueCommand}"/>
                                  <MenuItem Header="Mock Data…"     Command="{Binding AddMockDataCommand}"/>
                                </ContextMenu>
                              </TextBox.ContextMenu>
                              <TextBox.Styles>
                                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                  <Setter Property="BorderThickness" Value="0"/>
                                  <Setter Property="Background" Value="Transparent"/>
                                </Style>
                              </TextBox.Styles>
                            </TextBox>
                            <Border Background="#1a3a2a" BorderBrush="#2a6a4a" BorderThickness="1"
                                    CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                    IsVisible="{Binding IsDynamic}" VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="{Binding PillLabel}"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).KeyField.EditDynamicSegmentCommand}"
                                        CommandParameter="{Binding DynamicSegment}"
                                        Background="Transparent" Foreground="#4ec9b0"
                                        BorderThickness="0" Padding="0"
                                        FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"
                                        ToolTip.Tip="Click to edit dynamic reference"/>
                                <Button Content="×"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).KeyField.RemoveSegmentCommand}"
                                        CommandParameter="{Binding RawSegment}"
                                        Background="Transparent" Foreground="#888"
                                        BorderThickness="0" Padding="2,0" FontSize="12" Cursor="Hand"
                                        ToolTip.Tip="Remove this dynamic reference"/>
                              </StackPanel>
                            </Border>
                            <Border Background="#2a1a3a" BorderBrush="#6a2a9a" BorderThickness="1"
                                    CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                    IsVisible="{Binding IsMockData}" VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="{Binding PillLabel}"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).KeyField.EditMockSegmentCommand}"
                                        CommandParameter="{Binding MockDataSegment}"
                                        Background="Transparent" Foreground="#c586c0"
                                        BorderThickness="0" Padding="0"
                                        FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"
                                        ToolTip.Tip="Click to change mock data generator"/>
                                <Button Content="×"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).KeyField.RemoveSegmentCommand}"
                                        CommandParameter="{Binding RawSegment}"
                                        Background="Transparent" Foreground="#888"
                                        BorderThickness="0" Padding="2,0" FontSize="12" Cursor="Hand"
                                        ToolTip.Tip="Remove this mock data generator"/>
                              </StackPanel>
                            </Border>
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox Grid.Column="1"
                             IsVisible="{Binding KeyField.HasTrailingInput}"
                             Text="{Binding KeyField.TrailingText, Mode=TwoWay}"
                             Foreground="#cccccc"
                             FontFamily="Consolas,Menlo,monospace"
                             FontSize="11"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="2,1"
                             HorizontalAlignment="Stretch">
                      <TextBox.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Dynamic Value…" Command="{Binding KeyField.AddDynamicValueCommand}"/>
                          <MenuItem Header="Mock Data…"     Command="{Binding KeyField.AddMockDataCommand}"/>
                        </ContextMenu>
                      </TextBox.ContextMenu>
                      <TextBox.Styles>
                        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                          <Setter Property="BorderThickness" Value="0"/>
                          <Setter Property="Background" Value="Transparent"/>
                        </Style>
                      </TextBox.Styles>
                    </TextBox>
                  </Grid>
                </Border>

                <!-- ── Value column: plain input OR pill view ──────────────── -->

                <!-- Plain text input (no dynamic segments) -->
                <TextBox Grid.Column="2"
                         Text="{Binding ValueField.Text}"
                         Watermark="value"
                         FontSize="12"
                         Foreground="#d4d4d4"
                         Background="#2d2d30"
                         BorderBrush="#444"
                         Padding="6,4"
                         Margin="2,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas,Menlo,monospace"
                         IsVisible="{Binding ValueField.ShowPlainInput}"
                         controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}">
                  <TextBox.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Dynamic Value…"
                                Command="{Binding ValueField.AddDynamicValueCommand}"/>
                      <MenuItem Header="Mock Data…"
                                Command="{Binding ValueField.AddMockDataCommand}"/>
                    </ContextMenu>
                  </TextBox.ContextMenu>
                </TextBox>

                <!-- Pill view (active when the value contains dynamic/mock segments) -->
                <Border Grid.Column="2"
                        Background="#2d2d30"
                        BorderBrush="#4ec9b0"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="4,2"
                        Margin="2,0"
                        MinHeight="28"
                        IsVisible="{Binding ValueField.HasSegments}">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Dynamic Value…"
                                Command="{Binding ValueField.AddDynamicValueCommand}"/>
                      <MenuItem Header="Mock Data…"
                                Command="{Binding ValueField.AddMockDataCommand}"/>
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Grid ColumnDefinitions="Auto,*">

                    <ItemsControl Grid.Column="0" ItemsSource="{Binding ValueField.DisplaySegments}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SegmentedValueFieldViewModel+SegmentDisplayItem">
                          <StackPanel Orientation="Horizontal">

                            <!-- Static text segment — inline editable -->
                            <TextBox Text="{Binding StaticText, Mode=TwoWay}"
                                     IsVisible="{Binding IsStatic}"
                                     Foreground="#cccccc"
                                     FontFamily="Consolas,Menlo,monospace"
                                     FontSize="11"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Margin="2,1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="2,1"
                                     MinWidth="20"
                                     Watermark="…">
                              <TextBox.ContextMenu>
                                <ContextMenu>
                                  <MenuItem Header="Dynamic Value…"
                                            Command="{Binding AddDynamicValueCommand}"/>
                                  <MenuItem Header="Mock Data…"
                                            Command="{Binding AddMockDataCommand}"/>
                                </ContextMenu>
                              </TextBox.ContextMenu>
                              <TextBox.Styles>
                                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                  <Setter Property="BorderThickness" Value="0"/>
                                  <Setter Property="Background" Value="Transparent"/>
                                </Style>
                              </TextBox.Styles>
                            </TextBox>

                            <!-- Dynamic reference pill -->
                            <Border Background="#1a3a2a"
                                    BorderBrush="#2a6a4a"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6,2,2,2"
                                    Margin="2,2"
                                    IsVisible="{Binding IsDynamic}"
                                    VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="{Binding PillLabel}"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).ValueField.EditDynamicSegmentCommand}"
                                        CommandParameter="{Binding DynamicSegment}"
                                        Background="Transparent"
                                        Foreground="#4ec9b0"
                                        BorderThickness="0"
                                        Padding="0"
                                        FontFamily="Consolas,Menlo,monospace"
                                        FontSize="11"
                                        Cursor="Hand"
                                        ToolTip.Tip="Click to edit dynamic reference"/>
                                <Button Content="×"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).ValueField.RemoveSegmentCommand}"
                                        CommandParameter="{Binding RawSegment}"
                                        Background="Transparent"
                                        Foreground="#888"
                                        BorderThickness="0"
                                        Padding="2,0"
                                        FontSize="12"
                                        Cursor="Hand"
                                        ToolTip.Tip="Remove this dynamic reference"/>
                              </StackPanel>
                            </Border>

                            <!-- Mock data pill -->
                            <Border Background="#2a1a3a"
                                    BorderBrush="#6a2a9a"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6,2,2,2"
                                    Margin="2,2"
                                    IsVisible="{Binding IsMockData}"
                                    VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="{Binding PillLabel}"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).ValueField.EditMockSegmentCommand}"
                                        CommandParameter="{Binding MockDataSegment}"
                                        Background="Transparent"
                                        Foreground="#c586c0"
                                        BorderThickness="0"
                                        Padding="0"
                                        FontFamily="Consolas,Menlo,monospace"
                                        FontSize="11"
                                        Cursor="Hand"
                                        ToolTip.Tip="Click to change mock data generator"/>
                                <Button Content="×"
                                        Command="{Binding $parent[ItemsControl].((vm:KeyValueItemViewModel)DataContext).ValueField.RemoveSegmentCommand}"
                                        CommandParameter="{Binding RawSegment}"
                                        Background="Transparent"
                                        Foreground="#888"
                                        BorderThickness="0"
                                        Padding="2,0"
                                        FontSize="12"
                                        Cursor="Hand"
                                        ToolTip.Tip="Remove this mock data generator"/>
                              </StackPanel>
                            </Border>

                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Trailing free-form input -->
                    <TextBox Grid.Column="1"
                             IsVisible="{Binding ValueField.HasTrailingInput}"
                             Text="{Binding ValueField.TrailingText, Mode=TwoWay}"
                             Foreground="#cccccc"
                             FontFamily="Consolas,Menlo,monospace"
                             FontSize="11"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="2,1"
                             HorizontalAlignment="Stretch">
                      <TextBox.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Dynamic Value…"
                                    Command="{Binding ValueField.AddDynamicValueCommand}"/>
                          <MenuItem Header="Mock Data…"
                                    Command="{Binding ValueField.AddMockDataCommand}"/>
                        </ContextMenu>
                      </TextBox.ContextMenu>
                      <TextBox.Styles>
                        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                          <Setter Property="BorderThickness" Value="0"/>
                          <Setter Property="Background" Value="Transparent"/>
                        </Style>
                      </TextBox.Styles>
                    </TextBox>

                  </Grid>
                </Border>

                <Button Grid.Column="3"
                        Content="×"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding ShowDeleteButton}"
                        Background="Transparent"
                        Foreground="#aaa"
                        BorderThickness="0"
                        Padding="4,0"
                        FontSize="14"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>

              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="+ Add"
                Command="{Binding AddItemCommand}"
                Cursor="Hand"
                IsVisible="{Binding ShowAddButton}"
                Background="Transparent"
                Foreground="#4ec9b0"
                BorderThickness="0"
                Padding="0,6,0,0"
                HorizontalAlignment="Left"
                FontSize="12"
                Margin="30,2,0,0"/>
      </StackPanel>
    </ScrollViewer>

  </StackPanel>

</UserControl>

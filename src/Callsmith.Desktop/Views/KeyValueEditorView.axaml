<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="280"
             x:Class="Callsmith.Desktop.Views.KeyValueEditorView"
             x:DataType="vm:KeyValueEditorViewModel"
             Background="Transparent">

  <StackPanel>

    <!-- Column headers -->
    <Grid ColumnDefinitions="28,*,*,28"
          Margin="0,4,0,4">
      <TextBlock Grid.Column="1"
                 Text="Key"
                 Foreground="#888"
                 FontSize="10"
                 FontWeight="SemiBold"
                 LetterSpacing="1"
                 Margin="6,0"/>
      <TextBlock Grid.Column="2"
                 Text="Value"
                 Foreground="#888"
                 FontSize="10"
                 FontWeight="SemiBold"
                 LetterSpacing="1"
                 Margin="6,0"/>
    </Grid>

    <!-- Rows + add button (add appears where the new row will be inserted) -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:KeyValueItemViewModel">
              <Grid ColumnDefinitions="28,*,*,28" Margin="0,2">

                <CheckBox Grid.Column="0"
                          IsChecked="{Binding IsEnabled}"
                          IsVisible="{Binding ShowEnabledToggle}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         Text="{Binding Key}"
                         Watermark="key"
                         FontSize="12"
                         Foreground="#d4d4d4"
                         Background="#2d2d30"
                         BorderBrush="#444"
                         Padding="6,4"
                         Margin="2,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas,Menlo,monospace"
                         controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}"/>

                <TextBox Grid.Column="2"
                         Text="{Binding Value}"
                         Watermark="value"
                         FontSize="12"
                         Foreground="#d4d4d4"
                         Background="#2d2d30"
                         BorderBrush="#444"
                         Padding="6,4"
                         Margin="2,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas,Menlo,monospace"
                         controls:EnvVarCompletion.Suggestions="{Binding SuggestionNames}"/>

                <Button Grid.Column="3"
                        Content="×"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding ShowDeleteButton}"
                        Background="Transparent"
                        Foreground="#aaa"
                        BorderThickness="0"
                        Padding="4,0"
                        FontSize="14"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>

              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="+ Add"
                Command="{Binding AddItemCommand}"
                IsVisible="{Binding ShowAddButton}"
                Background="Transparent"
                Foreground="#4ec9b0"
                BorderThickness="0"
                Padding="0,6,0,0"
                HorizontalAlignment="Left"
                FontSize="12"
                Margin="30,2,0,0"/>
      </StackPanel>
    </ScrollViewer>

  </StackPanel>

</UserControl>

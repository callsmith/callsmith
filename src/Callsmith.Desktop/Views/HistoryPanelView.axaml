<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:views="using:Callsmith.Desktop.Views"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="Callsmith.Desktop.Views.HistoryPanelView"
             x:DataType="vm:HistoryPanelViewModel"
             Background="#1e1e1e">

  <UserControl.Styles>
    <Style Selector="TabControl.detail-response-tabs TabItem">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="MinHeight" Value="28"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </UserControl.Styles>

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}"/>
  </UserControl.KeyBindings>

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- ======================================================================
         Header bar
         ====================================================================== -->
    <Border Grid.Row="0"
            Background="#252526"
            BorderBrush="#444"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">

        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="Request History"
                     Foreground="#d4d4d4"
                     FontSize="14"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ScopeLabel}"
                     Foreground="#8aa7bf"
                     FontSize="11"
                     FontStyle="Italic"
                     LineHeight="15"
                     Padding="0,1,2,0"
                     Margin="8,1,12,0"
                     VerticalAlignment="Center"/>
          <Button Content="Show Global History"
            Command="{Binding ShowAllHistoryCommand}"
            IsVisible="{Binding IsRequestScoped}"
            FontSize="11"
            Background="Transparent"
            Foreground="#dcdcaa"
            BorderBrush="#555"
            BorderThickness="1"
            Padding="8,2"/>
          <Border Background="#5a1a1a"
                  CornerRadius="4"
                  Padding="8,3"
                  IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#f48771"
                       FontSize="12"/>
          </Border>
        </StackPanel>

        <Button Grid.Column="1"
                Content="← Back to Editor"
                Command="{Binding CloseCommand}"
                FontSize="11"
                Background="Transparent"
                Foreground="#4ec9b0"
                BorderThickness="0"
                Padding="8,3"
                ToolTip.Tip="Return to the request editor"/>
      </Grid>
    </Border>

    <!-- ======================================================================
         Filter bar
         ====================================================================== -->
    <Border Grid.Row="1"
            Background="#252526"
            BorderBrush="#333"
            BorderThickness="0,0,0,1"
            Padding="12,8">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="0">

          <!-- Environment selector -->
          <ComboBox ItemsSource="{Binding EnvironmentOptions}"
              SelectedItem="{Binding SelectedEnvironmentOption}"
              Width="170"
              FontSize="12"
              Background="#1e1e1e"
              Foreground="#d4d4d4"
              BorderBrush="#555">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:HistoryEnvironmentOptionViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Border Width="10" Height="10"
                          CornerRadius="2"
                          Background="{Binding Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                          IsVisible="{Binding Color, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
                          VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <!-- Global search -->
          <Grid Width="280">
            <TextBox Text="{Binding GlobalSearchText}"
                    Watermark="Search all — URL, name, headers, body…"
                    FontSize="12"
                    Background="#1e1e1e"
                    Foreground="#d4d4d4"
                    BorderBrush="#555"
                    VerticalContentAlignment="Center"
                    Padding="6,0,24,0"/>
            <Button Content="×"
                    Command="{Binding ClearGlobalSearchTextCommand}"
                    IsVisible="{Binding GlobalSearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Focusable="False"
                    Width="18" Height="18" Margin="0,0,5,0"
                    Background="Transparent" Foreground="#888"
                    BorderThickness="0" Padding="0" FontSize="12"
                    ToolTip.Tip="Clear"/>
          </Grid>

          <!-- Advanced search button -->
          <Button Content="Advanced Search"
                  Command="{Binding OpenAdvancedSearchCommand}"
                  FontSize="12"
                  Background="Transparent"
                  Foreground="#9cdcfe"
                  BorderBrush="#555"
                  BorderThickness="1"
                  Padding="10,4"/>

          <!-- Active advanced filters badge -->
          <Border Background="#1a3a5a"
                  CornerRadius="4"
                  Padding="6,2,2,2"
                  IsVisible="{Binding HasActiveAdvancedFilters}"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="{Binding ActiveAdvancedFilterCount, StringFormat='{}{0} filter active', FallbackValue=''}"
                        Foreground="#9cdcfe"
                        FontSize="11"
                        VerticalAlignment="Center"/>
              <Button Content="×"
                      Command="{Binding ClearAdvancedFiltersCommand}"
                      Background="Transparent"
                      Foreground="#9cdcfe"
                      BorderThickness="0"
                      Padding="2,0"
                      Focusable="False"
                      FontSize="12"
                      ToolTip.Tip="Clear all advanced filters"/>
            </StackPanel>
          </Border>

          <!-- Result count -->
          <TextBlock Text="{Binding ResultCountLabel}"
                    Foreground="#888"
                    FontSize="11"
                    VerticalAlignment="Center"
                    IsVisible="{Binding !IsLoading}"/>
          <TextBlock Text="Loading…"
                    Foreground="#888"
                    FontSize="11"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsLoading}"/>
        </StackPanel>
        <Button Grid.Column="1"
                Content="Purge old entries..."
                Command="{Binding OpenPurgeDialogCommand}"
                FontSize="11"
                Background="Transparent"
                Foreground="#f48771"
                BorderThickness="1"
                BorderBrush="#555"
                Padding="8,3"/>
      </Grid>
    </Border>

    <!-- ======================================================================
         Main body: list (left) + detail (right) — outer split is resizable
         ====================================================================== -->
    <Grid Grid.Row="2" ColumnDefinitions="320,5,*">

      <!-- ────────────────────────────────────────────────────────────────────
           Left: history list
           ──────────────────────────────────────────────────────────────────── -->
      <Grid Grid.Column="0" RowDefinitions="*,Auto" Background="#1e1e1e">

        <ListBox x:Name="HistoryEntriesList"
           Grid.Row="0"
                 ItemsSource="{Binding Entries}"
                 SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="#2d2d30"/>
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="#2a2a2a"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:HistoryEntryRowViewModel">
              <Border BorderBrush="#333"
                      BorderThickness="0,0,0,1"
                      Padding="12,8">
                <Grid ColumnDefinitions="52,*,70,80">

                  <!-- Method badge -->
                  <Border Grid.Column="0"
                          Width="42"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                    <Border Background="{Binding Method, Converter={x:Static conv:HttpMethodToBrushConverter.Instance}}"
                            CornerRadius="3"
                            Padding="5,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding MethodPillLabel}"
                                 Foreground="#1a1a1a"
                                 FontSize="9"
                                 FontWeight="Bold"
                                 VerticalAlignment="Center"/>
                    </Border>
                  </Border>

                  <!-- Request name -->
                  <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RequestName}"
                               Foreground="#d4d4d4"
                               FontSize="12"
                               IsVisible="{Binding RequestName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                IsVisible="{Binding EnvironmentName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                      <Border Width="8"
                              Height="8"
                              CornerRadius="2"
                              Margin="0,0,0,2"
                              Background="{Binding EnvironmentColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                              IsVisible="{Binding EnvironmentColor, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
                              VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding EnvironmentName, StringFormat='Env: {0}'}"
                                 Foreground="#6fb1d6"
                                 FontSize="10"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                  </StackPanel>

                  <!-- Status code -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding StatusCode}"
                             Foreground="{Binding StatusColor}"
                             ToolTip.Tip="{Binding DetailStatusCode}"
                             FontSize="12"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Right"/>

                  <!-- Sent At + elapsed -->
                  <StackPanel Grid.Column="3"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              ToolTip.Tip="{Binding DetailSentAtDisplay}">
                    <TextBlock Text="{Binding SentAtDisplay}"
                               Foreground="#888"
                               FontSize="10"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding ElapsedDisplay}"
                               Foreground="#666"
                               FontSize="10"
                               HorizontalAlignment="Right"/>
                  </StackPanel>

                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.ContextMenu>
            <ContextMenu x:Name="HistoryEntryContextMenu"/>
          </ListBox.ContextMenu>
        </ListBox>

        <!-- Status message footer -->
        <Border Grid.Row="1"
          Background="#252526"
          BorderBrush="#333"
          BorderThickness="0,1,0,0"
          Padding="12,8"
          IsVisible="{Binding HistoryListStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <TextBlock Text="{Binding HistoryListStatusMessage}"
               Foreground="#888"
               FontSize="12"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
        </Border>

              <!-- Delete confirmation popup (matches collection delete UX) -->
              <Border Grid.Row="0"
                Grid.RowSpan="2"
                IsVisible="{Binding PendingDeleteEntry, Converter={x:Static conv:NotNullConverter.Instance}}"
                Background="#66000000">
                <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="230"
                  Background="#2d2d30"
                  BorderBrush="#555"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="14,12"
                  BoxShadow="0 4 20 0 #CC000000">
                  <StackPanel Spacing="10">
                    <TextBlock Foreground="#f0c060"
                   FontSize="13"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Text="{Binding PendingDeleteEntryLabel, StringFormat='Delete &quot;{0}&quot;?', FallbackValue=''}"/>
                    <TextBlock Foreground="#999"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Text="This cannot be undone."/>
                    <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="6">
                <Button Content="Cancel"
                  Command="{Binding CancelRemoveEntryDeleteCommand}"
                  Background="#3a3a3a"
                  Foreground="#ccc"
                  BorderThickness="0"
                  Padding="12,4"
                  FontSize="11"
                  CornerRadius="3"/>
                <Button Content="Delete"
                  Command="{Binding ConfirmRemoveEntryDeleteCommand}"
                  Background="#922"
                  Foreground="White"
                  BorderThickness="0"
                  Padding="12,4"
                  FontSize="11"
                  CornerRadius="3"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </Border>

      </Grid>

      <!-- vertical separator — resizable -->
      <GridSplitter Grid.Column="1"
                    Background="#333"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

      <!-- ────────────────────────────────────────────────────────────────────
           Right: detail panel — split view (request | response)
           ──────────────────────────────────────────────────────────────────── -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*" Background="#1e1e1e">

        <!-- Detail header: title + timestamp on the left; layout toggle on the right -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#333"
                BorderThickness="0,0,0,1"
                Padding="8,6"
                IsVisible="{Binding HasDetail}">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Entry Detail"
                         Foreground="#d4d4d4"
                         FontSize="13"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding DetailSentAtDisplay}"
                         ToolTip.Tip="{Binding DetailSentAtToolTip}"
                         Foreground="#888"
                         FontSize="11"
                         FontStyle="Italic"
                         Padding="0,0,5,0"
                         VerticalAlignment="Center"
                         IsVisible="{Binding DetailSentAtDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
            <!-- Layout toggle button -->
            <Button Grid.Column="1"
                    Command="{Binding ToggleDetailLayoutCommand}"
                    Background="Transparent" Foreground="#888" BorderThickness="0"
                    Padding="6,4" Margin="4,0,0,0" VerticalAlignment="Center"
                    ToolTip.Tip="Toggle layout (horizontal / vertical)">
              <Grid>
                <!-- Stacked-panes icon: shown in vertical mode → click for horizontal -->
                <PathIcon Width="14" Height="14" Foreground="#888"
                          IsVisible="{Binding IsHorizontalDetailLayout, Converter={x:Static BoolConverters.Not}}"
                          Data="M2,3 L10,3 L10,21 L2,21 Z M14,3 L22,3 L22,21 L14,21 Z"/>
                <!-- Side-by-side icon: shown in horizontal mode → click for vertical -->
                <PathIcon Width="14" Height="14" Foreground="#888"
                          IsVisible="{Binding IsHorizontalDetailLayout}"
                          Data="M2,3 L22,3 L22,10 L2,10 Z M2,14 L22,14 L22,21 L2,21 Z"/>
              </Grid>
            </Button>
          </Grid>
        </Border>

        <!-- Empty state -->
        <TextBlock Grid.Row="0" Grid.RowSpan="2"
                   Text="Select an entry to see details"
                   Foreground="#555"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding !HasDetail}"/>

        <!-- Split panel: request (left/top) + splitter + response (right/bottom).
             Rearranged by code-behind based on IsHorizontalDetailLayout.
             Default (horizontal): ColumnDefinitions="0.45*,5,0.55*" -->
        <Grid x:Name="DetailContentGrid"
              Grid.Row="1"
              IsVisible="{Binding HasDetail}"
              ColumnDefinitions="0.45*,5,0.55*">

          <!-- Request panel: scrollable configured + resolved request text -->
          <ScrollViewer x:Name="DetailRequestPanel"
                        Grid.Column="0"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12" Spacing="12">

              <!-- Configured request -->
              <StackPanel Spacing="4">
                <TextBlock Text="CONFIGURED REQUEST"
                           Foreground="#888"
                           FontSize="10"
                           FontWeight="Bold"
                           LetterSpacing="1"/>
                <Border Background="#252526"
                        CornerRadius="4"
                        Padding="10">
                  <SelectableTextBlock Text="{Binding DetailConfigured}"
                                       Background="Transparent"
                                       Foreground="#d4d4d4"
                                       FontFamily="Consolas,Cascadia Mono,monospace"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                </Border>
              </StackPanel>

              <!-- Resolved request -->
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="RESOLVED REQUEST"
                             Foreground="#888"
                             FontSize="10"
                             FontWeight="Bold"
                             LetterSpacing="1"
                             VerticalAlignment="Center"/>
                  <Button Content="Resend Request"
                          Command="{Binding ResendRequestCommand}"
                          FontSize="11"
                          Background="Transparent"
                          Foreground="#9cdcfe"
                          BorderThickness="1"
                          BorderBrush="#555"
                          Padding="8,3"
                          VerticalAlignment="Center"/>
                  <Panel IsVisible="{Binding HasHiddenSecrets}">
                    <Button Content="Reveal Secrets"
                            Command="{Binding RevealSecretsCommand}"
                            IsVisible="{Binding !IsSecretShown}"
                            IsEnabled="{Binding !IsRevealingSecrets}"
                            FontSize="11"
                            Background="Transparent"
                            Foreground="#dcdcaa"
                            BorderThickness="1"
                            BorderBrush="#555"
                            Padding="8,3"
                            VerticalAlignment="Center"/>
                    <Button Content="Hide Secrets"
                            Command="{Binding HideSecretsCommand}"
                            IsVisible="{Binding IsSecretShown}"
                            FontSize="11"
                            Background="Transparent"
                            Foreground="#dcdcaa"
                            BorderThickness="1"
                            BorderBrush="#555"
                            Padding="8,3"
                            VerticalAlignment="Center"/>
                  </Panel>
                </StackPanel>
                <Border Background="#252526"
                        CornerRadius="4"
                        Padding="10">
                  <SelectableTextBlock Text="{Binding DetailResolved}"
                                       Background="Transparent"
                                       Foreground="#d4d4d4"
                                       FontFamily="Consolas,Cascadia Mono,monospace"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                </Border>
              </StackPanel>

            </StackPanel>
          </ScrollViewer>

          <!-- Splitter -->
          <GridSplitter x:Name="DetailContentSplitter"
                        Grid.Column="1"
                        Background="#333"
                        ResizeDirection="Columns"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>

          <!-- Response panel: TabControl with Body + Headers tabs.
               Body tab uses SyntaxEditor (full height, virtualised).
               Headers tab uses a scrollable table. -->
          <Grid x:Name="DetailResponsePanel"
                Grid.Column="2"
                Background="#252526">
            <TabControl Classes="detail-response-tabs" Background="Transparent">

              <TabItem Header="Response Body">
                <Grid Margin="10,4,10,10">
                  <Border Background="#1e1e1e"
                          CornerRadius="4"
                          Padding="10"
                          IsVisible="{Binding DetailHasResponseBody}">
                    <controls:SyntaxEditor Text="{Binding DetailResponse}"
                                           Language="{Binding DetailResponseLanguage}"
                                           IsReadOnly="True"/>
                  </Border>
                  <TextBlock Text="No body returned for response"
                             Foreground="#666"
                             FontSize="12"
                             FontStyle="Italic"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsVisible="{Binding !DetailHasResponseBody}"/>
                </Grid>
              </TabItem>

              <TabItem Header="Response Headers">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Margin="10,4,10,10">
                  <StackPanel Spacing="0">
                    <TextBlock Text="No response headers"
                               Foreground="#666"
                               FontSize="12"
                               FontStyle="Italic"
                               Padding="4,8"
                               IsVisible="{Binding !HasDetailResponseHeaders}"/>
                    <StackPanel Spacing="0"
                                IsVisible="{Binding HasDetailResponseHeaders}">
                      <Border Background="#3a3a3a"
                              CornerRadius="4,4,0,0"
                              Padding="10,6">
                        <Grid ColumnDefinitions="220,*">
                          <TextBlock Text="Header"
                                     Foreground="#c5c5c5"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     LetterSpacing="0.4"/>
                          <TextBlock Grid.Column="1"
                                     Text="Value"
                                     Foreground="#c5c5c5"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     LetterSpacing="0.4"/>
                        </Grid>
                      </Border>
                      <ItemsControl ItemsSource="{Binding DetailResponseHeaderRows}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:ResponseHeaderRowViewModel">
                            <Border Background="{Binding RowBackground}"
                                    BorderBrush="#3c3c3c"
                                    BorderThickness="0,0,0,1"
                                    Padding="10,6">
                              <Grid ColumnDefinitions="220,*">
                                <SelectableTextBlock Text="{Binding Name}"
                                                     Background="Transparent"
                                                     Foreground="#d7d7d7"
                                                     FontFamily="Consolas,Cascadia Mono,monospace"
                                                     FontSize="12"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     TextWrapping="Wrap"/>
                                <SelectableTextBlock Grid.Column="1"
                                                     Text="{Binding Value}"
                                                     Background="Transparent"
                                                     Foreground="#9cdcfe"
                                                     FontFamily="Consolas,Cascadia Mono,monospace"
                                                     FontSize="12"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     TextWrapping="Wrap"/>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </StackPanel>
                </ScrollViewer>
              </TabItem>

            </TabControl>
          </Grid>

        </Grid>

      </Grid>

    </Grid>

    <!-- Purge old entries modal -->
    <Border Grid.Row="0"
            Grid.RowSpan="3"
            IsVisible="{Binding IsPurgeDialogOpen}"
            Background="#66000000">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="430"
              Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="16,14"
              BoxShadow="0 4 20 0 #CC000000">
        <StackPanel Spacing="12">
          <TextBlock Text="Purge history entries"
                     Foreground="#f0c060"
                     FontSize="14"
                     FontWeight="SemiBold"/>

          <TextBlock Foreground="#d4d4d4" FontSize="12" TextWrapping="Wrap">
            Purge history entries in
          </TextBlock>

          <ComboBox ItemsSource="{Binding EnvironmentOptions}"
                    SelectedItem="{Binding SelectedPurgeEnvironmentOption}"
                    Width="220"
                    FontSize="12"
                    Background="#1e1e1e"
                    Foreground="#d4d4d4"
                    BorderBrush="#555">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:HistoryEnvironmentOptionViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Border Width="10" Height="10"
                          CornerRadius="2"
                          Background="{Binding Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                          IsVisible="{Binding Color, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
                          VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Foreground="#d4d4d4" FontSize="12" TextWrapping="Wrap">
            older than
          </TextBlock>

          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBox Text="{Binding PurgeOlderThanDaysText}"
                     Width="90"
                     IsEnabled="{Binding !IsPurgeAllTime}"
                     FontSize="12"
                     HorizontalContentAlignment="Right"
                     Background="#1e1e1e"
                     Foreground="#d4d4d4"
                     BorderBrush="#555"/>
            <TextBlock Text="days"
                       Foreground="#d4d4d4"
                       FontSize="12"
                       VerticalAlignment="Center"/>
          </StackPanel>

               <CheckBox IsChecked="{Binding IsPurgeAllTime}"
                      Foreground="#d4d4d4"
                      FontSize="12"
                      Content="All time"/>

          <TextBlock Text="{Binding PurgeDialogErrorMessage}"
                     IsVisible="{Binding PurgeDialogErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Foreground="#f48771"
                     FontSize="11"
                     TextWrapping="Wrap"/>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="6">
            <Button Content="Cancel"
                    Command="{Binding CancelPurgeDialogCommand}"
                    Background="#3a3a3a"
                    Foreground="#ccc"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
            <Button Content="OK"
                    Command="{Binding ConfirmPurgeDialogCommand}"
                    IsEnabled="{Binding CanConfirmPurgeDialog}"
                    Background="#922"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- Advanced search modal -->
    <Border Grid.Row="0"
            Grid.RowSpan="3"
            IsVisible="{Binding IsAdvancedSearchOpen}"
            Background="#66000000">
      <views:AdvancedHistorySearchView DataContext="{Binding AdvancedSearch}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
    </Border>

    <!-- Clear history confirmation popup (centered on full history panel) -->
    <Border Grid.Row="0"
            Grid.RowSpan="3"
            IsVisible="{Binding IsClearHistoryConfirmOpen}"
            Background="#66000000">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="230"
              Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="14,12"
              BoxShadow="0 4 20 0 #CC000000">
        <StackPanel Spacing="10">
          <TextBlock Foreground="#f0c060"
                     FontSize="13"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     Text="{Binding ClearHistoryConfirmTitle}"/>
          <TextBlock Foreground="#ccc"
                     FontSize="11"
                     TextWrapping="Wrap"
                     IsVisible="{Binding !ClearHistoryConfirmIsAllTime}">
            <Run Text="This will delete history records in "/>
            <Bold><Run Text="{Binding ClearHistoryConfirmEnvironmentLabel}"/></Bold>
            <Run Text=" older than "/>
            <Bold><Run Text="{Binding ClearHistoryConfirmDaysLabel}"/></Bold>
            <Run Text=" days."/>
          </TextBlock>
          <TextBlock Foreground="#ccc"
                     FontSize="11"
                     TextWrapping="Wrap"
                     IsVisible="{Binding ClearHistoryConfirmIsAllTime}">
            <Run Text="This will delete history records in "/>
            <Bold><Run Text="{Binding ClearHistoryConfirmEnvironmentLabel}"/></Bold>
            <Run Text=" for "/>
            <Bold><Run Text="all time"/></Bold>
            <Run Text="."/>
          </TextBlock>
          <TextBlock Foreground="#999"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Text="{Binding ClearHistoryConfirmDescription}"/>
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="6">
            <Button Content="Cancel"
                    Command="{Binding CancelClearHistoryCommand}"
                    Background="#3a3a3a"
                    Foreground="#ccc"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
            <Button Content="{Binding ClearHistoryConfirmButtonLabel}"
                    Command="{Binding ConfirmClearHistoryCommand}"
                    Background="#922"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

  </Grid>

</UserControl>

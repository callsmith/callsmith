<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="34"
             x:Class="Callsmith.Desktop.Views.EnvironmentSelectorView"
             x:DataType="vm:EnvironmentViewModel">

  <!-- Compact toolbar strip: label + environment chooser + manage button -->
  <DockPanel>

    <!-- Active environment color swatch — only visible when the selected env has a color -->
    <Border DockPanel.Dock="Left"
            Width="10" Height="10"
            CornerRadius="2"
            Background="{Binding ActiveEnvironment.Color, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
            IsVisible="{Binding ActiveEnvironment.Color, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
            Margin="0,0,6,0"
            VerticalAlignment="Center"/>

    <TextBlock DockPanel.Dock="Left"
               Text="ENV"
               Foreground="#888888"
               FontSize="11"
               FontWeight="SemiBold"
               LetterSpacing="1"
               VerticalAlignment="Center"
               Margin="0,0,8,0"/>

    <!-- Back button — shown when any editor is open -->
    <Button DockPanel.Dock="Right"
            Content="← Back to Editor"
            Command="{Binding CloseEditorCommand}"
            IsVisible="{Binding IsAnyEditorOpen}"
            FontSize="11"
            Background="Transparent"
            Foreground="#4ec9b0"
            BorderThickness="0"
            Padding="8,2"
            Margin="8,0,0,0"
            VerticalAlignment="Center"
            ToolTip.Tip="Return to the request editor"/>

    <!-- Manage Environments button — shown when no editor is open -->
    <Button DockPanel.Dock="Right"
            Content="Manage Environments"
            Command="{Binding OpenEditorCommand}"
            IsVisible="{Binding !IsAnyEditorOpen}"
            FontSize="11"
            Background="Transparent"
            Foreground="#4ec9b0"
            BorderThickness="0"
            Padding="8,2"
            Margin="8,0,0,0"
            VerticalAlignment="Center"
            ToolTip.Tip="Open the environment variable editor"/>

    <!-- Environment picker — hidden while any editor is open -->
    <ComboBox ItemsSource="{Binding EnvironmentsWithPlaceholder}"
              SelectedItem="{Binding SelectedDropdownItem, Mode=TwoWay}"
              MinWidth="160"
              FontSize="13"
              VerticalAlignment="Center"
              IsVisible="{Binding !IsAnyEditorOpen}">
      <ComboBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding Name}"/>
        </DataTemplate>
      </ComboBox.ItemTemplate>
    </ComboBox>

  </DockPanel>
</UserControl>

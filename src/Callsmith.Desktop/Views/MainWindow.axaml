<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Callsmith.Desktop.ViewModels"
        xmlns:views="using:Callsmith.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
        x:Class="Callsmith.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/callsmith.ico"
        Title="Callsmith"
        MinWidth="800" MinHeight="500"
        Background="#1e1e1e">

    <!-- Window-level Ctrl+S routes to the environment editor when it is open,
         otherwise falls through to the active request tab. -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenCommandPaletteCommand}"/>
        <KeyBinding Gesture="Ctrl+H" Command="{Binding OpenActiveRequestHistoryCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+H" Command="{Binding OpenGlobalHistoryCommand}"/>
        <KeyBinding Gesture="Alt+R" Command="{Binding RevealActiveRequestCommand}"/>
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding SendCommand}"/>
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Root layout: sidebar | main content -->
    <Grid ColumnDefinitions="280,6,*">

        <!-- ================================================================
             Left sidebar — Collections (only when a collection is open)
             Hidden when any editor panel is open or when no collection is open.
             ================================================================ -->
        <Panel Grid.Column="0" IsVisible="{Binding IsSidebarVisible}">
            <views:CollectionsView DataContext="{Binding Collections}"/>
        </Panel>

        <!-- Splitter — hidden alongside the sidebar and when no collection is open -->
        <GridSplitter Grid.Column="1"
                      ResizeDirection="Columns"
                      Background="#4a4a4a"
                      HorizontalAlignment="Stretch"
                      IsVisible="{Binding IsRightPaneVisible}"/>

        <!-- ================================================================
             Right pane — env toolbar + request/response editor
             Hidden when any editor panel is open, or when no collection is open.
             ================================================================ -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*"
              IsVisible="{Binding IsRightPaneVisible}">

            <!-- Environment selector toolbar + History button -->
            <Border Grid.Row="0"
                    Background="#2d2d30"
                    BorderBrush="#444"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                <Grid ColumnDefinitions="*,Auto">
                    <views:EnvironmentSelectorView Grid.Column="0" DataContext="{Binding Environment}"/>
                    <Button Grid.Column="1"
                            Content="Global History"
                            Command="{Binding OpenHistoryCommand}"
                            Background="Transparent"
                            Foreground="#9cdcfe"
                            BorderThickness="1"
                            BorderBrush="#555"
                            CornerRadius="3"
                            FontSize="11"
                            Padding="10,3"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="View sent request history"/>
                </Grid>
            </Border>

            <!-- Request editor + Response viewer -->
            <views:RequestEditorView Grid.Row="1"
                                     DataContext="{Binding RequestEditor}"/>

        </Grid>

        <!-- ================================================================
             Full-width Collections panel — shown when no collection is open
             Spans all columns so it takes the entire screen.
             Header bar at top with Open/Import, centered helper text below.
             ================================================================ -->
        <Panel Grid.Column="0" Grid.ColumnSpan="3"
               IsVisible="{Binding IsPlaceholderVisible}">
            <DockPanel Background="#252526">
                <!-- Header bar with Open and Import buttons -->
                <Border DockPanel.Dock="Top"
                        Background="#2d2d30"
                        Padding="12,8">
                    <Grid ColumnDefinitions="Auto,*">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="COLLECTIONS"
                                      Foreground="#cccccc"
                                      FontSize="11"
                                      FontWeight="SemiBold"
                                      LetterSpacing="1"
                                      VerticalAlignment="Center"/>

                            <!-- Open button -->
                            <Button Content="Open"
                                    FontSize="11"
                                    Foreground="#4ec9b0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,0"
                                    ToolTip.Tip="Open collection folder (Callsmith, Bruno)"
                                    Command="{Binding Collections.OpenFolderCommand}"
                                    CommandParameter="{Binding $parent[Window].StorageProvider}"/>

                            <!-- Import button -->
                            <Button Content="Import"
                                    FontSize="11"
                                    Foreground="#4ec9b0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4,0"
                                    ToolTip.Tip="Import collection (Postman, Insomnia)"
                                    Command="{Binding Collections.OpenImportDialogCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Centered placeholder content -->
                <StackPanel VerticalAlignment="Center" 
                           HorizontalAlignment="Center"
                           Spacing="24">
                    <TextBlock Text="No Collection Open"
                              Foreground="#cccccc"
                              FontSize="24"
                              FontWeight="SemiBold"
                              TextAlignment="Center"/>
                    <StackPanel Spacing="8">
                        <TextBlock TextAlignment="Center"
                                  Foreground="#999999"
                                  FontSize="13"
                                  Text="Open an empty folder to create a new collection,"/>
                        <TextBlock TextAlignment="Center"
                                  Foreground="#999999"
                                  FontSize="13"
                                  Text="open an existing Callsmith or Bruno collection,"/>
                        <TextBlock TextAlignment="Center"
                                  Foreground="#999999"
                                  FontSize="13"
                                  Text="or import from Postman or Insomnia."/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Panel>

        <!-- ================================================================
             Full-width collection environment editor panel
             Spans all columns so the collection sidebar is not visible.
             ================================================================ -->
           <!-- Full-width collection environment editor panel -->
        <Panel Grid.Column="0" Grid.ColumnSpan="3"
               IsVisible="{Binding Environment.IsEditorOpen}">
            <views:EnvironmentEditorView DataContext="{Binding EnvironmentEditor}"/>
        </Panel>

           <!-- ================================================================
               Full-width history panel
               Spans all columns; shown when HistoryPanel.IsOpen is true.
               ================================================================ -->
           <Panel Grid.Column="0" Grid.ColumnSpan="3"
                IsVisible="{Binding HistoryPanel.IsOpen}">
              <views:HistoryPanelView DataContext="{Binding HistoryPanel}"/>
           </Panel>

        <!-- ================================================================
             Command palette overlay — floats over all content, manages its
             own IsVisible state. ZIndex puts it on top of everything else.
             ================================================================ -->
        <views:CommandPaletteView Grid.Column="0" Grid.ColumnSpan="3"
                                  ZIndex="100"
                                  DataContext="{Binding CommandPalette}"/>

    </Grid>

</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Callsmith.Desktop.ViewModels"
        xmlns:views="using:Callsmith.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
        x:Class="Callsmith.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Callsmith"
        MinWidth="800" MinHeight="500"
        Background="#1e1e1e">

    <!-- Window-level Ctrl+S so saving works even when focus is in the sidebar
         or any other element outside RequestView / RequestEditorView. -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding RequestEditor.ActiveTab.SaveCommand}"/>
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Root layout: sidebar | main content -->
    <Grid ColumnDefinitions="280,6,*">

        <!-- ================================================================
             Left sidebar — Collections
             ================================================================ -->
        <views:CollectionsView Grid.Column="0"
                               DataContext="{Binding Collections}"/>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      ResizeDirection="Columns"
                      Background="#4a4a4a"
                      HorizontalAlignment="Stretch"/>

        <!-- ================================================================
             Right pane — thin env toolbar + request/response editor
             ================================================================ -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*">

            <!-- Environment selector toolbar -->
            <Border Grid.Row="0"
                    Background="#2d2d30"
                    BorderBrush="#444"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                <views:EnvironmentSelectorView DataContext="{Binding Environment}"/>
            </Border>

            <!-- Request editor + Response viewer -->
            <views:RequestEditorView Grid.Row="1"
                                     DataContext="{Binding RequestEditor}"/>

        </Grid>

    </Grid>

</Window>

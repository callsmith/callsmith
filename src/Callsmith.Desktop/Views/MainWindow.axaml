<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Callsmith.Desktop.ViewModels"
        xmlns:views="using:Callsmith.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
        x:Class="Callsmith.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/callsmith.ico"
        Title="Callsmith"
        MinWidth="800" MinHeight="500"
        Background="#1e1e1e">

    <!-- Window-level Ctrl+S routes to the environment editor when it is open,
         otherwise falls through to the active request tab. -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding OpenCommandPaletteCommand}"/>
        <KeyBinding Gesture="Alt+R" Command="{Binding RevealActiveRequestCommand}"/>
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Root layout: sidebar | main content -->
    <Grid ColumnDefinitions="280,6,*">

        <!-- ================================================================
             Left sidebar — Collections
             Hidden when any editor panel is open.
             ================================================================ -->
        <Panel Grid.Column="0" IsVisible="{Binding !Environment.IsAnyEditorOpen}">
            <views:CollectionsView DataContext="{Binding Collections}"/>
        </Panel>

        <!-- Splitter — hidden alongside the sidebar -->
        <GridSplitter Grid.Column="1"
                      ResizeDirection="Columns"
                      Background="#4a4a4a"
                      HorizontalAlignment="Stretch"
                      IsVisible="{Binding !Environment.IsAnyEditorOpen}"/>

        <!-- ================================================================
             Right pane — env toolbar + request/response editor
             Hidden when any editor panel is open.
             ================================================================ -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*"
              IsVisible="{Binding !Environment.IsAnyEditorOpen}">

            <!-- Environment selector toolbar -->
            <Border Grid.Row="0"
                    Background="#2d2d30"
                    BorderBrush="#444"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                <views:EnvironmentSelectorView DataContext="{Binding Environment}"/>
            </Border>

            <!-- Request editor + Response viewer -->
            <views:RequestEditorView Grid.Row="1"
                                     DataContext="{Binding RequestEditor}"/>

        </Grid>

        <!-- ================================================================
             Full-width collection environment editor panel
             Spans all columns so the collection sidebar is not visible.
             ================================================================ -->
        <!-- Full-width collection environment editor panel -->
        <Panel Grid.Column="0" Grid.ColumnSpan="3"
               IsVisible="{Binding Environment.IsEditorOpen}">
            <views:EnvironmentEditorView DataContext="{Binding EnvironmentEditor}"/>
        </Panel>

        <!-- ================================================================
             Command palette overlay — floats over all content, manages its
             own IsVisible state. ZIndex puts it on top of everything else.
             ================================================================ -->
        <views:CommandPaletteView Grid.Column="0" Grid.ColumnSpan="3"
                                  ZIndex="100"
                                  DataContext="{Binding CommandPalette}"/>

    </Grid>

</Window>

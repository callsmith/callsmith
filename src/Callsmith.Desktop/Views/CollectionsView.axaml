<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:views="using:Callsmith.Desktop.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="750"
             x:Class="Callsmith.Desktop.Views.CollectionsView"
             x:DataType="vm:CollectionsViewModel"
             Background="#252526">

  <UserControl.Styles>

    <!-- Tree item padding -->
    <Style Selector="TreeViewItem">
      <Setter Property="Padding" Value="4,2"/>
    </Style>
    <!-- Two-way IsExpanded sync — keeps CollectionTreeItemViewModel.IsExpanded in
         step with the TreeViewItem UI control so expansion state can be persisted. -->
    <Style Selector="TreeViewItem" x:DataType="vm:CollectionTreeItemViewModel">
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
    </Style>

    <!-- Tree node label: default appearance -->
    <Style Selector="TextBlock.tree-icon">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.tree-label">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Active request node: brighter text -->
    <Style Selector="TextBlock.tree-icon.active-item">
      <Setter Property="Foreground" Value="#4ec9b0"/>
    </Style>
    <Style Selector="TextBlock.tree-label.active-item">
      <Setter Property="Foreground" Value="#ffffff"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Active request node: highlight background with left accent bar -->
    <Style Selector="Border.active-row">
      <Setter Property="Background" Value="#1a3a30"/>
    </Style>
    <Style Selector="Border.active-accent">
      <Setter Property="Background" Value="#4ec9b0"/>
    </Style>

    <!-- Suppress selection highlight: no blue background when an item is clicked -->
    <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TreeViewItem:selected:focus /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TreeViewItem:selected:pointerover /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#2a2d2e"/>
    </Style>
    <Style Selector="TreeViewItem:selected:focus:pointerover /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="#2a2d2e"/>
    </Style>

    <!-- Drop target highlighting -->
    <Style Selector="Border.drop-target">
      <Setter Property="Background" Value="#2a4a40"/>
    </Style>

  </UserControl.Styles>

  <!-- Sidebar layout: header toolbar + tree + path footer -->
  <Grid>
    <DockPanel>

    <!-- ── Header ── -->
    <Border DockPanel.Dock="Top"
            Background="#2d2d30"
            Padding="12,8">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

          <!-- COLLECTIONS label doubles as the recent-collections toggle -->
          <Button IsVisible="{Binding HasRecentCollections}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  ToolTip.Tip="Show recent collections"
                  Command="{Binding ToggleRecentPanelCommand}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="COLLECTIONS"
                         Foreground="#cccccc"
                         FontSize="11"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         VerticalAlignment="Center"/>
              <TextBlock Text="▴" VerticalAlignment="Center" IsVisible="{Binding IsRecentPanelOpen}"
                         Foreground="#cccccc" FontSize="13" Margin="0,1,0,0"/>
              <TextBlock Text="▾" VerticalAlignment="Center" IsVisible="{Binding !IsRecentPanelOpen}"
                         Foreground="#cccccc" FontSize="13" Margin="0,1,0,0"/>
            </StackPanel>
          </Button>
          <!-- Static label when there are no recent collections yet -->
          <TextBlock IsVisible="{Binding !HasRecentCollections}"
                     Text="COLLECTIONS"
                     Foreground="#cccccc"
                     FontSize="11"
                     FontWeight="SemiBold"
                     LetterSpacing="1"
                     VerticalAlignment="Center"/>

          <!-- Open button -->
          <Button Content="Open"
                  FontSize="11"
                  Foreground="#4ec9b0"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="6,0"
                  ToolTip.Tip="Open collection folder (Callsmith, Bruno)"
                  Command="{Binding OpenFolderCommand}"
                  CommandParameter="{Binding $parent[Window].StorageProvider}"/>

          <!-- Import button -->
          <Button Content="Import"
                  FontSize="11"
                  Foreground="#4ec9b0"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4,0"
                  ToolTip.Tip="Import collection (Postman, Insomnia)"
                  Command="{Binding ImportCollectionCommand}"
                  CommandParameter="{Binding $parent[Window].StorageProvider}"/>
        </StackPanel>

        <!-- Bruno compatibility mode indicator -->
        <Image Grid.Column="2"
               Width="20"
               Height="20"
               VerticalAlignment="Center"
               IsVisible="{Binding IsBrunoCollection}"
               Source="/Assets/bruno.png"
               ToolTip.Tip="Using a Bruno Collection"/>
      </Grid>
    </Border>

    <!-- ── Recent collections panel (collapsible dropdown) ── -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsRecentPanelOpen}"
            Background="#1e1e1e"
            BorderBrush="#444"
            BorderThickness="0,0,0,1"
            ZIndex="10">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="RECENT COLLECTIONS"
                   Foreground="#606060"
                   FontSize="10"
                   FontWeight="SemiBold"
                   LetterSpacing="1"
                   Margin="12,8,12,4"/>
        <ScrollViewer MaxHeight="220"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding RecentCollections}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Command="{Binding $parent[UserControl].((vm:CollectionsViewModel)DataContext).OpenRecentCommand}"
                        CommandParameter="{Binding .}"
                        Background="Transparent"
                        Foreground="#cccccc"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="12,5"
                        ToolTip.Tip="{Binding .}">
                  <StackPanel Spacing="1">
                    <TextBlock Text="{Binding ., Converter={x:Static conv:PathToCollectionNameConverter.Instance}}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding .}"
                               FontSize="10"
                               Foreground="#666"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ── Collection path label ── -->
    <TextBlock DockPanel.Dock="Bottom"
               IsVisible="{Binding HasCollection}"
               Text="{Binding CollectionPath}"
               Foreground="#888"
               FontSize="10"
               TextTrimming="CharacterEllipsis"
               Padding="10,4"
               ToolTip.Tip="{Binding CollectionPath}"/>

    <!-- ── Empty state with recent collections ── -->
    <ScrollViewer IsVisible="{Binding !HasCollection}"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="8"
                  Margin="16">
        <TextBlock Text="No collection open"
                   Foreground="#888"
                   FontSize="13"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Click Import or Open"
                   Foreground="#999"
                   FontSize="11"
                   HorizontalAlignment="Center"/>

        <!-- Recent collections -->
        <StackPanel IsVisible="{Binding HasRecentCollections}"
                    Spacing="2"
                    Margin="0,12,0,0">
          <TextBlock Text="RECENT"
                     Foreground="#606060"
                     FontSize="10"
                     FontWeight="SemiBold"
                     LetterSpacing="1"
                     Margin="0,0,0,4"/>
          <!-- Items bound via code-behind button list -->
          <ItemsControl ItemsSource="{Binding RecentCollections}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Content="{Binding .}"
                        Command="{Binding $parent[UserControl].((vm:CollectionsViewModel)DataContext).OpenRecentCommand}"
                        CommandParameter="{Binding .}"
                        Background="Transparent"
                        Foreground="#4ec9b0"
                        BorderThickness="0"
                        Padding="4,3"
                        HorizontalAlignment="Left"
                        FontSize="11"
                        TextBlock.TextTrimming="CharacterEllipsis"
                        MaxWidth="240"
                        ToolTip.Tip="{Binding .}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

        <!-- ── Tree view ── -->
        <Grid IsVisible="{Binding HasCollection}"
          Margin="0,4,0,0">
        <TreeView x:Name="CollectionTree"
          ItemsSource="{Binding TreeRoots}"
          Background="Transparent">
      <TreeView.ItemTemplate>
        <TreeDataTemplate ItemsSource="{Binding Children}"
                          x:DataType="vm:CollectionTreeItemViewModel">

          <!-- Panel wrapper allows the flat DropIndicator to overlay without
               inheriting ItemBorder's CornerRadius. -->
          <Panel>

          <Border x:Name="ItemBorder"
                  Classes.active-row="{Binding IsActive}"
                  CornerRadius="3"
                  Padding="0,1"
                  Margin="-4,-1,-2,-1">
            <Grid ColumnDefinitions="3,6,Auto,*">
              <!-- Left accent bar, only visible when active -->
              <Border Grid.Column="0"
                      Classes.active-accent="{Binding IsActive}"
                      CornerRadius="2,0,0,2"
                      IsVisible="{Binding IsActive}"/>
              <!-- Fixed-width slot for the pill keeps request names aligned regardless of verb length -->
              <Border Grid.Column="2"
                      Width="42"
                      IsVisible="{Binding !IsFolder}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Left">
                <Border Background="{Binding MethodName, Converter={x:Static conv:HttpMethodToBrushConverter.Instance}}"
                        CornerRadius="3"
                        Padding="5,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                  <TextBlock Text="{Binding MethodPillLabel}"
                             Foreground="#1a1a1a"
                             FontSize="9"
                             FontWeight="Bold"
                             VerticalAlignment="Center"/>
                </Border>
              </Border>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                          IsVisible="{Binding IsFolder}">
              </StackPanel>
              <TextBlock Grid.Column="3"
                         Classes="tree-label"
                         Classes.active-item="{Binding IsActive}"
                         Text="{Binding Name}"
                         VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <!-- Flat 2 px insertion indicator. CornerRadius stays 0 regardless of
               ItemBorder's rounding. Shown/hidden and positioned in code-behind. -->
          <Border x:Name="DropIndicator"
                  IsVisible="False"
                  Height="2"
                  Background="#4ec9b0"
                  VerticalAlignment="Top"
                  Margin="-4,0,-2,0"
                  IsHitTestVisible="False"/>

          </Panel>

        </TreeDataTemplate>
      </TreeView.ItemTemplate>

      <!-- Context menu bound in code-behind to avoid AXAML binding complexity -->
      <TreeView.ContextMenu>
        <ContextMenu x:Name="TreeContextMenu"/>
      </TreeView.ContextMenu>

        </TreeView>

        <!-- Bottom insertion indicator for dropping after the last visible item. -->
        <Border x:Name="TreeBottomDropIndicator"
          IsVisible="False"
          Height="2"
          Background="#4ec9b0"
          VerticalAlignment="Top"
          Margin="-4,0,-2,0"
          IsHitTestVisible="False"/>
        </Grid>

    </DockPanel>

    <!-- ── Rename / Create-Folder dialog overlay ── -->
    <Border IsVisible="{Binding IsRenameDialogOpen}"
            Background="#66000000">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="280"
              Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="14,12"
              BoxShadow="0 4 20 0 #CC000000">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding RenameDialogTitle}"
                     Foreground="#d4d4d4"
                     FontSize="13"
                     FontWeight="SemiBold"/>
          <TextBox IsVisible="{Binding IsRenameDialogOpen}"
                   Text="{Binding RenameDialogValue}"
                   Background="#3c3c3c"
                   Foreground="#d4d4d4"
                   BorderBrush="#555"
                   Padding="8,5"
                   FontSize="12"
                   views:FocusHelper.FocusOnVisible="True">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding CommitRenameDialogCommand}"/>
              <KeyBinding Gesture="Escape" Command="{Binding CancelRenameDialogCommand}"/>
            </TextBox.KeyBindings>
          </TextBox>
          <TextBlock Text="{Binding RenameDialogError}"
                     IsVisible="{Binding RenameDialogError, Converter={x:Static conv:StringNotEmptyConverter.Instance}}"
                     Foreground="#f48771"
                     FontSize="11"/>
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="6">
            <Button Content="{Binding RenameDialogConfirmLabel}"
                    Command="{Binding CommitRenameDialogCommand}"
                    Background="#1e7340"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
            <Button Content="Cancel"
                    Command="{Binding CancelRenameDialogCommand}"
                    Background="#3a3a3a"
                    Foreground="#ccc"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- ── Delete confirmation popup ── -->
    <Border IsVisible="{Binding PendingDeleteNode, Converter={x:Static conv:NotNullConverter.Instance}}"
            Background="#66000000">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="230"
              Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="14,12"
              BoxShadow="0 4 20 0 #CC000000">
        <StackPanel Spacing="10">
          <TextBlock Foreground="#f0c060"
                     FontSize="13"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     Text="{Binding PendingDeleteNode.Name, StringFormat='Delete &quot;{0}&quot;?', FallbackValue=''}"/>
          <TextBlock Foreground="#999"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Text="This cannot be undone."/>
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="6">
            <Button Content="Cancel"
                    Command="{Binding CancelDeleteCommand}"
                    Background="#3a3a3a"
                    Foreground="#ccc"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
            <Button Content="Delete"
                    Command="{Binding ConfirmDeleteCommand}"
                    Background="#922"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    CornerRadius="3"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

  </Grid>

</UserControl>

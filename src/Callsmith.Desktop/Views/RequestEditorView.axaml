<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:views="using:Callsmith.Desktop.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="750"
             x:Class="Callsmith.Desktop.Views.RequestEditorView"
             x:DataType="vm:RequestEditorViewModel"
             Background="#1e1e1e">

  <!-- Ctrl+S here catches the case where focus leaves RequestView (e.g. after
       deleting a key-value row whose button was removed from the visual tree). -->
  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding ActiveTab.SaveCommand}"/>
  </UserControl.KeyBindings>

  <UserControl.Styles>

    <!-- Tab chip — the clickable item in the tab strip -->
    <Style Selector="Border.tab-chip">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0,0,1,0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.tab-chip.active">
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#0078d4" Offset="0.0"/>
            <GradientStop Color="#0078d4" Offset="0.08"/>
            <GradientStop Color="#1e1e1e" Offset="0.08"/>
            <GradientStop Color="#1e1e1e" Offset="1.0"/>
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="BorderBrush" Value="#444"/>
    </Style>
    <Style Selector="Border.tab-chip.active TextBlock.tab-title">
      <Setter Property="Foreground" Value="#ffffff"/>
    </Style>
    <Style Selector="Border.tab-chip:pointerover">
      <Setter Property="Background" Value="#2a2a2a"/>
    </Style>
    <Style Selector="Border.tab-chip.active:pointerover">
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#0078d4" Offset="0.0"/>
            <GradientStop Color="#0078d4" Offset="0.08"/>
            <GradientStop Color="#252525" Offset="0.08"/>
            <GradientStop Color="#252525" Offset="1.0"/>
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Method chip inside each tab -->
    <Style Selector="Border.method-chip">
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Padding" Value="4,1"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Close × button on each tab -->
    <Style Selector="Button.tab-close">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#666"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="2,0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Width" Value="18"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.tab-close:pointerover">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="Background" Value="#3a3a3a"/>
    </Style>

  </UserControl.Styles>

  <DockPanel>

    <!-- ================================================================
         TAB STRIP
         ================================================================ -->
    <Border DockPanel.Dock="Top"
            Background="#2d2d30"
            BorderBrush="#444"
            BorderThickness="0,0,0,1"
            Height="36">
      <!-- Scrollable tab list with + button immediately after tabs -->
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <ItemsControl x:Name="TabStrip"
                        ItemsSource="{Binding Tabs}"
                        VerticalAlignment="Stretch">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:RequestTabViewModel">

                <!-- Individual tab chip -->
                <Border x:Name="TabChip"
                        Classes="tab-chip"
                        Classes.active="{Binding IsActive}"
                        BorderBrush="#333"
                        BorderThickness="0,0,1,0"
                        MinWidth="140"
                        MaxWidth="220"
                        VerticalAlignment="Stretch"
                        Padding="10,0,6,0">          

                  <DockPanel VerticalAlignment="Center">

                    <!-- Close × button -->
                    <Button DockPanel.Dock="Right"
                            Classes="tab-close"
                            Content="×"
                            Command="{Binding CloseCommand}"
                            ToolTip.Tip="Close tab"/>

                    <!-- Dirty dot -->
                    <TextBlock DockPanel.Dock="Right"
                               Text="●"
                               Foreground="#f48771"
                               FontSize="8"
                               VerticalAlignment="Center"
                               Margin="4,0,2,0"
                               IsVisible="{Binding TabIsDirty}"
                               ToolTip.Tip="Unsaved changes"/>

                    <DockPanel VerticalAlignment="Center" LastChildFill="True">
                      <!-- Method badge -->
                      <Border DockPanel.Dock="Left"
                              Classes="method-chip"
                              Background="{Binding MethodColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}">
                        <TextBlock Text="{Binding MethodPillLabel}"
                                   Foreground="White"
                                   FontSize="9"
                                   FontWeight="Bold"/>
                      </Border>

                      <!-- Request name — fills remaining space and truncates with ellipsis -->
                      <TextBlock Classes="tab-title"
                                 Text="{Binding TabTitle}"
                                 Foreground="#cccccc"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 Margin="6,0,0,0"
                                 TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                  </DockPanel>
                </Border>

              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- + New Tab button sits immediately after the last tab -->
          <Button Content="+"
                  Command="{Binding NewTabCommand}"
                  Background="Transparent"
                  Foreground="#888"
                  BorderThickness="0"
                  Padding="14,0"
                  FontSize="18"
                  FontWeight="Light"
                  VerticalAlignment="Center"
                  ToolTip.Tip="New tab (blank request)"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ================================================================
         EMPTY STATE / ACTIVE TAB CONTENT — share the remaining fill area
         ================================================================ -->
    <Grid>
      <StackPanel IsVisible="{Binding !HasTabs}"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="8">
        <TextBlock Text="No request open"
                   Foreground="#555"
                   FontSize="14"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Click + or select a request from the sidebar"
                   Foreground="#444"
                   FontSize="11"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- ================================================================
           ACTIVE TAB CONTENT
           ================================================================ -->
      <Panel IsVisible="{Binding HasTabs}">
        <views:RequestView DataContext="{Binding ActiveTab}"/>
      </Panel>
    </Grid>

  </DockPanel>

</UserControl>

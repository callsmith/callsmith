<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             xmlns:views="using:Callsmith.Desktop.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="750"
             x:Class="Callsmith.Desktop.Views.RequestView"
             x:DataType="vm:RequestTabViewModel"
             Background="#1e1e1e">

  <UserControl.Styles>
    <Style Selector="TabControl.request-tabs TabItem">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="18,6"/>
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="TabControl.response-tabs TabItem">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="MinHeight" Value="28"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </UserControl.Styles>

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
  </UserControl.KeyBindings>

  <DockPanel>

    <!-- ================================================================
         FIXED TOP: URL bar + Preview bar (always full-width)
         ================================================================ -->
    <Border DockPanel.Dock="Top" Background="#252526" Padding="12,10">
      <Grid RowDefinitions="Auto,Auto">

        <!-- Row 0: Method + URL + Send/Cancel + Save + Revert -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,8,*,8,Auto,Auto,Auto">
          <ComboBox Grid.Column="0"
                    ItemsSource="{Binding HttpMethods}"
                    SelectedItem="{Binding SelectedMethod}"
                    MinWidth="120"
                    Foreground="{Binding MethodColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                    FontWeight="SemiBold" FontSize="13">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding .}"
                           Foreground="{Binding ., Converter={x:Static conv:HttpMethodToBrushConverter.Instance}}"
                           FontWeight="SemiBold"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBox x:Name="UrlTextBox" Grid.Column="2"
                   Text="{Binding Url}"
                   Watermark="https://api.example.com/endpoint or paste a cURL command"
                   FontSize="13" Foreground="#d4d4d4" Background="#3c3c3c"
                   BorderBrush="#555" Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                   controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
          <!-- Send (with cURL dropdown) / Cancel -->
          <Grid Grid.Column="4" ColumnDefinitions="*,1,Auto">
            <!-- Primary Send button -->
            <Button Grid.Column="0"
                    IsVisible="{Binding !IsSending}"
                    Content="Send" Command="{Binding SendCommand}"
                    Background="#0e639c" Foreground="White" FontWeight="SemiBold"
                    FontSize="14" Padding="28,6" CornerRadius="4,0,0,4"
                  BorderThickness="0" VerticalAlignment="Stretch"
                  ToolTip.Tip="Send Current Request (Ctrl+Enter)"/>
            <!-- Divider between Send and dropdown arrow -->
            <Rectangle Grid.Column="1"
                       IsVisible="{Binding !IsSending}"
                       Fill="#0a4f7a" Width="1"
                       VerticalAlignment="Stretch"/>
            <!-- Dropdown arrow — opens flyout with extra actions -->
            <Button Grid.Column="2"
                    IsVisible="{Binding !IsSending}"
                    Background="#0e639c" Foreground="White" BorderThickness="0"
                    Padding="12,6" CornerRadius="0,4,4,0"
                    VerticalAlignment="Stretch"
                    ToolTip.Tip="More options">
              <Button.Content>
                <TextBlock Text="&#x25BE;" FontSize="13" VerticalAlignment="Center"/>
              </Button.Content>
              <Button.Flyout>
                <MenuFlyout x:CompileBindings="False">
                  <MenuItem Header="View as cURL…" Command="{Binding ViewCurlCommand}"/>
                </MenuFlyout>
              </Button.Flyout>
            </Button>
            <!-- Cancel — spans all columns while request is in-flight -->
            <Button Grid.Column="0" Grid.ColumnSpan="3"
                    IsVisible="{Binding IsSending}"
                    Content="Cancel" Command="{Binding SendCancelCommand}"
                    Background="#6c2020" Foreground="White" FontWeight="SemiBold"
                    FontSize="14" Padding="28,6" CornerRadius="4"
                    BorderThickness="0" VerticalAlignment="Stretch"/>
          </Grid>
          <!-- Save button — visible whenever the tab has unsaved changes -->
          <Button Grid.Column="5"
                  Content="{Binding SaveButtonLabel}"
                  Command="{Binding SaveCommand}"
                  IsVisible="{Binding TabIsDirty}"
                  Background="#1e7340" Foreground="White" FontWeight="SemiBold"
                  Padding="16,6" CornerRadius="4"
                  Margin="8,0,0,0"
                  ToolTip.Tip="Save changes (Ctrl+S)"/>
          <!-- Revert button — visible for existing requests with unsaved changes -->
          <Button Grid.Column="6"
                  Content="Revert"
                  Command="{Binding RevertCommand}"
                  IsVisible="{Binding ShowRevertButton}"
                  Background="#5a3e1b" Foreground="White" FontWeight="SemiBold"
                  Padding="16,6" CornerRadius="4"
                  Margin="4,0,0,0"
                  ToolTip.Tip="Discard unsaved changes and revert to last saved state"/>

        </Grid>

        <!-- Row 1: Preview URL bar + layout toggle (toggle is outside the dark border) -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
          <!-- Dark preview area -->
          <Border Grid.Column="0"
                  Background="#1e1e1e" BorderBrush="#3a3a3a" BorderThickness="0,1,0,0"
                  Padding="0,5,0,5">
          <Grid ColumnDefinitions="Auto,*,Auto">
              <TextBlock Grid.Column="0"
                         Text="PREVIEW" Foreground="#5a5a5a" FontSize="10" FontWeight="SemiBold"
                         VerticalAlignment="Center" Margin="8,0,8,0"/>
              <Panel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="PreviewUrlText"
                           Text="{Binding PreviewUrl}"
                           Foreground="{Binding PreviewUrlForeground, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                           FontFamily="Consolas,Menlo,monospace" FontSize="12"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding PreviewUrlTooltip}"/>
              </Panel>
              <Button Grid.Column="2"
                      x:Name="CopyPreviewUrlButton"
                      Content="&#x2398;" ToolTip.Tip="Copy URL to clipboard"
                      Background="Transparent" Foreground="#888" BorderThickness="0"
                      Padding="6,2" FontSize="14" Margin="6,0,6,0"/>
            </Grid>
          </Border>
          <!-- Layout toggle — outside the dark preview box, on the lighter outer background -->
          <Button Grid.Column="1"
                  x:Name="ToggleLayoutButton"
                  Command="{Binding ToggleLayoutCommand}"
                  Background="Transparent" Foreground="#888" BorderThickness="0"
                  Padding="6,4" Margin="6,0,0,0" VerticalAlignment="Center"
                  ToolTip.Tip="Toggle layout (horizontal / vertical)">
            <Grid>
              <!-- Stacked-panes icon: shown in vertical mode → click to switch to horizontal -->
              <PathIcon Width="14" Height="14" Foreground="#888"
                        IsVisible="{Binding IsHorizontalLayout, Converter={x:Static BoolConverters.Not}}"
                        Data="M2,3 L10,3 L10,21 L2,21 Z M14,3 L22,3 L22,21 L14,21 Z"/>
              <!-- Side-by-side icon: shown in horizontal mode → click to switch to vertical -->
              <PathIcon Width="14" Height="14" Foreground="#888"
                        IsVisible="{Binding IsHorizontalLayout}"
                        Data="M2,3 L22,3 L22,10 L2,10 Z M2,14 L22,14 L22,21 L2,21 Z"/>
            </Grid>
          </Button>
        </Grid>

      </Grid>
    </Border>

    <!-- ================================================================
         MAIN CONTENT AREA: request config + splitter + response
         Rearranged by code-behind based on IsHorizontalLayout.
         Default (horizontal): ColumnDefinitions="0.45*,6,0.55*"
         ================================================================ -->
    <Grid x:Name="ContentGrid" ColumnDefinitions="0.45*,6,0.55*">

      <!-- Request config section (Panel allows close-guard overlay) -->
      <Panel x:Name="RequestConfigPanel" Grid.Column="0">
        <Border Background="#252526" Padding="12,6,12,12">
          <Grid RowDefinitions="*,Auto">

            <!-- Row 0: Params & Headers | Body | Auth -->
            <TabControl Grid.Row="0" Classes="request-tabs" Margin="0" Background="Transparent">

          <TabItem>
            <TabItem.Header>
              <!-- Panel measures only the TextBlock, so the active underline spans only
                   the label. The dot sits in a zero-size Canvas that floats to the right
                   without affecting the measured (and therefore underlined) width. -->
              <Panel>
                <TextBlock Text="Headers &amp; Params"/>
                <Canvas Width="0" Height="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <Ellipse Canvas.Left="4" Canvas.Top="-3.5"
                           Width="7" Height="7"
                           Fill="#4ec9b0"
                           Opacity="{Binding IsHeadersAndParamsModified, Converter={x:Static conv:BoolToOpacityConverter.Instance}}"/>
                </Canvas>
              </Panel>
            </TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          AllowAutoHide="False"
                          Padding="0,0,12,0">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="0,4">
                <!-- Headers -->
                <TextBlock Grid.Row="0" Text="HEADERS" Foreground="#888" FontWeight="Bold" FontSize="10"
                           LetterSpacing="1" Margin="0,1,0,4" VerticalAlignment="Bottom"/>
                <views:KeyValueEditorView Grid.Row="1" DataContext="{Binding Headers}" Margin="0,4"/>

                <!-- Separator -->
                <Separator Grid.Row="2" Margin="0,8" />

                <!-- Path Params -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                  <TextBlock Text="PATH PARAMS" Foreground="#888" FontWeight="Bold" FontSize="10"
                             LetterSpacing="1" VerticalAlignment="Bottom"/>
                  <TextBlock Text="{Binding PathParamHintText}" Foreground="#9a9a9a"
                             FontSize="11" FontStyle="Italic" VerticalAlignment="Bottom"/>
                </StackPanel>
                <Border Grid.Row="4"
                        IsVisible="{Binding HasUnresolvedPathParams}"
                        Background="#2d1e00" BorderBrush="#7a5010" BorderThickness="1"
                        CornerRadius="3" Padding="8,5" Margin="30,6,30,6">
                  <TextBlock Text="&#x26A0;  One or more path params have no value."
                            Foreground="#c07a20" FontSize="11" TextWrapping="Wrap"/>
                </Border>
                <views:KeyValueEditorView Grid.Row="5" DataContext="{Binding PathParams}" Margin="0,0,0,10"/>

                <!-- Separator -->
                <Separator Grid.Row="6" Margin="0,8" />

                <!-- Query Params -->
                <TextBlock Grid.Row="7" Text="QUERY PARAMS" Foreground="#888" FontWeight="Bold" FontSize="10"
                           LetterSpacing="1" Margin="0,1,0,4" VerticalAlignment="Bottom" />
                <views:KeyValueEditorView Grid.Row="8" DataContext="{Binding QueryParams}"/>
              </Grid>
            </ScrollViewer>
          </TabItem>

          <TabItem>
            <TabItem.Header>
              <Panel>
                <TextBlock Text="Body"/>
                <Canvas Width="0" Height="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <Ellipse Canvas.Left="4" Canvas.Top="-3.5"
                           Width="7" Height="7"
                           Fill="#4ec9b0"
                           Opacity="{Binding IsBodyModified, Converter={x:Static conv:BoolToOpacityConverter.Instance}}"/>
                </Canvas>
              </Panel>
            </TabItem.Header>
            <Grid RowDefinitions="Auto,*" Margin="0,8">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <ComboBox ItemsSource="{Binding BodyTypes}"
                          SelectedItem="{Binding SelectedBodyTypeOption, Mode=OneWay}"
                          SelectionChanged="OnBodyTypeSelectionChanged"
                          MinWidth="160" Foreground="#d4d4d4" Background="#3c3c3c"
                          BorderBrush="#555">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:BodyTypeOption">
                      <Panel>
                        <!-- Separator row -->
                        <Separator IsVisible="{Binding IsSeparator}" Margin="0,2"/>
                        <!-- Normal item -->
                        <TextBlock Text="{Binding DisplayName}"
                                   IsVisible="{Binding !IsSeparator}"
                                   Foreground="#d4d4d4"/>
                      </Panel>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                  <ComboBox.Styles>
                    <Style Selector="ComboBoxItem" x:DataType="vm:BodyTypeOption">
                      <Setter Property="IsEnabled" Value="{Binding !IsSeparator}"/>
                      <Setter Property="IsHitTestVisible" Value="{Binding !IsSeparator}"/>
                    </Style>
                  </ComboBox.Styles>
                </ComboBox>
                <Button Content="Format" Command="{Binding FormatBodyCommand}"
                        IsVisible="{Binding CanFormatBody}"
                        Background="Transparent" Foreground="#4ec9b0" BorderThickness="0"
                  Padding="0" FontSize="12"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Pretty-print the body"/>
              </StackPanel>
              <controls:SyntaxEditor x:Name="BodyEditor" Grid.Row="1"
                       Text="{Binding Body}" Language="{Binding BodyLanguage}"
                       controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"
                       IsVisible="{Binding ShowTextBodyEditor}"/>
              <Panel Grid.Row="1" IsVisible="{Binding ShowUrlEncodedFormBodyEditor}">
                <views:KeyValueEditorView DataContext="{Binding FormParams}"/>
              </Panel>
              <Panel Grid.Row="1" IsVisible="{Binding ShowMultipartBodyEditor}">
                <views:KeyValueEditorView DataContext="{Binding MultipartFormParams}"/>
              </Panel>
              <!-- File body picker -->
              <StackPanel Grid.Row="1" IsVisible="{Binding ShowFileBodyEditor}"
                          VerticalAlignment="Top" Spacing="12" Margin="0,8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button Content="Choose File…"
                          Command="{Binding SelectFileCommand}"
                          Background="#3c3c3c" Foreground="#d4d4d4"
                          BorderBrush="#555" BorderThickness="1"
                          Padding="12,6" CornerRadius="4"/>
                  <TextBlock Text="{Binding SelectedFilePath}"
                             Foreground="#888" FontFamily="Consolas,Menlo,monospace"
                             FontSize="12" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             IsVisible="{Binding HasFileBodySelected}"/>
                  <TextBlock Text="No file selected"
                             Foreground="#666" FontSize="12" VerticalAlignment="Center"
                             IsVisible="{Binding !HasFileBodySelected}"/>
                </StackPanel>
                <TextBlock Text="The file will be sent as application/octet-stream."
                           Foreground="#666" FontSize="11"/>
              </StackPanel>
              <TextBlock Grid.Row="1" IsVisible="{Binding !ShowBodyEditor}"
                         Text="No body" Foreground="#888" FontSize="12"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </TabItem>

          <TabItem>
            <TabItem.Header>
              <Panel>
                <TextBlock Text="Auth"/>
                <Canvas Width="0" Height="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <Ellipse Canvas.Left="4" Canvas.Top="-3.5"
                           Width="7" Height="7"
                           Fill="#4ec9b0"
                           Opacity="{Binding IsAuthModified, Converter={x:Static conv:BoolToOpacityConverter.Instance}}"/>
                </Canvas>
              </Panel>
            </TabItem.Header>
            <ScrollViewer Margin="0,8" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="8">
                <ComboBox ItemsSource="{Binding AuthTypes}" SelectedItem="{Binding AuthType}"
                          MinWidth="160" Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"/>
                <!-- Inherit message — shown when auth is inherited from the parent folder -->
                <TextBlock IsVisible="{Binding IsAuthInherit}"
                           TextWrapping="Wrap"
                           Text="Auth will be inherited from the parent folder. Set a scheme on the folder to apply credentials to all requests within it."
                           Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
                <StackPanel IsVisible="{Binding IsAuthBearer}" Spacing="6">
                  <TextBlock Text="Token" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthToken}"
                           Watermark="Enter bearer token..."
                           Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                           Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                           controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
                </StackPanel>
                <StackPanel IsVisible="{Binding IsAuthBasic}" Spacing="6">
                  <TextBlock Text="Username" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthUsername}" Watermark="username"
                           Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                           Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                           controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>

                  <TextBlock Text="Password" Foreground="#888" FontSize="11"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding AuthPassword}" Watermark="password"
                             Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                             Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                             PasswordChar="●"
                             IsVisible="{Binding ShowAuthPassword, Converter={x:Static BoolConverters.Not}}"
                             controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
                    <TextBox Grid.Column="0" Text="{Binding AuthPassword}" Watermark="password"
                             Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                             Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                             IsVisible="{Binding ShowAuthPassword}"
                             controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
                    <ToggleButton Grid.Column="1" IsChecked="{Binding ShowAuthPassword}"
                                  Background="Transparent" BorderThickness="0"
                                  Margin="6,0,0,0"
                                  Padding="6,4" Cursor="Hand" VerticalAlignment="Center"
                                  ToolTip.Tip="Show/hide password">
                      <Grid>
                        <PathIcon Width="16" Height="16" Foreground="#888"
                                  IsVisible="{Binding ShowAuthPassword, Converter={x:Static BoolConverters.Not}}"
                                  Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                        <PathIcon Width="16" Height="16" Foreground="#888"
                                  IsVisible="{Binding ShowAuthPassword}"
                                  Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                      </Grid>
                    </ToggleButton>
                  </Grid>
                </StackPanel>
                <StackPanel IsVisible="{Binding IsAuthApiKey}" Spacing="6">
                  <TextBlock Text="Key name" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthApiKeyName}" Watermark="X-Api-Key"
                           Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                           Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                           controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
                  <TextBlock Text="Key value" Foreground="#888" FontSize="11"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding AuthApiKeyValue}"
                             Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                             Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                             PasswordChar="●"
                             IsVisible="{Binding ShowAuthApiKeyValue, Converter={x:Static BoolConverters.Not}}"
                             controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
                    <TextBox Grid.Column="0" Text="{Binding AuthApiKeyValue}"
                             Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                             Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                             IsVisible="{Binding ShowAuthApiKeyValue}"
                             controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
                    <ToggleButton Grid.Column="1" IsChecked="{Binding ShowAuthApiKeyValue}"
                                  Background="Transparent" BorderThickness="0"
                                  Margin="6,0,0,0"
                                  Padding="6,4" Cursor="Hand" VerticalAlignment="Center"
                                  ToolTip.Tip="Show/hide API key value">
                      <Grid>
                        <PathIcon Width="16" Height="16" Foreground="#888"
                                  IsVisible="{Binding ShowAuthApiKeyValue, Converter={x:Static BoolConverters.Not}}"
                                  Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                        <PathIcon Width="16" Height="16" Foreground="#888"
                                  IsVisible="{Binding ShowAuthApiKeyValue}"
                                  Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                      </Grid>
                    </ToggleButton>
                  </Grid>
                  <TextBlock Text="Add to" Foreground="#888" FontSize="11"/>
                  <ComboBox ItemsSource="{Binding ApiKeyLocations}" SelectedItem="{Binding AuthApiKeyIn}"
                            MinWidth="160" Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem>
            <TabItem.Header>
              <Panel>
                <TextBlock Text="Info"/>
                <Canvas Width="0" Height="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <Ellipse Canvas.Left="4" Canvas.Top="-3.5"
                           Width="7" Height="7"
                           Fill="#4ec9b0"
                           Opacity="{Binding IsInfoModified, Converter={x:Static conv:BoolToOpacityConverter.Instance}}"/>
                </Canvas>
              </Panel>
            </TabItem.Header>
            <ScrollViewer Margin="0,8" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="6">
                <TextBlock Text="Description" Foreground="#888" FontSize="11"/>
                <TextBox Text="{Binding Description, Mode=TwoWay}"
                         Watermark="Add a description for this request…"
                         Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                         Padding="8,6" AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="120" MaxHeight="400" FontSize="12"/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

        </TabControl>

        <!-- Row 1: Send error -->
            <Border Grid.Row="1"
                IsVisible="{Binding ErrorMessage, Converter={x:Static conv:StringNotEmptyConverter.Instance}}"
                Background="#3a1414" CornerRadius="3" Padding="10,6" Margin="0,4,0,0">
              <TextBlock Text="{Binding ErrorMessage}" Foreground="#f48771" FontSize="12" TextWrapping="Wrap"/>
            </Border>

      </Grid>
    </Border>

    <!-- Close guard popup — shown when closing a dirty named tab -->
    <Border IsVisible="{Binding PendingClose}"
            Background="#66000000">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,40,0,0"
              Width="300"
              Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="14,12"
              BoxShadow="0 4 20 0 #CC000000">
        <StackPanel Spacing="10">
          <TextBlock Foreground="#f0c060"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Text="Close without saving?"/>
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="6">
            <Button Content="Cancel" Command="{Binding CancelCloseCommand}"
                    Background="#3a3a3a" Foreground="#ccc" BorderThickness="0"
                    Padding="12,4" FontSize="11" CornerRadius="3"/>
            <Button Content="Discard" Command="{Binding DiscardAndCloseCommand}"
                    Background="#6c2020" Foreground="White" BorderThickness="0"
                    Padding="12,4" FontSize="11" CornerRadius="3"/>
            <Button Content="Save &amp; close" Command="{Binding SaveAndCloseCommand}"
                    Background="#1e7340" Foreground="White" BorderThickness="0"
                    Padding="12,4" FontSize="11" CornerRadius="3"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
    </Panel>

      <GridSplitter x:Name="ContentSplitter" Grid.Column="1" ResizeDirection="Columns"
                    Background="#4a4a4a" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

      <!-- RESPONSE VIEWER -->
      <Grid x:Name="ResponsePanel" Grid.Column="2" RowDefinitions="Auto,*">

      <Border Grid.Row="0" Background="#2d2d30" Padding="16,8">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16"
                      IsVisible="{Binding Response, Converter={x:Static conv:NotNullConverter.Instance}}">
            <Border CornerRadius="3" Padding="8,3"
                    Background="{Binding StatusBadgeColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}">
              <TextBlock Text="{Binding StatusDisplay}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
            </Border>
            <TextBlock Text="{Binding ElapsedDisplay}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SizeDisplay}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding HistoryResponseDisplay}"
                       ToolTip.Tip="{Binding HistoryResponseToolTip}"
                       Foreground="#dcdcaa"
                       FontSize="11"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsResponseFromHistory}"/>
          </StackPanel>
          <!-- Request History button (floats right) -->
          <Button Grid.Column="1"
                  Content="Request History"
                  Command="{Binding OpenRequestHistoryCommand}"
                  IsVisible="{Binding CanOpenRequestHistory}"
                  Background="Transparent"
                  Foreground="#9cdcfe"
                  BorderBrush="#555"
                  BorderThickness="1"
                  Padding="10,3"
                  CornerRadius="3"
                  FontSize="11"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Open history scoped to this request (Ctrl+H)"/>
        </Grid>
      </Border>

      <StackPanel Grid.Row="1" IsVisible="{Binding IsSending}"
                  VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="Sending..." Foreground="#888" FontSize="13" HorizontalAlignment="Center"/>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  IsVisible="{Binding Response, Converter={x:Static conv:NullConverter.Instance}}"
                  VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
        <TextBlock IsVisible="{Binding !IsSending}"
                   Text="Enter a URL and click Send"
                   Foreground="#777" FontSize="13" HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Response tab control: Preview | Headers -->
      <TabControl Grid.Row="1"
                  Classes="response-tabs"
                  Background="Transparent"
                  IsVisible="{Binding Response, Converter={x:Static conv:NotNullConverter.Instance}}">
        <TabItem Header="Preview">
          <controls:FilteredSyntaxViewer Text="{Binding FormattedResponseBody, FallbackValue='', Mode=OneWay}"
                                         Language="{Binding ResponseLanguage}"
                                         FilterExpression="{Binding ResponsePathFilterExpression, Mode=TwoWay}"/>
        </TabItem>
        <TabItem Header="Headers">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Margin="8" Spacing="0">
              <Border Background="#3a3a3a"
                      CornerRadius="4,4,0,0"
                      Padding="10,6"
                      IsVisible="{Binding HasResponseHeaders}">
                <Grid ColumnDefinitions="220,*">
                  <TextBlock Text="Header"
                             Foreground="#c5c5c5"
                             FontSize="11"
                             FontWeight="SemiBold"
                             LetterSpacing="0.4"/>
                  <TextBlock Grid.Column="1"
                             Text="Value"
                             Foreground="#c5c5c5"
                             FontSize="11"
                             FontWeight="SemiBold"
                             LetterSpacing="0.4"/>
                </Grid>
              </Border>

              <ItemsControl ItemsSource="{Binding ResponseHeaderRows}"
                            IsVisible="{Binding HasResponseHeaders}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ResponseHeaderRowViewModel">
                    <Border Background="{Binding RowBackground}"
                            BorderBrush="#3c3c3c"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                      <Grid ColumnDefinitions="220,*">
                        <SelectableTextBlock Text="{Binding Name}"
                                             Background="Transparent"
                                             Foreground="#d7d7d7"
                                             FontFamily="Consolas,Cascadia Mono,monospace"
                                             FontSize="12"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             TextWrapping="Wrap"/>
                        <SelectableTextBlock Grid.Column="1"
                                             Text="{Binding Value}"
                                             Background="Transparent"
                                             Foreground="#9cdcfe"
                                             FontFamily="Consolas,Cascadia Mono,monospace"
                                             FontSize="12"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             TextWrapping="Wrap"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="No response headers"
                         IsVisible="{Binding !HasResponseHeaders}"
                         Foreground="#777"
                         FontStyle="Italic"
                         FontSize="12"
                         Margin="2,4,0,0"/>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>

    </Grid>

  </Grid>

</DockPanel>

</UserControl>

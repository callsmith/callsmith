<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:conv="using:Callsmith.Desktop.Converters"
             xmlns:controls="using:Callsmith.Desktop.Controls"
             xmlns:views="using:Callsmith.Desktop.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="750"
             x:Class="Callsmith.Desktop.Views.RequestView"
             x:DataType="vm:RequestTabViewModel"
             Background="#1e1e1e">

  <UserControl.Styles>
    <Style Selector="TabControl.request-tabs TabItem">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="13,6"/>
      <Setter Property="MinHeight" Value="34"/>
    </Style>
  </UserControl.Styles>

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
  </UserControl.KeyBindings>

  <Grid RowDefinitions="0.45*,6,0.55*">

    <!-- REQUEST EDITOR -->
    <Panel Grid.Row="0">
    <Border Background="#252526" Padding="12,10">
      <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Row 0: Method + URL + Send/Cancel + Save -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,8,*,8,Auto,8,Auto">
          <ComboBox Grid.Column="0"
                    ItemsSource="{Binding HttpMethods}"
                    SelectedItem="{Binding SelectedMethod}"
                    MinWidth="120"
                    Foreground="{Binding MethodColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                    FontWeight="SemiBold" FontSize="13">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding .}"
                           Foreground="{Binding ., Converter={x:Static conv:HttpMethodToBrushConverter.Instance}}"
                           FontWeight="SemiBold"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBox Grid.Column="2"
                   Text="{Binding Url}"
                   Watermark="https://api.example.com/endpoint"
                   FontSize="13" Foreground="#d4d4d4" Background="#3c3c3c"
                   BorderBrush="#555" Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                   controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"/>
          <!-- Send (with cURL dropdown) / Cancel -->
          <Grid Grid.Column="4" ColumnDefinitions="*,1,Auto">
            <!-- Primary Send button -->
            <Button Grid.Column="0"
                    IsVisible="{Binding !IsSending}"
                    Content="Send" Command="{Binding SendCommand}"
                    Background="#0e639c" Foreground="White" FontWeight="SemiBold"
                    FontSize="14" Padding="28,6" CornerRadius="4,0,0,4"
                    BorderThickness="0" VerticalAlignment="Stretch"/>
            <!-- Divider between Send and dropdown arrow -->
            <Rectangle Grid.Column="1"
                       IsVisible="{Binding !IsSending}"
                       Fill="#0a4f7a" Width="1"
                       VerticalAlignment="Stretch"/>
            <!-- Dropdown arrow — opens flyout with extra actions -->
            <Button Grid.Column="2"
                    IsVisible="{Binding !IsSending}"
                    Background="#0e639c" Foreground="White" BorderThickness="0"
                    Padding="12,6" CornerRadius="0,4,4,0"
                    VerticalAlignment="Stretch"
                    ToolTip.Tip="More options">
              <Button.Content>
                <TextBlock Text="&#x25BE;" FontSize="13" VerticalAlignment="Center"/>
              </Button.Content>
              <Button.Flyout>
                <MenuFlyout x:CompileBindings="False">
                  <MenuItem Header="View as cURL…" Command="{Binding ViewCurlCommand}"/>
                </MenuFlyout>
              </Button.Flyout>
            </Button>
            <!-- Cancel — spans all columns while request is in-flight -->
            <Button Grid.Column="0" Grid.ColumnSpan="3"
                    IsVisible="{Binding IsSending}"
                    Content="Cancel" Command="{Binding SendCancelCommand}"
                    Background="#6c2020" Foreground="White" FontWeight="SemiBold"
                    FontSize="14" Padding="28,6" CornerRadius="4"
                    BorderThickness="0" VerticalAlignment="Stretch"/>
          </Grid>
          <!-- Save button — visible whenever the tab has unsaved changes -->
          <Button Grid.Column="6"
                  Content="{Binding SaveButtonLabel}"
                  Command="{Binding SaveCommand}"
                  IsVisible="{Binding TabIsDirty}"
                  Background="#1e7340" Foreground="White" FontWeight="SemiBold"
                  Padding="16,6" CornerRadius="4"
                  ToolTip.Tip="Save changes (Ctrl+S)"/>
        </Grid>

        <!-- Row 1: Preview URL bar -->
        <Border Grid.Row="1"
                Background="#1e1e1e" BorderBrush="#3a3a3a" BorderThickness="0,1,0,0"
                Padding="0,5,0,5" Margin="0,4,0,0">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0"
                       Text="PREVIEW" Foreground="#5a5a5a" FontSize="10" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="8,0,8,0"/>
            <TextBlock Grid.Column="1"
                       x:Name="PreviewUrlText"
                       Text="{Binding PreviewUrl}"
                       Foreground="{Binding PreviewUrlForeground, Converter={x:Static conv:HexColorToBrushConverter.Instance}}"
                       FontFamily="Consolas,Menlo,monospace" FontSize="12"
                       VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="2"
                    x:Name="CopyPreviewUrlButton"
                    Content="&#x2398;" ToolTip.Tip="Copy URL to clipboard"
                    Background="Transparent" Foreground="#888" BorderThickness="0"
                    Padding="6,2" FontSize="14" Cursor="Hand" Margin="6,0,0,0"/>
          </Grid>
        </Border>

        <!-- Row 2: Params | Headers | Body | Auth -->
        <TabControl Grid.Row="2" Classes="request-tabs" Margin="0,8,0,0" Background="Transparent">

          <TabItem Header="Params">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="0,4">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                <TextBlock Text="Path Params" Foreground="#9a9a9a"
                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="use {variable} syntax in the URL to add path params"
                           Foreground="#555" FontSize="11" FontStyle="Italic" VerticalAlignment="Center"/>
              </StackPanel>
              <Border Grid.Row="1"
                      IsVisible="{Binding HasUnresolvedPathParams}"
                      Background="#2d1e00" BorderBrush="#7a5010" BorderThickness="1"
                      CornerRadius="3" Padding="8,5" Margin="30,0,30,6">
                <TextBlock Text="&#x26A0;  One or more path params have no value."
                           Foreground="#c07a20" FontSize="11" TextWrapping="Wrap"/>
              </Border>
              <views:KeyValueEditorView Grid.Row="2" DataContext="{Binding PathParams}" Margin="0,0,0,10"/>
              <TextBlock Grid.Row="3" Text="Query Params" Foreground="#9a9a9a"
                         FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
              <views:KeyValueEditorView Grid.Row="4" DataContext="{Binding QueryParams}"/>
            </Grid>
          </TabItem>

          <TabItem Header="Headers">
            <views:KeyValueEditorView DataContext="{Binding Headers}" Margin="0,4"/>
          </TabItem>

          <TabItem Header="Body">
            <Grid RowDefinitions="Auto,*" Margin="0,8">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <ComboBox ItemsSource="{Binding BodyTypes}" SelectedItem="{Binding SelectedBodyType}"
                          MinWidth="160" Foreground="#d4d4d4" Background="#3c3c3c"
                          BorderBrush="#555"/>
                <Button Content="Format" Command="{Binding FormatBodyCommand}"
                        IsVisible="{Binding IsBodyJson}"
                        Background="Transparent" Foreground="#4ec9b0" BorderThickness="0"
                        Padding="0" FontSize="12" Cursor="Hand"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Pretty-print the JSON body"/>
              </StackPanel>
              <controls:SyntaxEditor x:Name="BodyEditor" Grid.Row="1"
                       Text="{Binding Body}" Language="{Binding BodyLanguage}"
                       controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}"
                       IsVisible="{Binding ShowTextBodyEditor}"/>
              <Panel Grid.Row="1" IsVisible="{Binding ShowFormBodyEditor}">
                <views:KeyValueEditorView DataContext="{Binding FormParams}"/>
              </Panel>
              <TextBlock Grid.Row="1" IsVisible="{Binding !ShowBodyEditor}"
                         Text="No body" Foreground="#888" FontSize="12"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </TabItem>

          <TabItem Header="Auth">
            <ScrollViewer Margin="0,8" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="8">
                <ComboBox ItemsSource="{Binding AuthTypes}" SelectedItem="{Binding AuthType}"
                          MinWidth="160" Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"/>
                <StackPanel IsVisible="{Binding IsAuthBearer}" Spacing="6">
                  <TextBlock Text="Token" Foreground="#888" FontSize="11"/>
                  <!-- Plain input when no segments -->
                  <TextBox Text="{Binding AuthTokenField.Text}"
                           Watermark="Enter bearer token..."
                           Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                           Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                           IsVisible="{Binding AuthTokenField.ShowPlainInput}"
                           controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}">
                    <TextBox.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthTokenField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthTokenField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </TextBox.ContextMenu>
                  </TextBox>
                  <!-- Pill view when segments are present -->
                  <Border Background="#3c3c3c" BorderBrush="#4ec9b0" BorderThickness="1"
                          CornerRadius="3" Padding="4,2" MinHeight="32"
                          IsVisible="{Binding AuthTokenField.HasSegments}">
                    <Border.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthTokenField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthTokenField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </Border.ContextMenu>
                    <Grid ColumnDefinitions="Auto,*">
                      <ItemsControl Grid.Column="0" ItemsSource="{Binding AuthTokenField.DisplaySegments}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SegmentedValueFieldViewModel+SegmentDisplayItem">
                            <StackPanel Orientation="Horizontal">
                              <TextBox Text="{Binding StaticText, Mode=TwoWay}" IsVisible="{Binding IsStatic}"
                                       Foreground="#cccccc" FontFamily="Consolas,Menlo,monospace" FontSize="11"
                                       VerticalAlignment="Center" VerticalContentAlignment="Center"
                                       Background="Transparent" BorderThickness="0" Padding="2,1" MinWidth="20" Watermark="…"
                                       controls:EnvVarCompletion.Suggestions="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).EnvVarNames}"/>
                              <Border Background="#1a3a2a" BorderBrush="#2a6a4a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsDynamic}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthTokenField.EditDynamicSegmentCommand}"
                                          CommandParameter="{Binding DynamicSegment}"
                                          Background="Transparent" Foreground="#4ec9b0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthTokenField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                              <Border Background="#2a1a3a" BorderBrush="#6a2a9a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsMockData}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthTokenField.EditMockSegmentCommand}"
                                          CommandParameter="{Binding MockDataSegment}"
                                          Background="Transparent" Foreground="#c586c0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthTokenField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>
                </StackPanel>
                <StackPanel IsVisible="{Binding IsAuthBasic}" Spacing="6">
                  <TextBlock Text="Username" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthUsernameField.Text}" Watermark="username"
                           Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                           Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                           IsVisible="{Binding AuthUsernameField.ShowPlainInput}"
                           controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}">
                    <TextBox.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthUsernameField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthUsernameField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </TextBox.ContextMenu>
                  </TextBox>
                  <Border Background="#3c3c3c" BorderBrush="#4ec9b0" BorderThickness="1"
                          CornerRadius="3" Padding="4,2" MinHeight="32"
                          IsVisible="{Binding AuthUsernameField.HasSegments}">
                    <Border.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthUsernameField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthUsernameField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </Border.ContextMenu>
                    <Grid ColumnDefinitions="Auto,*">
                      <ItemsControl Grid.Column="0" ItemsSource="{Binding AuthUsernameField.DisplaySegments}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SegmentedValueFieldViewModel+SegmentDisplayItem">
                            <StackPanel Orientation="Horizontal">
                              <TextBox Text="{Binding StaticText, Mode=TwoWay}" IsVisible="{Binding IsStatic}"
                                       Foreground="#cccccc" FontFamily="Consolas,Menlo,monospace" FontSize="11"
                                       VerticalAlignment="Center" VerticalContentAlignment="Center"
                                       Background="Transparent" BorderThickness="0" Padding="2,1" MinWidth="20" Watermark="…"
                                       controls:EnvVarCompletion.Suggestions="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).EnvVarNames}"/>
                              <Border Background="#1a3a2a" BorderBrush="#2a6a4a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsDynamic}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthUsernameField.EditDynamicSegmentCommand}"
                                          CommandParameter="{Binding DynamicSegment}"
                                          Background="Transparent" Foreground="#4ec9b0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthUsernameField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                              <Border Background="#2a1a3a" BorderBrush="#6a2a9a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsMockData}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthUsernameField.EditMockSegmentCommand}"
                                          CommandParameter="{Binding MockDataSegment}"
                                          Background="Transparent" Foreground="#c586c0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthUsernameField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>

                  <TextBlock Text="Password" Foreground="#888" FontSize="11"/>
                  <Grid IsVisible="{Binding AuthPasswordField.ShowPlainInput}" ColumnDefinitions="*,Auto">
                    <!-- Masked password input -->
                    <TextBox Grid.Column="0" Text="{Binding AuthPasswordField.Text}" Watermark="password"
                             Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                             Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                             PasswordChar="●"
                             IsVisible="{Binding ShowAuthPassword, Converter={x:Static BoolConverters.Not}}"
                             controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}">
                      <TextBox.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Dynamic Value…" Command="{Binding AuthPasswordField.AddDynamicValueCommand}"/>
                          <MenuItem Header="Mock Data…"     Command="{Binding AuthPasswordField.AddMockDataCommand}"/>
                        </ContextMenu>
                      </TextBox.ContextMenu>
                    </TextBox>
                    <!-- Plain text password input (revealed) -->
                    <TextBox Grid.Column="0" Text="{Binding AuthPasswordField.Text}" Watermark="password"
                             Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                             Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                             IsVisible="{Binding ShowAuthPassword}"
                             controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}">
                      <TextBox.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Dynamic Value…" Command="{Binding AuthPasswordField.AddDynamicValueCommand}"/>
                          <MenuItem Header="Mock Data…"     Command="{Binding AuthPasswordField.AddMockDataCommand}"/>
                        </ContextMenu>
                      </TextBox.ContextMenu>
                    </TextBox>
                    <!-- Eye toggle button -->
                    <ToggleButton Grid.Column="1" IsChecked="{Binding ShowAuthPassword}"
                                  Background="Transparent" BorderThickness="0"
                                  Padding="6,4" Cursor="Hand" VerticalAlignment="Center"
                                  ToolTip.Tip="Show/hide password">
                      <Grid>
                        <!-- Eye icon shown when password is hidden -->
                        <PathIcon Width="16" Height="16" Foreground="#888"
                                  IsVisible="{Binding ShowAuthPassword, Converter={x:Static BoolConverters.Not}}"
                                  Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                        <!-- Eye-slash icon shown when password is revealed -->
                        <PathIcon Width="16" Height="16" Foreground="#888"
                                  IsVisible="{Binding ShowAuthPassword}"
                                  Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                      </Grid>
                    </ToggleButton>
                  </Grid>
                  <Border Background="#3c3c3c" BorderBrush="#4ec9b0" BorderThickness="1"
                          CornerRadius="3" Padding="4,2" MinHeight="32"
                          IsVisible="{Binding AuthPasswordField.HasSegments}">
                    <Border.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthPasswordField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthPasswordField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </Border.ContextMenu>
                    <Grid ColumnDefinitions="Auto,*">
                      <ItemsControl Grid.Column="0" ItemsSource="{Binding AuthPasswordField.DisplaySegments}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SegmentedValueFieldViewModel+SegmentDisplayItem">
                            <StackPanel Orientation="Horizontal">
                              <TextBox Text="{Binding StaticText, Mode=TwoWay}" IsVisible="{Binding IsStatic}"
                                       Foreground="#cccccc" FontFamily="Consolas,Menlo,monospace" FontSize="11"
                                       VerticalAlignment="Center" VerticalContentAlignment="Center"
                                       Background="Transparent" BorderThickness="0" Padding="2,1" MinWidth="20" Watermark="…"
                                       controls:EnvVarCompletion.Suggestions="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).EnvVarNames}"/>
                              <Border Background="#1a3a2a" BorderBrush="#2a6a4a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsDynamic}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthPasswordField.EditDynamicSegmentCommand}"
                                          CommandParameter="{Binding DynamicSegment}"
                                          Background="Transparent" Foreground="#4ec9b0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthPasswordField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                              <Border Background="#2a1a3a" BorderBrush="#6a2a9a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsMockData}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthPasswordField.EditMockSegmentCommand}"
                                          CommandParameter="{Binding MockDataSegment}"
                                          Background="Transparent" Foreground="#c586c0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthPasswordField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>
                </StackPanel>
                <StackPanel IsVisible="{Binding IsAuthApiKey}" Spacing="6">
                  <TextBlock Text="Key name" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthApiKeyNameField.Text}" Watermark="X-Api-Key"
                           Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                           Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                           IsVisible="{Binding AuthApiKeyNameField.ShowPlainInput}"
                           controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}">
                    <TextBox.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthApiKeyNameField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthApiKeyNameField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </TextBox.ContextMenu>
                  </TextBox>
                  <Border Background="#3c3c3c" BorderBrush="#4ec9b0" BorderThickness="1"
                          CornerRadius="3" Padding="4,2" MinHeight="32"
                          IsVisible="{Binding AuthApiKeyNameField.HasSegments}">
                    <Border.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthApiKeyNameField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthApiKeyNameField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </Border.ContextMenu>
                    <Grid ColumnDefinitions="Auto,*">
                      <ItemsControl Grid.Column="0" ItemsSource="{Binding AuthApiKeyNameField.DisplaySegments}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SegmentedValueFieldViewModel+SegmentDisplayItem">
                            <StackPanel Orientation="Horizontal">
                              <TextBox Text="{Binding StaticText, Mode=TwoWay}" IsVisible="{Binding IsStatic}"
                                       Foreground="#cccccc" FontFamily="Consolas,Menlo,monospace" FontSize="11"
                                       VerticalAlignment="Center" VerticalContentAlignment="Center"
                                       Background="Transparent" BorderThickness="0" Padding="2,1" MinWidth="20" Watermark="…"
                                       controls:EnvVarCompletion.Suggestions="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).EnvVarNames}"/>
                              <Border Background="#1a3a2a" BorderBrush="#2a6a4a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsDynamic}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyNameField.EditDynamicSegmentCommand}"
                                          CommandParameter="{Binding DynamicSegment}"
                                          Background="Transparent" Foreground="#4ec9b0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyNameField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                              <Border Background="#2a1a3a" BorderBrush="#6a2a9a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsMockData}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyNameField.EditMockSegmentCommand}"
                                          CommandParameter="{Binding MockDataSegment}"
                                          Background="Transparent" Foreground="#c586c0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyNameField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>
                  <TextBlock Text="Key value" Foreground="#888" FontSize="11"/>
                  <!-- Plain input when no segments -->
                  <TextBox Text="{Binding AuthApiKeyValueField.Text}"
                           Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"
                           Padding="8,6" FontFamily="Consolas,Menlo,monospace"
                           IsVisible="{Binding AuthApiKeyValueField.ShowPlainInput}"
                           controls:EnvVarCompletion.Suggestions="{Binding EnvVarNames}">
                    <TextBox.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthApiKeyValueField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthApiKeyValueField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </TextBox.ContextMenu>
                  </TextBox>
                  <!-- Pill view when segments are present -->
                  <Border Background="#3c3c3c" BorderBrush="#4ec9b0" BorderThickness="1"
                          CornerRadius="3" Padding="4,2" MinHeight="32"
                          IsVisible="{Binding AuthApiKeyValueField.HasSegments}">
                    <Border.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Dynamic Value…" Command="{Binding AuthApiKeyValueField.AddDynamicValueCommand}"/>
                        <MenuItem Header="Mock Data…"     Command="{Binding AuthApiKeyValueField.AddMockDataCommand}"/>
                      </ContextMenu>
                    </Border.ContextMenu>
                    <Grid ColumnDefinitions="Auto,*">
                      <ItemsControl Grid.Column="0" ItemsSource="{Binding AuthApiKeyValueField.DisplaySegments}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SegmentedValueFieldViewModel+SegmentDisplayItem">
                            <StackPanel Orientation="Horizontal">
                              <TextBox Text="{Binding StaticText, Mode=TwoWay}" IsVisible="{Binding IsStatic}"
                                       Foreground="#cccccc" FontFamily="Consolas,Menlo,monospace" FontSize="11"
                                       VerticalAlignment="Center" VerticalContentAlignment="Center"
                                       Background="Transparent" BorderThickness="0" Padding="2,1" MinWidth="20" Watermark="…"
                                       controls:EnvVarCompletion.Suggestions="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).EnvVarNames}"/>
                              <Border Background="#1a3a2a" BorderBrush="#2a6a4a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsDynamic}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyValueField.EditDynamicSegmentCommand}"
                                          CommandParameter="{Binding DynamicSegment}"
                                          Background="Transparent" Foreground="#4ec9b0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyValueField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                              <Border Background="#2a1a3a" BorderBrush="#6a2a9a" BorderThickness="1"
                                      CornerRadius="10" Padding="6,2,2,2" Margin="2,2"
                                      IsVisible="{Binding IsMockData}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Content="{Binding PillLabel}"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyValueField.EditMockSegmentCommand}"
                                          CommandParameter="{Binding MockDataSegment}"
                                          Background="Transparent" Foreground="#c586c0" BorderThickness="0"
                                          Padding="0" FontFamily="Consolas,Menlo,monospace" FontSize="11" Cursor="Hand"/>
                                  <Button Content="×"
                                          Command="{Binding $parent[ItemsControl].((vm:RequestTabViewModel)DataContext).AuthApiKeyValueField.RemoveSegmentCommand}"
                                          CommandParameter="{Binding RawSegment}"
                                          Background="Transparent" Foreground="#888" BorderThickness="0"
                                          Padding="2,0" FontSize="12" Cursor="Hand"/>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>
                  <TextBlock Text="Add to" Foreground="#888" FontSize="11"/>
                  <ComboBox ItemsSource="{Binding ApiKeyLocations}" SelectedItem="{Binding AuthApiKeyIn}"
                            MinWidth="160" Foreground="#d4d4d4" Background="#3c3c3c" BorderBrush="#555"/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

        </TabControl>

        <!-- Row 3: Send error -->
        <Border Grid.Row="3"
                IsVisible="{Binding ErrorMessage, Converter={x:Static conv:StringNotEmptyConverter.Instance}}"
                Background="#3a1414" CornerRadius="3" Padding="10,6" Margin="0,4,0,0">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#f48771" FontSize="12" TextWrapping="Wrap"/>
        </Border>

      </Grid>
    </Border>

    <!-- Close guard popup — shown when closing a dirty named tab -->
    <Border IsVisible="{Binding PendingClose}"
            Background="#66000000">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,40,0,0"
              Width="300"
              Background="#2d2d30"
              BorderBrush="#555"
              BorderThickness="1"
              CornerRadius="6"
              Padding="14,12"
              BoxShadow="0 4 20 0 #CC000000">
        <StackPanel Spacing="10">
          <TextBlock Foreground="#f0c060"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Text="Close without saving?"/>
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="6">
            <Button Content="Cancel" Command="{Binding CancelCloseCommand}"
                    Background="#3a3a3a" Foreground="#ccc" BorderThickness="0"
                    Padding="12,4" FontSize="11" CornerRadius="3"/>
            <Button Content="Discard" Command="{Binding DiscardAndCloseCommand}"
                    Background="#6c2020" Foreground="White" BorderThickness="0"
                    Padding="12,4" FontSize="11" CornerRadius="3"/>
            <Button Content="Save &amp; close" Command="{Binding SaveAndCloseCommand}"
                    Background="#1e7340" Foreground="White" BorderThickness="0"
                    Padding="12,4" FontSize="11" CornerRadius="3"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
    </Panel>

    <GridSplitter Grid.Row="1" ResizeDirection="Rows"
                  Background="#4a4a4a" HorizontalAlignment="Stretch"/>

    <!-- RESPONSE VIEWER -->
    <Grid Grid.Row="2" RowDefinitions="Auto,*">

      <Border Grid.Row="0" Background="#2d2d30" Padding="16,8"
              IsVisible="{Binding Response, Converter={x:Static conv:NotNullConverter.Instance}}">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <Border CornerRadius="3" Padding="8,3"
                  Background="{Binding StatusBadgeColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}">
            <TextBlock Text="{Binding StatusDisplay}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
          </Border>
          <TextBlock Text="{Binding ElapsedDisplay}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding SizeDisplay}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="1" IsVisible="{Binding IsSending}"
                  VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="Sending..." Foreground="#888" FontSize="13" HorizontalAlignment="Center"/>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  IsVisible="{Binding Response, Converter={x:Static conv:NullConverter.Instance}}"
                  VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
        <TextBlock IsVisible="{Binding !IsSending}"
                   Text="Enter a URL and click Send"
                   Foreground="#777" FontSize="13" HorizontalAlignment="Center"/>
      </StackPanel>

      <controls:SyntaxEditor Grid.Row="1"
                    IsVisible="{Binding Response, Converter={x:Static conv:NotNullConverter.Instance}}"
                    Text="{Binding FormattedResponseBody, FallbackValue='', Mode=OneWay}"
                    Language="{Binding ResponseLanguage}"
                    IsReadOnly="True"/>

    </Grid>

  </Grid>

</UserControl>

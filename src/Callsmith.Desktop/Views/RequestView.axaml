<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Callsmith.Desktop.ViewModels"
             xmlns:views="using:Callsmith.Desktop.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="750"
             x:Class="Callsmith.Desktop.Views.RequestView"
             x:DataType="vm:RequestViewModel"
             Background="#1e1e1e">

  <UserControl.Styles>
    <Style Selector="TabControl.request-tabs TabItem">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="13,6"/>
      <Setter Property="MinHeight" Value="34"/>
    </Style>
  </UserControl.Styles>

  <!-- Request pane (top 45%) + Response pane (bottom 55%) — both always visible -->
  <Grid RowDefinitions="0.45*,6,0.55*">

    <!-- ==================================================================
         REQUEST EDITOR
         ================================================================== -->
    <Border Grid.Row="0"
            Background="#252526"
            Padding="12,10">
      <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Title bar: request name + unsaved indicator + Save button -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              IsVisible="{Binding HasSourceRequest}"
              Margin="0,0,0,8">
          <StackPanel Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center">
            <TextBlock Text="&#x25CF;"
                       Foreground="#f48771"
                       FontSize="10"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasUnsavedChanges}"/>
            <TextBlock Text="{Binding RequestName}"
                       Foreground="#bbb"
                       FontSize="11"
                       FontStyle="Italic"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <Button Grid.Column="1"
                  Content="Save"
                  Command="{Binding SaveCommand}"
                  IsVisible="{Binding HasUnsavedChanges}"
                  Background="#1e7340"
                  Foreground="White"
                  Padding="12,3"
                  FontSize="11"
                  CornerRadius="4"/>
        </Grid>

        <!-- Method selector + URL bar + Send / Cancel -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,8,*,8,Auto"
              Margin="0,0,0,0">

          <ComboBox Grid.Column="0"
                    ItemsSource="{Binding HttpMethods}"
                    SelectedItem="{Binding SelectedMethod}"
                    MinWidth="120"
                    Foreground="{Binding MethodColor, Converter={x:Static vm:HexColorToBrushConverter.Instance}}"
                    FontWeight="SemiBold"
                    FontSize="13">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding .}"
                           Foreground="{Binding ., Converter={x:Static vm:HttpMethodToBrushConverter.Instance}}"
                           FontWeight="SemiBold"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBox Grid.Column="2"
                   Text="{Binding Url}"
                   Watermark="https://api.example.com/endpoint"
                   FontSize="13"
                   Foreground="#d4d4d4"
                   Background="#3c3c3c"
                   BorderBrush="#555"
                   Padding="8,6"
                   FontFamily="Consolas,Menlo,monospace"/>

          <Button Grid.Column="4"
                  IsVisible="{Binding !IsSending}"
                  Content="Send"
                  Command="{Binding SendCommand}"
                  Background="#0e639c"
                  Foreground="White"
                  FontWeight="SemiBold"
                  Padding="20,6"
                  CornerRadius="4"/>

          <Button Grid.Column="4"
                  IsVisible="{Binding IsSending}"
                  Content="Cancel"
                  Command="{Binding SendCancelCommand}"
                  Background="#6c2020"
                  Foreground="White"
                  FontWeight="SemiBold"
                  Padding="20,6"
                  CornerRadius="4"/>

        </Grid>

        <!-- URL Preview bar -->
        <Border Grid.Row="2"
                Background="#1e1e1e"
                BorderBrush="#3a3a3a"
                BorderThickness="0,1,0,0"
                Padding="0,5,0,5"
                Margin="0,4,0,0">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0"
                       Text="PREVIEW"
                       Foreground="#5a5a5a"
                       FontSize="10"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="8,0,8,0"/>
            <TextBlock Grid.Column="1"
                       x:Name="PreviewUrlText"
                       Text="{Binding PreviewUrl}"
                       Foreground="#888"
                       FontFamily="Consolas,Menlo,monospace"
                       FontSize="12"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="2"
                    x:Name="CopyPreviewUrlButton"
                    Content="&#x2398;"
                    ToolTip.Tip="Copy URL to clipboard"
                    Background="Transparent"
                    Foreground="#888"
                    BorderThickness="0"
                    Padding="6,2"
                    FontSize="14"
                    Cursor="Hand"
                    Margin="6,0,0,0"/>
          </Grid>
        </Border>

        <!-- Tabs: Params | Headers | Body | Auth -->
        <TabControl Grid.Row="3"
                    Classes="request-tabs"
                    Margin="0,8,0,0"
                    Background="Transparent">

          <!-- PARAMS -->
          <TabItem Header="Params">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  Margin="0,4">
              <TextBlock Grid.Row="0"
                         Text="Path Params"
                         Foreground="#9a9a9a"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Margin="0,0,0,4"/>
              <views:KeyValueEditorView Grid.Row="1"
                                        DataContext="{Binding PathParams}"
                                        Margin="0,0,0,10"/>

              <TextBlock Grid.Row="2"
                         Text="Query Params"
                         Foreground="#9a9a9a"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Margin="0,0,0,4"/>
              <views:KeyValueEditorView Grid.Row="3"
                                        DataContext="{Binding QueryParams}"/>
            </Grid>
          </TabItem>

          <!-- HEADERS -->
          <TabItem Header="Headers">
            <views:KeyValueEditorView DataContext="{Binding Headers}"
                                      Margin="0,4"/>
          </TabItem>

          <!-- BODY -->
          <TabItem Header="Body">
            <Grid RowDefinitions="Auto,*" Margin="0,8">
              <ComboBox Grid.Row="0"
                        ItemsSource="{Binding BodyTypes}"
                        SelectedItem="{Binding SelectedBodyType}"
                        MinWidth="160"
                        Foreground="#d4d4d4"
                        Background="#3c3c3c"
                        BorderBrush="#555"
                        Margin="0,0,0,8"/>
              <TextBox Grid.Row="1"
                       Text="{Binding Body}"
                       IsVisible="{Binding ShowBodyEditor}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       FontFamily="Consolas,Menlo,monospace"
                       FontSize="12"
                       Foreground="#d4d4d4"
                       Background="#1e1e1e"
                       BorderBrush="#444"
                       Padding="8"/>
              <TextBlock Grid.Row="1"
                         IsVisible="{Binding !ShowBodyEditor}"
                         Text="No body"
                         Foreground="#888"
                         FontSize="12"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Grid>
          </TabItem>

          <!-- AUTH -->
          <TabItem Header="Auth">
            <ScrollViewer Margin="0,8"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="8">

                <ComboBox ItemsSource="{Binding AuthTypes}"
                          SelectedItem="{Binding AuthType}"
                          MinWidth="160"
                          Foreground="#d4d4d4"
                          Background="#3c3c3c"
                          BorderBrush="#555"/>

                <!-- Bearer token -->
                <StackPanel IsVisible="{Binding IsAuthBearer}" Spacing="6">
                  <TextBlock Text="Token" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthToken}"
                           Watermark="Enter bearer token..."
                           Foreground="#d4d4d4"
                           Background="#3c3c3c"
                           BorderBrush="#555"
                           Padding="8,6"
                           FontFamily="Consolas,Menlo,monospace"/>
                </StackPanel>

                <!-- Basic auth -->
                <StackPanel IsVisible="{Binding IsAuthBasic}" Spacing="6">
                  <TextBlock Text="Username" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthUsername}"
                           Foreground="#d4d4d4"
                           Background="#3c3c3c"
                           BorderBrush="#555"
                           Padding="8,6"/>
                  <TextBlock Text="Password" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthPassword}"
                           PasswordChar="*"
                           Foreground="#d4d4d4"
                           Background="#3c3c3c"
                           BorderBrush="#555"
                           Padding="8,6"/>
                </StackPanel>

                <!-- API key -->
                <StackPanel IsVisible="{Binding IsAuthApiKey}" Spacing="6">
                  <TextBlock Text="Key name" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthApiKeyName}"
                           Watermark="X-Api-Key"
                           Foreground="#d4d4d4"
                           Background="#3c3c3c"
                           BorderBrush="#555"
                           Padding="8,6"
                           FontFamily="Consolas,Menlo,monospace"/>
                  <TextBlock Text="Key value" Foreground="#888" FontSize="11"/>
                  <TextBox Text="{Binding AuthApiKeyValue}"
                           Foreground="#d4d4d4"
                           Background="#3c3c3c"
                           BorderBrush="#555"
                           Padding="8,6"
                           FontFamily="Consolas,Menlo,monospace"/>
                  <TextBlock Text="Add to" Foreground="#888" FontSize="11"/>
                  <ComboBox ItemsSource="{Binding ApiKeyLocations}"
                            SelectedItem="{Binding AuthApiKeyIn}"
                            MinWidth="160"
                            Foreground="#d4d4d4"
                            Background="#3c3c3c"
                            BorderBrush="#555"/>
                </StackPanel>

              </StackPanel>
            </ScrollViewer>
          </TabItem>

        </TabControl>

        <!-- Error message (below tabs) -->
        <Border Grid.Row="4"
                IsVisible="{Binding ErrorMessage, Converter={x:Static vm:StringNotEmptyConverter.Instance}}"
                Background="#3a1414"
                CornerRadius="3"
                Padding="10,6"
                Margin="0,4,0,0">
          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="#f48771"
                     FontSize="12"
                     TextWrapping="Wrap"/>
        </Border>

      </Grid>
    </Border>

    <!-- Splitter -->
    <GridSplitter Grid.Row="1"
                  ResizeDirection="Rows"
                  Background="#4a4a4a"
                  HorizontalAlignment="Stretch"/>

    <!-- ==================================================================
         RESPONSE VIEWER
         ================================================================== -->
    <Grid Grid.Row="2" RowDefinitions="Auto,*">

      <!-- Response meta bar -->
      <Border Grid.Row="0"
              Background="#2d2d30"
              Padding="16,8"
              IsVisible="{Binding Response, Converter={x:Static vm:NotNullConverter.Instance}}">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <Border CornerRadius="3" Padding="8,3" Background="{Binding StatusBadgeColor, Converter={x:Static vm:HexColorToBrushConverter.Instance}}">
            <TextBlock Text="{Binding StatusDisplay}"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="12"/>
          </Border>
          <TextBlock Text="{Binding ElapsedDisplay}"
                     Foreground="#888"
                     FontSize="12"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding SizeDisplay}"
                     Foreground="#888"
                     FontSize="12"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Sending indicator -->
      <StackPanel Grid.Row="1"
                  IsVisible="{Binding IsSending}"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="8">
        <TextBlock Text="Sending&#x2026;"
                   Foreground="#888"
                   FontSize="13"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Empty state -->
      <StackPanel Grid.Row="1"
                  IsVisible="{Binding Response, Converter={x:Static vm:NullConverter.Instance}}"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="4">
        <TextBlock IsVisible="{Binding !IsSending}"
                   Text="Enter a URL and click Send"
                   Foreground="#777"
                   FontSize="13"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Response body -->
      <ScrollViewer Grid.Row="1"
                    IsVisible="{Binding Response, Converter={x:Static vm:NotNullConverter.Instance}}"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <TextBox Text="{Binding Response.Body, FallbackValue=''}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas,Menlo,monospace"
                 FontSize="12"
                 Foreground="#d4d4d4"
                 Background="#1e1e1e"
                 BorderThickness="0"
                 Padding="16"/>
      </ScrollViewer>

    </Grid>

  </Grid>

</UserControl>
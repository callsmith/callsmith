<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Callsmith.Desktop.ViewModels"
        xmlns:conv="using:Callsmith.Desktop.Converters"
        x:Class="Callsmith.Desktop.Views.ImportCollectionDialog"
        x:DataType="vm:ImportCollectionViewModel"
        Title="Import Collection"
        Icon="/Assets/callsmith.ico"
        Width="560" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#252526"
        ShowInTaskbar="False">

  <StackPanel Spacing="14" Margin="24,20">

    <!-- Header -->
    <TextBlock Text="Import collection from another API tool"
               Foreground="#d4d4d4"
               FontSize="14"
               FontWeight="SemiBold"/>

    <!-- Mode toggle (only visible when a collection is already open) -->
    <Border IsVisible="{Binding HasCurrentCollectionOption}"
            Background="#2d2d2d"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12,10">
      <StackPanel Spacing="6">
        <TextBlock Text="Import mode"
                   Foreground="#aaa"
                   FontSize="11"
                   FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Spacing="20">
          <RadioButton Content="Create new collection"
                       Foreground="#d4d4d4"
                       FontSize="12"
                       IsChecked="{Binding IsImportIntoCurrentCollection,
                                           Mode=TwoWay,
                                           Converter={x:Static BoolConverters.Not}}"/>
          <RadioButton Content="Import into current collection"
                       Foreground="#d4d4d4"
                       FontSize="12"
                       IsChecked="{Binding IsImportIntoCurrentCollection, Mode=TwoWay}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Import type -->
    <Grid ColumnDefinitions="110,10,*">
      <TextBlock Grid.Column="0"
                 Text="Import type"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <ComboBox Grid.Column="2"
                ItemsSource="{Binding ImportTypeOptions}"
                SelectedItem="{Binding SelectedImportType, Mode=TwoWay}"
                HorizontalAlignment="Stretch"
                Foreground="#d4d4d4"
                Background="#3c3c3c"
                BorderBrush="#555"
                FontSize="12"
                VerticalContentAlignment="Center">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ImportCollectionViewModel+ImportTypeOption">
            <TextBlock Text="{Binding Name}"
                       Opacity="{Binding IsEnabled, Converter={x:Static conv:BoolToOpacityConverter.Instance}}"
                       FontSize="12"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </Grid>

    <!-- Files to import -->
    <Grid ColumnDefinitions="110,10,*,8,Auto">
      <TextBlock Grid.Column="0"
                 Text="Files to import"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <TextBox Grid.Column="2"
               Text="{Binding FilePath}"
               Watermark="Select one or more collection files…"
               Foreground="#d4d4d4"
               Background="#3c3c3c"
               BorderBrush="#555"
               Padding="8,5"
               FontSize="12"
               IsReadOnly="True"
               ToolTip.Tip="{Binding FilePath}"/>
      <Button Grid.Column="4"
              Content="Browse…"
              Command="{Binding BrowseFileCommand}"
              CommandParameter="{Binding $parent[Window].StorageProvider}"
              Background="#3a3a3a"
              Foreground="#ccc"
              BorderThickness="0"
              Padding="10,5"
              FontSize="12"
              CornerRadius="3"
              ToolTip.Tip="Choose one or more collection files to import (different formats may be mixed)"/>
    </Grid>

    <!-- Path to folder (new-collection mode only) -->
    <Grid ColumnDefinitions="110,10,*,8,Auto"
          IsVisible="{Binding !IsImportIntoCurrentCollection}">
      <TextBlock Grid.Column="0"
                 Text="Path to folder"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <TextBox Grid.Column="2"
               Text="{Binding FolderPath}"
               Watermark="Select a destination folder…"
               Foreground="#d4d4d4"
               Background="#3c3c3c"
               BorderBrush="#555"
               Padding="8,5"
               FontSize="12"
               IsReadOnly="True"/>
      <Button Grid.Column="4"
              Content="Browse…"
              Command="{Binding BrowseFolderCommand}"
              CommandParameter="{Binding $parent[Window].StorageProvider}"
              Background="#3a3a3a"
              Foreground="#ccc"
              BorderThickness="0"
              Padding="10,5"
              FontSize="12"
              CornerRadius="3"
              ToolTip.Tip="Choose the folder to import into"/>
    </Grid>

    <!-- Sub-folder path (import-into-current mode only) -->
    <Grid ColumnDefinitions="110,10,*"
          IsVisible="{Binding IsImportIntoCurrentCollection}">
      <TextBlock Grid.Column="0"
                 Text="Target sub-folder"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <TextBox Grid.Column="2"
               Text="{Binding SubFolderPath}"
               Watermark="Leave blank to import at collection root"
               Foreground="#d4d4d4"
               Background="#3c3c3c"
               BorderBrush="#555"
               Padding="8,5"
               FontSize="12"
               ToolTip.Tip="Optional relative path within the collection (e.g. 'Orders/Internal'). Leave blank to import at the collection root."/>
    </Grid>

    <!-- Non-empty folder warning -->
    <Border IsVisible="{Binding IsNonEmptyFolderWarningVisible}"
            Background="#3a2a10"
            BorderBrush="#b87020"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12,10">
      <StackPanel Spacing="10">
        <TextBlock TextWrapping="Wrap"
                   Foreground="#e0a040"
                   FontSize="12"
                   Text="We strongly suggest importing into an empty folder. Would you like to proceed anyway?"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Content="Proceed Anyway"
                  Command="{Binding ProceedAnywayCommand}"
                  Background="#b87020"
                  Foreground="White"
                  BorderThickness="0"
                  Padding="12,5"
                  FontSize="11"
                  CornerRadius="3"/>
          <Button Content="Go Back"
                  Command="{Binding CancelWarningCommand}"
                  Background="#3a3a3a"
                  Foreground="#ccc"
                  BorderThickness="0"
                  Padding="12,5"
                  FontSize="11"
                  CornerRadius="3"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Error message -->
    <TextBlock Text="{Binding ErrorMessage}"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               Foreground="#f48771"
               FontSize="11"
               TextWrapping="Wrap"/>

    <!-- Import / Cancel buttons -->
    <Grid ColumnDefinitions="*,Auto,10,Auto"
          IsVisible="{Binding !IsNonEmptyFolderWarningVisible}"
          Margin="0,4,0,4">
      <Button Grid.Column="1"
              Content="Import"
              Command="{Binding ImportCommand}"
              IsEnabled="{Binding !IsImporting}"
              Background="#0e639c"
              Foreground="White"
              BorderThickness="0"
              Padding="20,7"
              FontSize="12"
              CornerRadius="4"/>
      <Button Grid.Column="3"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsEnabled="{Binding !IsImporting}"
              Background="#3a3a3a"
              Foreground="#ccc"
              BorderThickness="0"
              Padding="14,7"
              FontSize="12"
              CornerRadius="4"/>
    </Grid>

  </StackPanel>

</Window>

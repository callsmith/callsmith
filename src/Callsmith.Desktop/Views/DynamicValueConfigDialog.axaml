<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Callsmith.Desktop.ViewModels"
        xmlns:conv="using:Callsmith.Desktop.Converters"
        x:Class="Callsmith.Desktop.Views.DynamicValueConfigDialog"
        x:DataType="vm:DynamicValueConfigViewModel"
        Title="Dynamic Value"
        Icon="/Assets/callsmith.ico"
        Width="520" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#252526"
        ShowInTaskbar="False">

  <StackPanel Spacing="12" Margin="20,18,20,18">

    <TextBlock Text="Configure Dynamic Value"
               Foreground="#d4d4d4"
               FontSize="14"
               FontWeight="SemiBold"/>

    <TextBlock TextWrapping="Wrap"
               Foreground="#888"
               FontSize="11">
      Select a request to execute and a JSONPath expression to extract its response value.
    </TextBlock>

    <!-- Request search + dropdown -->
    <Grid ColumnDefinitions="110,10,*">
      <TextBlock Grid.Column="0"
                 Text="Request"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <AutoCompleteBox Grid.Column="2"
                       ItemsSource="{Binding AvailableRequests}"
                       Text="{Binding SelectedRequest, Mode=TwoWay}"
                       FilterMode="Contains"
                       MinimumPrefixLength="0"
                       MaxDropDownHeight="220"
                       HorizontalAlignment="Stretch"
                       Foreground="#d4d4d4"
                       Background="#3c3c3c"
                       BorderBrush="#555"
                       FontFamily="Consolas,Menlo,monospace"
                       FontSize="12"
                       Padding="8,4"
                       Watermark="Search requests…">
        <AutoCompleteBox.Styles>
          <!-- AutoCompleteBox has no VerticalContentAlignment; target its inner TextBox -->
          <Style Selector="AutoCompleteBox TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
          </Style>
        </AutoCompleteBox.Styles>
        <AutoCompleteBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding .}"
                       FontFamily="Consolas,Menlo,monospace"
                       FontSize="12"/>
          </DataTemplate>
        </AutoCompleteBox.ItemTemplate>
      </AutoCompleteBox>
    </Grid>

    <!-- Frequency dropdown -->
    <Grid ColumnDefinitions="110,10,*">
      <TextBlock Grid.Column="0"
                 Text="Frequency"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <ComboBox Grid.Column="2"
                ItemsSource="{Binding FrequencyOptions}"
                SelectedItem="{Binding SelectedFrequency, Mode=TwoWay}"
                HorizontalAlignment="Stretch"
                Foreground="#d4d4d4"
                Background="#3c3c3c"
                BorderBrush="#555"
                FontSize="12"
                Padding="8,0"
                VerticalContentAlignment="Center">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:DynamicValueConfigViewModel+FrequencyOption">
            <TextBlock Text="{Binding Label}" FontSize="12"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </Grid>

    <!-- Lifetime (seconds) — visible only when "If Expired" is selected -->
    <Grid ColumnDefinitions="110,10,*"
          IsVisible="{Binding IsIfExpiredSelected}">
      <TextBlock Grid.Column="0"
                 Text="Lifetime (s)"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <NumericUpDown Grid.Column="2"
                     Value="{Binding ExpiresAfterSeconds, Mode=TwoWay}"
                     Minimum="1"
                     Maximum="86400"
                     Increment="60"
                     FormatString="0"
                     Foreground="#d4d4d4"
                     Background="#3c3c3c"
                     BorderBrush="#555"
                     FontSize="12"
                     Padding="6,0"
                     VerticalContentAlignment="Center"
                     VerticalAlignment="Center"
                     ToolTip.Tip="Cache lifetime in seconds (e.g. 900 = 15 minutes)"/>
    </Grid>

    <!-- JSONPath expression -->
    <Grid ColumnDefinitions="110,10,*">
      <TextBlock Grid.Column="0"
                 Text="JSONPath"
                 Foreground="#aaa"
                 FontSize="12"
                 VerticalAlignment="Center"/>
      <TextBox Grid.Column="2"
               Text="{Binding Path}"
               Watermark="e.g. $.access_token"
               Foreground="#d4d4d4"
               Background="#3c3c3c"
               BorderBrush="#555"
               FontFamily="Consolas,Menlo,monospace"
               FontSize="12"
               Padding="8,0"
               VerticalContentAlignment="Center"/>
    </Grid>

    <!-- Preview area -->
    <Border Background="#1e1e1e"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            CornerRadius="3"
            Padding="10,8">
      <Grid RowDefinitions="Auto,Auto,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="PREVIEW"
                     Foreground="#666"
                     FontSize="9"
                     FontWeight="SemiBold"
                     LetterSpacing="1"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1"
                  Content="▶ Test"
                  Command="{Binding PreviewCommand}"
                  Background="#1a4a2a"
                  Foreground="#4ec9b0"
                  BorderThickness="0"
                  Padding="10,3"
                  CornerRadius="3"
                  FontSize="11"
                  IsEnabled="{Binding !IsPreviewLoading}"
                  ToolTip.Tip="Execute the request and show the extracted value"/>
        </Grid>

        <!-- Preview loading indicator -->
        <TextBlock Grid.Row="1"
                   Text="Running request…"
                   Foreground="#888"
                   FontSize="11"
                   Margin="0,6,0,0"
                   IsVisible="{Binding IsPreviewLoading}"/>

        <!-- Preview result -->
        <Border Grid.Row="1"
                IsVisible="{Binding PreviewResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#1a2a1a"
                CornerRadius="2"
                Padding="6,4"
                Margin="0,6,0,0">
          <TextBlock Text="{Binding PreviewResult}"
                     Foreground="#4ec9b0"
                     FontFamily="Consolas,Menlo,monospace"
                     FontSize="11"
                     TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Preview error -->
        <TextBlock Grid.Row="2"
                   Text="{Binding PreviewError}"
                   Foreground="#f48771"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0"
                   IsVisible="{Binding PreviewError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      </Grid>
    </Border>

    <!-- Confirm / Cancel buttons -->
    <Grid ColumnDefinitions="*,Auto,10,Auto" Margin="0,4,0,0">
      <Button Grid.Column="1"
              Content="OK"
              Command="{Binding ConfirmCommand}"
              Background="#1e7340"
              Foreground="White"
              BorderThickness="0"
              Padding="24,7"
              FontSize="12"
              CornerRadius="4"
              ToolTip.Tip="Apply this dynamic value configuration"/>
      <Button Grid.Column="3"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              Background="#3a3a3a"
              Foreground="#ccc"
              BorderThickness="0"
              Padding="14,7"
              FontSize="12"
              CornerRadius="4"/>
    </Grid>

  </StackPanel>

</Window>

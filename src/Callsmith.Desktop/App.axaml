<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Callsmith.Desktop.App"
             xmlns:local="using:Callsmith.Desktop"
             xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:editSearch="clr-namespace:AvaloniaEdit.Search;assembly=AvaloniaEdit"
             xmlns:folding="clr-namespace:AvaloniaEdit.Folding;assembly=AvaloniaEdit"
             RequestedThemeVariant="Dark">
             <!-- Force native Fluent dark theme for consistent desktop UX. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml"/>
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="avaloniaEdit|TextEditor">
            <!-- Replace bright default white folding boxes with subtle dark/accent markers. -->
            <Setter Property="folding:FoldingMargin.FoldingMarkerBrush" Value="#7A8A9A"/>
            <Setter Property="folding:FoldingMargin.FoldingMarkerBackgroundBrush" Value="#1E2A34"/>
            <Setter Property="folding:FoldingMargin.SelectedFoldingMarkerBrush" Value="#9EC2FF"/>
            <Setter Property="folding:FoldingMargin.SelectedFoldingMarkerBackgroundBrush" Value="#27456A"/>
        </Style>
        <Style Selector="editSearch|SearchPanel ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D6772"/>
            <Setter Property="Background" Value="#222A32"/>
            <Setter Property="Foreground" Value="#C8D0D8"/>
        </Style>
        <Style Selector="editSearch|SearchPanel ToggleButton:pointerover">
            <Setter Property="Background" Value="#2A3440"/>
            <Setter Property="BorderBrush" Value="#7C8A98"/>
        </Style>
        <Style Selector="editSearch|SearchPanel ToggleButton:checked">
            <Setter Property="Background" Value="#2F4F74"/>
            <Setter Property="BorderBrush" Value="#8CB5E6"/>
            <Setter Property="Foreground" Value="#F3F8FF"/>
        </Style>
        <!-- Disable the built-in TextBox undo history so Ctrl+Z is routed exclusively
             to the application-level UndoRedoService via the MainWindow key binding. -->
        <Style Selector="TextBox">
            <Setter Property="UndoLimit" Value="0"/>
        </Style>
    </Application.Styles>
</Application>